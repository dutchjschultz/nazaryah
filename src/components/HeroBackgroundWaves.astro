---
// Alternative animated canvas background with flowing wave patterns
// Represents wind/breath/spirit with smooth, organic waves
---

<canvas id="hero-canvas-waves" class="absolute inset-0 w-full h-full"></canvas>

<script>
  class Wave {
    amplitude: number;
    frequency: number;
    speed: number;
    offset: number;
    yPosition: number;
    opacity: number;

    constructor(canvas: HTMLCanvasElement, index: number) {
      this.amplitude = Math.random() * 50 + 40;
      this.frequency = Math.random() * 0.004 + 0.003;
      this.speed = Math.random() * 0.5 + 0.3;
      this.offset = Math.random() * Math.PI * 2;
      this.yPosition = (canvas.height / 6) * index + Math.random() * 80;
      this.opacity = Math.random() * 0.25 + 0.15;
    }

    update() {
      this.offset += this.speed * 0.01;
    }

    draw(ctx: CanvasRenderingContext2D, canvas: HTMLCanvasElement, color: string) {
      ctx.strokeStyle = color;
      ctx.globalAlpha = this.opacity;
      ctx.lineWidth = 2.5;
      ctx.lineCap = 'round';
      ctx.beginPath();

      for (let x = 0; x < canvas.width; x += 5) {
        const y = this.yPosition + Math.sin(x * this.frequency + this.offset) * this.amplitude;
        if (x === 0) {
          ctx.moveTo(x, y);
        } else {
          ctx.lineTo(x, y);
        }
      }

      ctx.stroke();
      ctx.globalAlpha = 1;
    }
  }

  function initWavesCanvas() {
    const canvas = document.getElementById('hero-canvas-waves') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let waves: Wave[] = [];
    let animationFrameId: number;

    // Set canvas size
    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;

      // Reinitialize waves on resize
      waves = [];
      const waveCount = 8;
      for (let i = 0; i < waveCount; i++) {
        waves.push(new Wave(canvas, i));
      }
    }

    // Get color based on theme
    function getWaveColor(): string {
      const isDark = document.documentElement.classList.contains('dark');
      return isDark ? 'rgba(212, 168, 95, 0.8)' : 'rgba(139, 38, 53, 0.8)';
    }

    // Animation loop
    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const color = getWaveColor();

      waves.forEach(wave => {
        wave.update();
        wave.draw(ctx, canvas, color);
      });

      animationFrameId = requestAnimationFrame(animate);
    }

    // Initialize
    resizeCanvas();
    animate();

    // Handle resize
    let resizeTimeout: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(resizeCanvas, 250);
    });

    // Cleanup on navigation
    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(animationFrameId);
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWavesCanvas);
  } else {
    initWavesCanvas();
  }
</script>

<style>
  #hero-canvas-waves {
    pointer-events: none;
    opacity: 0.7;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    #hero-canvas-waves {
      display: none;
    }
  }
</style>
