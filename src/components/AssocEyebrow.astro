---
// src/components/AssocEyebrow.astro  ·  V2
// Persistent (not hover-only) cluster-label eyebrow for a study card in a
// listing. Renders nothing when the study has no associations.
import { labelsFor } from "../data/associations.js";

const { post } = Astro.props;
const labels = labelsFor({ associations: post?.data?.associations || [] });
---

{labels.length > 0 && <p class="assoc-eyebrow">{labels.join(" · ")}</p>}

<style>
  .assoc-eyebrow { font-family: var(--font-display); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); margin: 0 0 0.35rem; line-height: 1.4; }
  :global(.dark) .assoc-eyebrow { color: var(--gold-light); }
</style>
