---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border-strong)] dark:border-[var(--color-dark-border-strong)] bg-[var(--color-surface-elevated)] dark:bg-[var(--color-dark-surface-elevated)] mt-20">
  <div class="container mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- About -->
      <div>
        <h3 class="font-serif text-lg font-semibold mb-4 text-[var(--color-accent)] dark:text-[var(--color-dark-accent)]">
          Nazaryah
        </h3>
        <p class="text-sm text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed">
          A modern biblical studies platform emphasizing original languages, fresh perspectives, and rich contextual understanding.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-sans text-base font-semibold mb-4 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
          Quick Links
        </h3>
        <ul class="space-y-3 text-sm font-sans">
          <li>
            <a href="/about" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>About Us</span>
            </a>
          </li>
          <li>
            <a href="/blog" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>Blog & Studies</span>
            </a>
          </li>
          <li>
            <a href="/contact" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>Contact</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-sans text-base font-semibold mb-4 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
          Resources
        </h3>
        <ul class="space-y-3 text-sm font-sans">
          <li>
            <a href="/blog?category=exegetical" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>Exegetical Studies</span>
            </a>
          </li>
          <li>
            <a href="/blog?category=theological" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>Theological Themes</span>
            </a>
          </li>
          <li>
            <a href="/blog?category=historical" class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors inline-flex items-center gap-1">
              <span>Historical Context</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)] mt-10 pt-8 text-center">
      <p class="text-sm text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] font-sans">
        &copy; {currentYear} Nazaryah. All rights reserved. | Exploring Scripture with scholarly integrity.
      </p>
    </div>
  </div>
</footer>
