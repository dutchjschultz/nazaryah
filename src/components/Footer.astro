---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer mt-6" data-pagefind-ignore>
  <div class="w-full px-8 md:px-12 py-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start max-w-none">
      <!-- About -->
      <div>
        <h3 class="text-base font-semibold mb-2 tracking-widest uppercase text-sm" style="font-family: var(--font-display);">
          Nazaryah
        </h3>
        <p class="text-sm leading-relaxed" style="color: var(--stone-light); font-family: var(--font-body);">
          A modern biblical studies platform emphasizing original languages, fresh perspectives, and rich contextual understanding.
        </p>
      </div>

      <!-- Stay Updated (replaces Quick Links) -->
      <div class="text-center">
        <h3 class="text-base font-semibold mb-2 tracking-widest uppercase text-sm" style="font-family: var(--font-display);">
          Stay Updated
        </h3>
        <p class="text-sm mb-3 leading-relaxed mx-auto" style="color: var(--stone-light); font-family: var(--font-body); max-width: 26rem;">
          New studies, straight to your inbox. No spam.
        </p>
        <form class="stay-updated-form flex gap-0 max-w-md mx-auto">
          <input
            type="email"
            placeholder="Your email"
            class="input-field flex-1 text-sm su-input"
            required
          />
          <button
            type="submit"
            class="btn btn-stone px-4 py-2 text-sm whitespace-nowrap su-btn"
          >
            Subscribe
          </button>
        </form>
      </div>

      <!-- Resources -->
      <div class="md:text-right">
        <h3 class="text-base font-semibold mb-2 tracking-widest uppercase text-sm" style="font-family: var(--font-display);">
          Resources
        </h3>
        <ul class="space-y-1.5 text-sm" style="font-family: var(--font-body);">
          <li>
            <a href="/blog?category=exegetical" class="inline-flex items-center gap-1">
              <span>Exegetical Studies</span>
            </a>
          </li>
          <li>
            <a href="/blog?category=theological" class="inline-flex items-center gap-1">
              <span>Theological Themes</span>
            </a>
          </li>
          <li>
            <a href="/blog?category=historical" class="inline-flex items-center gap-1">
              <span>Historical Context</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[rgba(139,125,107,0.25)] mt-4 pt-3 text-center">
      <p class="text-xs" style="color: var(--stone); font-family: var(--font-display); letter-spacing: 1px;">
        &copy; {currentYear} Nazaryah. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  /* Visually join the email input and Subscribe button as a single group */
  .stay-updated-form .su-input {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-right-width: 0;
  }
  .stay-updated-form .su-btn {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
  }
</style>
