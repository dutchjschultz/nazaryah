---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Blog', href: '/blog' },
  { name: 'Pathways', href: '/pathways' },
  { name: 'Glossary', href: '/glossary' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] dark:border-[var(--color-dark-border)] bg-[var(--color-surface)]/95 dark:bg-[var(--color-dark-surface)]/95 backdrop-blur-sm">
  <nav class="container mx-auto px-6 py-5">
    <div class="flex items-center justify-between">
      <a href="/" class="no-underline group">
        <Logo variant="full" />
      </a>

      <div class="hidden md:flex items-center space-x-8">
        <ul class="flex space-x-8 font-sans">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'text-base font-medium transition-colors relative',
                  currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                    ? 'text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] after:absolute after:bottom-[-4px] after:left-0 after:right-0 after:h-[2px] after:bg-[var(--color-accent)] dark:after:bg-[var(--color-dark-accent)]'
                    : 'text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)]'
                ]}
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
        <ThemeToggle />
      </div>

      <!-- Mobile: Theme Toggle + Menu Button -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          class="p-2 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-6 pb-4 border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)] pt-4">
      <ul class="space-y-4 font-sans">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block text-base font-medium transition-colors py-2 px-3 rounded-lg',
                currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                  ? 'text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] bg-[var(--color-surface-elevated)] dark:bg-[var(--color-dark-surface-elevated)]'
                  : 'text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] hover:bg-[var(--color-surface-elevated)] dark:hover:bg-[var(--color-dark-surface-elevated)]'
              ]}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    button?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  });
</script>
