---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Blog', href: '/blog' },
  { name: 'Trinity', href: '/trinity' },
  { name: 'Pathways', href: '/pathways' },
  { name: 'Glossary', href: '/glossary' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--sand-dark)] dark:border-[rgba(139,125,107,0.25)] bg-[var(--parchment)]/95 dark:bg-[var(--deep-earth)]/95 backdrop-blur-sm" data-pagefind-ignore>
  <nav class="container mx-auto px-6 py-5">
    <div class="flex items-center justify-between">
      <a href="/" class="no-underline group">
        <Logo variant="full" />
      </a>

      <div class="hidden md:flex items-center space-x-8">
        <ul class="flex space-x-2">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'nav-link',
                  (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) ? 'active' : ''
                ]}
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
        <button
          data-search-trigger
          aria-label="Open search"
          class="p-2 rounded transition-colors hover:bg-[rgba(139,105,20,0.1)]"
          style="color: var(--ink-faded);"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <ThemeToggle />
      </div>

      <!-- Mobile: Theme Toggle + Menu Button -->
      <div class="flex items-center gap-2 md:hidden">
        <button
          data-search-trigger
          aria-label="Open search"
          class="p-2 transition-colors hover:bg-[rgba(139,105,20,0.1)] rounded"
          style="color: var(--ink-faded);"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          class="p-2 text-[var(--ink)] dark:text-[var(--sand-light)]"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-6 pb-4 border-t border-[var(--sand-dark)] pt-4">
      <ul class="space-y-2">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'nav-link-mobile',
                (currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))) ? 'active' : ''
              ]}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');

    button?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  });
</script>
