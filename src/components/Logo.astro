---
// Logo component — uses the Nazaryah logo image at /public/images/nazaryah-logo.png
interface Props {
  variant?: 'full' | 'icon-only';
  className?: string;
}
const { variant = 'full', className = '' } = Astro.props;
---

{variant === 'full' ? (
  <div class={`logo-full ${className}`}>
    <img
      src="/images/nazaryah-logo.png"
      alt="Nazaryah — Separated Unto Yah"
      class="logo-img"
      loading="eager"
      decoding="async"
    />
  </div>
) : (
  <img
    src="/images/nazaryah-logo.png"
    alt="Nazaryah"
    class={`logo-img logo-icon-only ${className}`}
    loading="eager"
    decoding="async"
  />
)}

<style>
  .logo-full {
    display: inline-flex;
    align-items: center;
  }
  .logo-img {
    display: block;
    height: 88px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    transition: opacity 0.25s ease;
  }
  .logo-full:hover .logo-img,
  .logo-icon-only:hover {
    opacity: 0.9;
  }
  .logo-icon-only {
    height: 64px;
    width: 64px;
  }
  @media (max-width: 900px) {
    .logo-img { height: 72px; }
  }
  @media (max-width: 640px) {
    .logo-img { height: 56px; }
  }
</style>
