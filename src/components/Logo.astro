---
// Logo component — uses the Nazaryah mountain/desert logo image.
// The source image lives at /public/images/nazaryah-logo.png — replace that
// file to update the logo site-wide.
interface Props {
  variant?: 'full' | 'icon-only';
  className?: string;
}

const { variant = 'full', className = '' } = Astro.props;
---

{variant === 'full' ? (
  <div class={`logo-full ${className}`}>
    <img
      src="/images/nazaryah-logo.png"
      alt="Nazaryah"
      class="logo-img"
      width="220"
      height="56"
      loading="eager"
      decoding="async"
    />
  </div>
) : (
  <img
    src="/images/nazaryah-logo.png"
    alt="Nazaryah"
    class={`logo-img logo-icon-only ${className}`}
    width="56"
    height="56"
    loading="eager"
    decoding="async"
  />
)}

<style>
  .logo-full {
    display: inline-flex;
    align-items: center;
  }
  .logo-img {
    display: block;
    height: 56px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .logo-full:hover .logo-img,
  .logo-icon-only:hover {
    opacity: 0.88;
  }
  /* Icon-only variant — square crop */
  .logo-icon-only {
    height: 48px;
    width: 48px;
  }
  @media (max-width: 640px) {
    .logo-img { height: 44px; }
  }
</style>
