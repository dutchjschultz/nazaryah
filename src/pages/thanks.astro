---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Message Received — Nazaryah"
  description="Thank you for reaching out to Nazaryah."
>
  <div class="py-24 md:py-32">
    <div class="container mx-auto px-6">
      <div class="max-w-lg mx-auto text-center">
        <div class="card p-12">
          <h1 class="text-3xl font-bold mb-4" style="font-family: var(--font-display); color: var(--deep-earth);">
            Message Received
          </h1>
          <p class="text-lg mb-8" style="color: var(--ink-faded);">
            Thank you for reaching out. We'll get back to you as soon as we can.
          </p>
          <a href="/" class="btn btn-stone px-8 py-3">
            Return Home
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
