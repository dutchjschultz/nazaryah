---
// src/pages/associations/[key].astro  ·  V2
// One cluster, every member. Anchor (★) first. The "See all" target from the
// panel. Ported from the React reference to Astro + site theme.
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getCluster, clusterKeys, membersOf, isAnchorOf, toStudy } from "../../data/associations.js";

export function getStaticPaths() {
  return clusterKeys().map((key) => ({ params: { key } }));
}

const { key } = Astro.params;
const cluster = getCluster(key);
const all = (await getCollection("posts", (p) => !p.data.draft)).map(toStudy);
const members = membersOf(key, all);
---

<BaseLayout
  title={`${cluster.label} — Associations | Nazaryah`}
  description={cluster.blurb}
>
  <main class="cluster-page">
    <a href="/associations" class="back">← All associations</a>

    <h1>{cluster.label}</h1>
    {cluster.blurb && <p class="blurb">{cluster.blurb}</p>}
    <p class="count">{members.length} {members.length === 1 ? "study" : "studies"}</p>

    {members.length === 0 ? (
      <p class="empty">Nothing written yet.</p>
    ) : (
      <ul class="list">
        {members.map((s) => (
          <li class="item">
            <a href={`/blog/${s.slug}`} class="link">
              {s.title}
              {isAnchorOf(s, key) && <span class="anchor" title="Main study"><span aria-hidden="true"> ★</span><span class="sr-only">Main study</span></span>}
            </a>
            {s.deck && <span class="deck">{s.deck}</span>}
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>

<style>
  .cluster-page { max-width: 44rem; margin: 0 auto; padding: 3rem 1.5rem; font-family: var(--font-body); }
  .back { font-size: 0.8rem; color: var(--gold); text-decoration: none; font-style: italic; }
  :global(.dark) .back { color: var(--gold-light); }
  .back:hover { text-decoration: underline; }

  h1 { font-family: var(--font-display); font-size: 2rem; color: var(--ink); margin: 1.5rem 0 0.5rem; }
  :global(.dark) h1 { color: var(--color-dark-text); }
  .blurb { font-style: italic; color: var(--ink-faded); margin: 0 0 0.5rem; line-height: 1.5; max-width: 46ch; }
  :global(.dark) .blurb { color: var(--color-dark-secondary-text); }
  .count { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sand-dark); margin: 0 0 2.5rem; }

  .empty { color: var(--gold); font-style: italic; }
  :global(.dark) .empty { color: var(--gold-light); }

  .list { list-style: none; margin: 0; padding: 0 0 0 1.25rem; border-left: 2px solid var(--gold); }
  :global(.dark) .list { border-left-color: var(--gold-light); }
  .item { margin-bottom: 1.25rem; }
  .link { display: block; color: var(--ink); font-family: var(--font-display); font-weight: 700; font-size: 1.08rem; text-decoration: none; line-height: 1.3; }
  :global(.dark) .link { color: var(--color-dark-text); }
  .link:hover { color: var(--gold); }
  :global(.dark) .link:hover { color: var(--gold-light); }
  .anchor { color: var(--gold); font-size: 0.8em; }
  :global(.dark) .anchor { color: var(--gold-light); }
  .deck { display: block; font-style: italic; font-size: 0.9rem; color: var(--ink-faded); margin-top: 0.15rem; max-width: 54ch; }
  :global(.dark) .deck { color: var(--color-dark-secondary-text); }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
</style>
