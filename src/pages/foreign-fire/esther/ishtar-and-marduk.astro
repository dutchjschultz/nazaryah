---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

// ONE SOURCE: the study text lives in the posts collection and is rendered here
// inside the Foreign Fire skin. Same words as /blog/esther-ishtar-marduk.
const entry = await getEntry('posts', 'esther-ishtar-marduk');
const { Content } = await entry.render();
const { title, description, deck } = entry.data;

const blogUrl = '/blog/esther-ishtar-marduk';
const companionUrl = '/foreign-fire/esther/the-star-on-the-flag';
---

<BaseLayout
  title={`${title} — Nazaryah`}
  description={description}
  canonical={blogUrl}
>
  <div class="ff-wrap">

    <!-- ── HERO ── -->
    <section class="ff-hero">
      <a href="/foreign-fire/esther" class="ff-back">&#8592; Esther</a>
      <p class="ff-label">&#8213; Foreign Fire &middot; Esther &middot; Study 1 &#8213;</p>
      <h1 class="ff-title">{title}</h1>
      <p class="ff-sub">{deck}</p>
    </section>

    <!-- ── BODY (rendered from the shared markdown, Foreign Fire skin) ── -->
    <section class="ff-section">
      <div class="ff-prose ff-markdown">
        <Content />
      </div>
    </section>

    <!-- ── COMPANION (stays inside Foreign Fire) ── -->
    <section class="ff-section ff-section-alt">
      <div class="ff-companion">
        <p class="ff-companion-label">Companion Study</p>
        <p class="ff-companion-text">The same trail, followed to the flag over Jerusalem.</p>
        <a href={companionUrl} class="ff-companion-link">The Star on the Flag &#8594;</a>
      </div>
    </section>

    <!-- ── THE ONE DOOR OUT ── -->
    <section class="ff-blogcta">
      <a href={blogUrl} class="ff-blog-button">Read as a blog post &#8594;</a>
    </section>

  </div>
</BaseLayout>

<style>
  .ff-wrap {
    background: linear-gradient(180deg, #0a0402 0%, #1a0a04 20%, #140805 100%);
    color: #f0d8b8;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
  }

  .ff-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid #3a1408;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(200, 70, 20, 0.22), transparent 70%),
      linear-gradient(180deg, #0a0402 0%, #1a0a04 100%);
  }

  .ff-back {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 2px;
    color: #8a4820;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }
  .ff-back:hover { color: #d46020; }

  .ff-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #a84a1a;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .ff-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #f5deb3;
    margin: 0 0 0.85rem;
    line-height: 1.15;
    text-shadow: 0 0 30px rgba(200, 70, 20, 0.2);
  }

  .ff-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #d49555;
    font-style: italic;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ff-section {
    padding: 3.5rem 1.5rem;
    border-bottom: 1px solid #2a0f06;
  }
  .ff-section-alt { background: rgba(30, 12, 6, 0.4); }

  .ff-prose {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.85;
    color: #d9c2a0;
  }

  /* ── Skin the rendered markdown with the Foreign Fire theme ── */
  .ff-markdown :global(p) { margin-bottom: 1.4rem; }
  .ff-markdown :global(em) { color: #d49555; font-style: italic; }
  .ff-markdown :global(strong) { color: #f0c888; font-weight: 600; }
  .ff-markdown :global(a) { color: #d46020; text-decoration: underline; }

  .ff-markdown :global(h2) {
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    letter-spacing: 1.5px;
    color: #d49555;
    text-transform: uppercase;
    margin: 3rem 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(168, 74, 26, 0.3);
  }
  .ff-markdown :global(h2:first-child) { margin-top: 0; }

  .ff-markdown :global(h3) {
    font-family: 'Cinzel', serif;
    font-size: 1.05rem;
    letter-spacing: 1.5px;
    color: #c4884a;
    text-transform: uppercase;
    margin: 2rem 0 1rem;
  }

  .ff-markdown :global(blockquote) {
    border-left: 2px solid #a84a1a;
    padding: 1rem 1.25rem;
    margin: 1.75rem 0;
    background: rgba(40, 16, 8, 0.4);
    border-radius: 0 4px 4px 0;
    font-style: italic;
    color: #d9b885;
  }
  .ff-markdown :global(blockquote p) { margin: 0; }

  .ff-markdown :global(ul) { list-style: none; padding: 0; margin: 1rem 0 1.5rem; }
  .ff-markdown :global(li) {
    padding: 0.6rem 0 0.6rem 1.5rem;
    border-bottom: 1px solid rgba(168, 74, 26, 0.12);
    position: relative;
    color: #d9c2a0;
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .ff-markdown :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.15rem;
    width: 5px;
    height: 5px;
    background: #a84a1a;
    transform: rotate(45deg);
  }

  .ff-markdown :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.98rem;
  }
  .ff-markdown :global(th), .ff-markdown :global(td) {
    border: 1px solid #3a1a0e;
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .ff-markdown :global(th) { color: #c4884a; font-family: 'Cinzel', serif; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; }

  /* ── COMPANION ── */
  .ff-companion {
    max-width: 720px;
    margin: 0 auto;
    background: linear-gradient(180deg, rgba(60, 24, 10, 0.6) 0%, rgba(40, 16, 8, 0.6) 100%);
    border: 1px solid #4a2010;
    border-left: 4px solid #d46020;
    border-radius: 4px;
    padding: 1.75rem 2rem;
    text-align: center;
  }
  .ff-companion-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 3px;
    color: #d46020;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }
  .ff-companion-text { color: #d9b885; font-size: 1.05rem; line-height: 1.7; margin: 0 0 1rem; }
  .ff-companion-link {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #d46020;
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(212, 96, 32, 0.5);
    border-radius: 20px;
    transition: all 0.2s;
    font-weight: 600;
  }
  .ff-companion-link:hover { background: rgba(212, 96, 32, 0.12); color: #f0c888; border-color: #d46020; }

  /* ── THE ONE DOOR OUT ── */
  .ff-blogcta {
    text-align: center;
    padding: 3rem 1.5rem 4rem;
    background: linear-gradient(180deg, #0a0402 0%, #040201 100%);
  }
  .ff-blog-button {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #f0d8b8;
    text-decoration: none;
    padding: 0.85rem 2rem;
    border: 1px solid #a84a1a;
    border-radius: 3px;
    background: rgba(168, 74, 26, 0.12);
    transition: all 0.2s;
    font-weight: 600;
  }
  .ff-blog-button:hover { background: rgba(212, 96, 32, 0.25); color: #fff; border-color: #d46020; }
</style>
