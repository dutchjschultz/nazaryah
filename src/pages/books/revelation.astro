      </section>

      <div style="height: 100px;"></div>
    </div>

    <!-- ─── READER SECTION ─── -->
    <div id="reader-section" style="display:none">

      <!-- Toolbar -->
      <div class="rd-bar">
        <button id="reader-back-btn" class="rd-back-btn">← Back to book</button>
        <button id="chapter-toggle-btn" class="rd-chapter-btn">
          <span id="chapter-indicator" class="rd-ch-indicator">I</span>
          <span id="chapter-of"> of XXII — Chapter index</span>
          <span id="chapter-toggle-arrow" class="rd-toggle-arrow">▼</span>
        </button>
        <button id="rd-spread-btn" class="rd-book-view-btn" title="Book view">⊞ Book View</button>
      </div>

      <!-- Chapter selector -->
      <div id="chapter-selector" style="display:none" class="rd-selector">
        <div class="rd-selector-label">JUMP TO CHAPTER</div>
        <div class="rd-selector-grid">
          {chapters.map((ch) => (
            <>
              <button class="rd-selector-item" data-chapter={ch.num}>
                <span class="rd-sel-num">{toRoman(ch.num)}</span>
                <span class="rd-sel-title">{ch.title}</span>
              </button>
              {ch.num === 17 && (
                <button class="rd-selector-item rd-sel-appeal" data-panel="court-appeal-2">
                  <span class="rd-sel-num">CA</span>
