      <!-- Amazon card -->
      <aside class="bk-amz">
        <div class="bk-amz-spine-wrap">
          <div class="bk-amz-spine">
            <div class="bk-amz-spine-text">The Courtroom of Heaven</div>
          </div>
        </div>
        <div class="bk-amz-body">
          <div class="bk-amz-kicker">
            <span class="bk-amz-diamond">◆</span>
            <span class="bk-amz-kicker-text">AVAILABLE IN PRINT</span>
          </div>
          <h3 class="bk-amz-title">The Courtroom of Heaven</h3>
          <p class="bk-amz-sub">Revelation Putting Modern Teaching on Trial</p>
          <div class="bk-amz-meta">
            <span>by Dutch Schultz</span><span class="bk-dot">·</span>
            <span>First Edition</span><span class="bk-dot">·</span>
            <span>Paperback</span><span class="bk-dot">·</span>
