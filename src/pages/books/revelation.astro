---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ACCENT = '#8B2828';

const chapters = [
  { num: 1,  title: 'Summons to the Court',         templeledger: 'Lampstands Inspected', subtitle: 'The gavel falls; the King calls all.' },
  { num: 2,  title: 'Letters as Indictments',        templeledger: 'Charges Filed',         subtitle: 'Seven charges, no defense counsel.' },
  { num: 3,  title: 'Witness of the Faithful',       templeledger: 'Altar Blood Entered',   subtitle: 'Blood speaks louder than swords.' },
  { num: 4,  title: 'The Throne Convened',           templeledger: 'Court Assembled',       subtitle: 'Heaven stands; earth trembles.' },
  { num: 5,  title: 'The Lamb Takes Exhibit A',      templeledger: 'Worthiness Confirmed',  subtitle: 'Wounds entered as evidence; the Scroll yields.' },
  { num: 6,  title: 'Seals Break the Case',          templeledger: 'Case Seals Broken',     subtitle: 'Each seal snaps; the case unravels.' },
  { num: 7,  title: 'Protected Under Oath',          templeledger: 'Firstfruits Sealed',    subtitle: 'Sealed in the record, shielded from sentence.' },
  { num: 8,  title: 'Trumpets Sound Contempt',       templeledger: 'Warnings Issued',       subtitle: 'Before the blaze — seven warnings on the record.' },
  { num: 9,  title: 'Woe Sentence Announced',        templeledger: 'Abyss Unsealed',        subtitle: 'When the pit breathes, the court goes silent.' },
  { num: 10, title: 'Open Scroll Testimony',         templeledger: 'Scroll Consumed',       subtitle: 'Sweet to receive, bitter to testify.' },
  { num: 11, title: 'Measured and Marked',           templeledger: 'Courts Measured',       subtitle: 'The court is measured; the remnant stands.' },
  { num: 12, title: 'War Over Custody',              templeledger: 'Dragon Cast Down',      subtitle: 'The dragon contests; the court overrules.' },
  { num: 13, title: 'False Claims Enforced',         templeledger: 'Strange Fire Offered',  subtitle: 'A forged crown demands your allegiance.' },
  { num: 14, title: 'Harvest of the Convicted',      templeledger: 'Sickle Through Vine',   subtitle: 'Ripe rebellion meets the blade.' },
  { num: 15, title: 'Bowls of Final Wrath',          templeledger: 'Bowls Emptied',         subtitle: 'Cup by cup, the sentence pours.' },
  { num: 16, title: 'It Is Done',                    templeledger: 'Final Word Spoken',     subtitle: 'Final word — no appeal.' },
  { num: 17, title: 'Babylon Found Guilty',          templeledger: 'Harlot Judged Unclean',  subtitle: 'The perfume fades; the chains hold.' },
  { num: 18, title: 'Merchants\u2019 Court Lament',  templeledger: 'Commerce Condemned',    subtitle: 'Gold weeps when idols burn.' },
  { num: 19, title: 'The Rider\u2019s Verdict',      templeledger: 'King Rides in White',   subtitle: 'Truth takes the stand; falsehood is sentenced.' },
  { num: 20, title: 'The Binding Order',             templeledger: 'Serpent Chained',       subtitle: 'Chained for a season; released for a final test.' },
  { num: 21, title: 'Great White Sentencing',        templeledger: 'Books Unsealed',        subtitle: 'Books open; hearts exposed.' },
  { num: 22, title: 'New Creation Decree',           templeledger: 'Holy City Descends',    subtitle: 'Old world ends; new dawn sings.' },
];

function toRoman(n: number) {
  const map: [string, number][] = [
    ['M',1000],['CM',900],['D',500],['CD',400],
    ['C',100],['XC',90],['L',50],['XL',40],
    ['X',10],['IX',9],['V',5],['IV',4],['I',1]
  ];
  let r = '';
  for (const [l, v] of map) { while (n >= v) { r += l; n -= v; } }
  return r;
}
---

<BaseLayout
  title="The Courtroom of Heaven — Nazaryah"
  description="Revelation Putting Modern Teaching on Trial. The case was filed in the Old Testament, argued through the prophets, and closed in Revelation."
>
  <div class="bk-root">

    <!-- ─── BOOK DETAILS SECTION ─── -->
    <div id="book-details">

      <a href="/books" class="bk-back">← The Bookshelf</a>

