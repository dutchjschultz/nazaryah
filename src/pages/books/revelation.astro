---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ACCENT = '#8B2828';

const chapters = [
  { num: 1,  title: 'Summons to the Court',         templeledger: 'Lampstands Inspected', subtitle: 'The gavel falls; the King calls all.' },
  { num: 2,  title: 'Letters as Indictments',        templeledger: 'Charges Filed',         subtitle: 'Seven charges, no defense counsel.' },
  { num: 3,  title: 'Witness of the Faithful',       templeledger: 'Altar Blood Entered',   subtitle: 'Blood speaks louder than swords.' },
  { num: 4,  title: 'The Throne Convened',           templeledger: 'Court Assembled',       subtitle: 'Heaven stands; earth trembles.' },
  { num: 5,  title: 'The Lamb Takes Exhibit A',      templeledger: 'Worthiness Confirmed',  subtitle: 'Wounds entered as evidence; the Scroll yields.' },
  { num: 6,  title: 'Six Seals Broken',              templeledger: '',                      subtitle: 'The First Testimonies Enter the Record' },
  { num: 7,  title: 'Sealed and Standing',           templeledger: '',                      subtitle: 'The 144,000 and the Great Multitude' },
  { num: 8,  title: 'Silence, Then Fire',            templeledger: '',                      subtitle: 'The Seventh Seal and the First Four Trumpets' },
  { num: 9,  title: 'Key to the Abyss',              templeledger: '',                      subtitle: 'The Fifth and Sixth Trumpets' },
  { num: 10, title: 'The Mighty Angel',              templeledger: '',                      subtitle: "The Little Scroll and the Prophet's Commission" },
  { num: 11, title: 'Measured and Witnessed',        templeledger: '',                      subtitle: 'The Two Witnesses and the Seventh Trumpet' },
  { num: 12, title: 'War in Heaven',                 templeledger: '',                      subtitle: 'The Woman, the Dragon, and the Male Child' },
  { num: 13, title: 'Beasts and Allegiance',         templeledger: '',                      subtitle: 'The Mark, the Image, and the Count' },
  { num: 14, title: 'Harvest of the Earth',          templeledger: '',                      subtitle: 'Three Angels and Two Reapings' },
  { num: 15, title: 'Bowls of Completion',           templeledger: '',                      subtitle: 'Preparation for the Final Judgments' },
  { num: 16, title: 'Armageddon Gathered',           templeledger: '',                      subtitle: 'The Seven Bowls of Wrath' },
  { num: 17, title: 'Mystery Babylon Exposed',       templeledger: '',                      subtitle: 'The Woman on the Scarlet Beast' },
  { num: 18, title: 'One Hour Collapse',             templeledger: '',                      subtitle: 'The Fall of Babylon the Great' },
  { num: 19, title: 'Rider in White',                templeledger: '',                      subtitle: 'The Marriage of the Lamb and the Return of the King' },
  { num: 20, title: 'The Thousand-Year Reign',       templeledger: '',                      subtitle: 'Satan Bound, the Millennium, and the Final Rebellion' },
  { num: 21, title: 'Great White Throne',            templeledger: '',                      subtitle: 'Final Judgment and the New Creation Begins' },
  { num: 22, title: 'All Things New',                templeledger: '',                      subtitle: 'The New Jerusalem and the Tree of Life Restored' },
];

function toRoman(n: number) {
  const map: [string, number][] = [
    ['M',1000],['CM',900],['D',500],['CD',400],
    ['C',100],['XC',90],['L',50],['XL',40],
    ['X',10],['IX',9],['V',5],['IV',4],['I',1]
  ];
  let r = '';
  for (const [l, v] of map) { while (n >= v) { r += l; n -= v; } }
  return r;
}
