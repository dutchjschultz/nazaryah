        <!-- ─── Chapters VI–XXII ─── -->
        {chapters.filter(ch => ch.num > 5).map((ch) => (
          <div class="rd-chapter-panel" id={`chapter-${ch.num}`} style="display:none">
            <header class="rd-page-header">
              <div class="rd-docket-rule"></div>
              <div class="rd-docket-label">C H A P T E R &nbsp; {toRoman(ch.num)}</div>
              <h1 class="rd-page-title">{ch.title}</h1>
              {ch.templeledger && <div class="rd-ledger">TEMPLE LEDGER: {ch.templeledger.toUpperCase()}</div>}
              <p class="rd-page-sub">{ch.subtitle}</p>
              <div class="rd-docket-rule"></div>
            </header>
            <div class="rd-page-body">
              <p class="rd-placeholder">[ Chapter {ch.num} content — coming soon. ]</p>
            </div>
            <footer class="rd-page-footer">
              <div class="rd-pf-left">The Courtroom of Heaven</div>
              <div class="rd-pf-center">{toRoman(ch.num)}</div>
              <div class="rd-pf-right">nazaryah.com</div>
            </footer>
          </div>
        ))}
      </article>

      <!-- Prev / Next -->
      <nav class="rd-nav" id="rd-nav">
        <button id="rd-prev-btn" class="rd-nav-btn" style="text-align:left">
          <div class="rd-nav-label">◄ PREVIOUS</div>
          <div class="rd-nav-title" id="rd-prev-title"></div>
        </button>
        <button id="rd-next-btn" class="rd-nav-btn" style="text-align:right">
          <div class="rd-nav-label">NEXT ►</div>
          <div class="rd-nav-title" id="rd-next-title"></div>
        </button>
      </nav>

      <div style="height: 80px;"></div>
    </div>

  </div>
</BaseLayout>

<script>
  // ─── Chapter data ───
  const CHAPTERS = [
    { num: 1,  title: 'Summons to the Court' },
    { num: 2,  title: 'Letters as Indictments' },
    { num: 3,  title: 'Witness of the Faithful' },
    { num: 4,  title: 'The Throne Convened' },
    { num: 5,  title: 'The Lamb Takes Exhibit A' },
    { num: 6,  title: 'Six Seals Broken' },
    { num: 7,  title: 'Sealed and Standing' },
    { num: 8,  title: 'Silence, Then Fire' },
    { num: 9,  title: 'Key to the Abyss' },
    { num: 10, title: 'The Mighty Angel' },
    { num: 11, title: 'Measured and Witnessed' },
    { num: 12, title: 'War in Heaven' },
    { num: 13, title: 'Beasts and Allegiance' },
    { num: 14, title: 'Harvest of the Earth' },
    { num: 15, title: 'Bowls of Completion' },
    { num: 16, title: 'Armageddon Gathered' },
    { num: 17, title: 'Mystery Babylon Exposed' },
    { num: 18, title: 'One Hour Collapse' },
    { num: 19, title: 'Rider in White' },
    { num: 20, title: 'The Thousand-Year Reign' },
    { num: 21, title: 'Great White Throne' },
    { num: 22, title: 'All Things New' },
  ];

  function toRoman(n: number): string {
    const map: [string, number][] = [
      ['M',1000],['CM',900],['D',500],['CD',400],
      ['C',100],['XC',90],['L',50],['XL',40],
      ['X',10],['IX',9],['V',5],['IV',4],['I',1]
    ];
    let r = '';
    for (const [l, v] of map) { while (n >= v) { r += l; n -= v; } }
    return r;
  }

  let currentChapter = 1;

  function showChapter(n: number) {
    currentChapter = n;

    // Hide all panels, show current
    document.querySelectorAll('.rd-chapter-panel').forEach(p => {
      (p as HTMLElement).style.display = 'none';
    });
    const panel = document.getElementById(`chapter-${n}`);
    if (panel) panel.style.display = 'block';

    // Update toolbar indicator
    const indicator = document.getElementById('chapter-indicator');
    if (indicator) indicator.textContent = toRoman(n);

    // Update selector active state
    document.querySelectorAll('.rd-selector-item').forEach(btn => {
      const b = btn as HTMLElement;
      const ch = parseInt(b.dataset.chapter || '0');
      b.style.background = ch === n ? 'rgba(139,40,40,0.2)' : 'transparent';
      b.style.borderLeft = ch === n ? '2px solid #8B2828' : '2px solid transparent';
    });

    // Prev / Next
    const prev = CHAPTERS.find(c => c.num === n - 1);
    const next = CHAPTERS.find(c => c.num === n + 1);
    const prevBtn = document.getElementById('rd-prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('rd-next-btn') as HTMLButtonElement;
    const prevTitle = document.getElementById('rd-prev-title');
    const nextTitle = document.getElementById('rd-next-title');

    if (prev) {
      prevBtn.style.display = 'block';
      if (prevTitle) prevTitle.textContent = `${toRoman(prev.num)}. ${prev.title}`;
      prevBtn.onclick = () => { showChapter(prev.num); scrollToTop(); };
    } else {
      prevBtn.style.display = 'none';
    }
    if (next) {
      nextBtn.style.display = 'block';
      if (nextTitle) nextTitle.textContent = `${toRoman(next.num)}. ${next.title}`;
      nextBtn.onclick = () => { showChapter(next.num); scrollToTop(); };
    } else {
      nextBtn.style.display = 'none';
    }

    // Close selector
    const sel = document.getElementById('chapter-selector');
    const arrow = document.getElementById('chapter-toggle-arrow');
    if (sel) sel.style.display = 'none';
    if (arrow) arrow.textContent = '▼';
  }

  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function openReader(startChapter = 1) {
    document.getElementById('book-details')!.style.display = 'none';
    document.getElementById('reader-section')!.style.display = 'block';
    showChapter(startChapter);
    scrollToTop();
  }

  function showBook() {
    document.getElementById('reader-section')!.style.display = 'none';
    document.getElementById('book-details')!.style.display = 'block';
    scrollToTop();
  }

  // Wire up buttons
  document.getElementById('open-reader-btn')?.addEventListener('click', () => openReader(1));
  document.getElementById('reader-back-btn')?.addEventListener('click', showBook);

  // Chapter list buttons on book-details page
  document.querySelectorAll('.open-reader-ch').forEach(btn => {
    btn.addEventListener('click', () => {
      const ch = parseInt((btn as HTMLElement).dataset.chapter || '1');
      openReader(ch);
    });
  });

  // Chapter selector toggle
  document.getElementById('chapter-toggle-btn')?.addEventListener('click', () => {
    const sel = document.getElementById('chapter-selector')!;
    const arrow = document.getElementById('chapter-toggle-arrow')!;
    const open = sel.style.display !== 'none';
    sel.style.display = open ? 'none' : 'block';
    arrow.textContent = open ? '▼' : '▲';
  });

  // Selector items
  document.querySelectorAll('.rd-selector-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const ch = parseInt((btn as HTMLElement).dataset.chapter || '1');
      showChapter(ch);
      scrollToTop();
    });
  });

  // ─── PDF print ───
  // window.print() can't override JS inline styles, so we temporarily
  // force the right DOM state, print, then restore everything.
  document.getElementById('rd-pdf-btn')?.addEventListener('click', () => {
    const readerSection  = document.getElementById('reader-section') as HTMLElement;
    const bookDetails    = document.getElementById('book-details') as HTMLElement;
    const rdBar          = document.querySelector('.rd-bar') as HTMLElement | null;
    const rdNav          = document.getElementById('rd-nav') as HTMLElement | null;
    const rdSelector     = document.getElementById('chapter-selector') as HTMLElement | null;
    const allPanels      = Array.from(document.querySelectorAll('.rd-chapter-panel')) as HTMLElement[];
    const activePanel    = document.getElementById(`chapter-${currentChapter}`) as HTMLElement | null;

    // Snapshot current inline display values
    const snap = {
      reader:   readerSection?.style.display,
      details:  bookDetails?.style.display,
      bar:      rdBar?.style.display ?? '',
      nav:      rdNav?.style.display ?? '',
      sel:      rdSelector?.style.display ?? '',
      panels:   allPanels.map(p => p.style.display),
    };

    // Force print-ready state via inline styles (overrides everything)
    if (readerSection) readerSection.style.display = 'block';
    if (bookDetails)   bookDetails.style.display   = 'none';
    if (rdBar)         rdBar.style.display          = 'none';
    if (rdNav)         rdNav.style.display          = 'none';
    if (rdSelector)    rdSelector.style.display     = 'none';
    allPanels.forEach(p => { p.style.display = 'none'; });
    if (activePanel)   activePanel.style.display    = 'block';

    // Restore after the print dialog closes (afterprint fires in all modern browsers)
    const restore = () => {
      if (readerSection) readerSection.style.display = snap.reader;
      if (bookDetails)   bookDetails.style.display   = snap.details;
      if (rdBar)         rdBar.style.display          = snap.bar;
      if (rdNav)         rdNav.style.display          = snap.nav;
      if (rdSelector)    rdSelector.style.display     = snap.sel;
      allPanels.forEach((p, i) => { p.style.display = snap.panels[i]; });
      window.removeEventListener('afterprint', restore);
    };
    window.addEventListener('afterprint', restore);

    window.print();
  });

  // ─── Book spread view ───
  let spreadOpen = false;

  function openSpread() {
    const panel = document.getElementById(`chapter-${currentChapter}`);
    if (!panel) return;

    // Build overlay
    const overlay = document.createElement('div');
    overlay.id = 'book-spread-overlay';

    const title = CHAPTERS.find(c => c.num === currentChapter)?.title || '';
    const numeral = toRoman(currentChapter);

    // Clone content
    const contentClone = panel.querySelector('.rd-page-body')?.cloneNode(true) as HTMLElement;
    if (!contentClone) return;

    overlay.innerHTML = `
      <div class="bs-shell">
        <button class="bs-close" id="bs-close-btn">✕ Close book view</button>
        <div class="bs-book">
          <button class="bs-arrow bs-arrow-left" id="bs-prev-page" aria-label="Previous pages">&#8249;</button>
          <div class="bs-spread-wrap">
            <div class="bs-page bs-page-left">
              <div class="bs-running-head">The Courtroom of Heaven</div>
              <div class="bs-content" id="bs-content"></div>
              <div class="bs-footer"><span class="bs-pg" id="bs-pg-left"></span></div>
            </div>
            <div class="bs-gutter"></div>
            <div class="bs-page bs-page-right">
              <div class="bs-running-head">${title}</div>
              <div class="bs-content bs-content-right" id="bs-content-right"></div>
              <div class="bs-footer"><span class="bs-pg" id="bs-pg-right"></span></div>
            </div>
          </div>
          <button class="bs-arrow bs-arrow-right" id="bs-next-page" aria-label="Next pages">&#8250;</button>
        </div>
        <div class="bs-chapter-nav">
          <button class="bs-ch-nav" id="bs-prev-ch">&#8592; Previous chapter</button>
          <span class="bs-ch-indicator">${numeral} · ${title}</span>
          <button class="bs-ch-nav" id="bs-next-ch">Next chapter &#8594;</button>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';
    spreadOpen = true;

    // Paginate the content
    paginateSpread(contentClone, numeral, title);

    document.getElementById('bs-close-btn')?.addEventListener('click', closeSpread);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeSpread(); });

    // Chapter nav
    document.getElementById('bs-prev-ch')?.addEventListener('click', () => {
      const prev = CHAPTERS.find(c => c.num === currentChapter - 1);
      if (prev) { closeSpread(); showChapter(prev.num); setTimeout(openSpread, 50); }
    });
    document.getElementById('bs-next-ch')?.addEventListener('click', () => {
      const next = CHAPTERS.find(c => c.num === currentChapter + 1);
      if (next) { closeSpread(); showChapter(next.num); setTimeout(openSpread, 50); }
    });
  }

  let spreadPages: string[] = [];
  let spreadCurrentPage = 0; // 0-indexed, shows pages[spreadCurrentPage] and pages[spreadCurrentPage+1]

  function paginateSpread(contentEl: HTMLElement, numeral: string, title: string) {
    // Use a hidden measuring container to paginate
    const measurer = document.createElement('div');
    measurer.style.cssText = 'position:absolute;top:-9999px;left:-9999px;width:340px;font-family:"EB Garamond",Georgia,serif;font-size:16px;line-height:1.75;color:#2B2420;';
    document.body.appendChild(measurer);

    // Split content into paragraphs and block elements
    const blocks = Array.from(contentEl.children);
    const PAGE_HEIGHT = 560; // approximate page content height in px

    const pages: string[] = [];
    let currentPageHTML = '';
    let currentHeight = 0;

    for (const block of blocks) {
      const clone = block.cloneNode(true) as HTMLElement;
      measurer.innerHTML = '';
      measurer.appendChild(clone);
      const h = measurer.getBoundingClientRect().height || measurer.offsetHeight || 40;

      if (currentHeight + h > PAGE_HEIGHT && currentPageHTML) {
        pages.push(currentPageHTML);
        currentPageHTML = block.outerHTML;
        currentHeight = h;
      } else {
        currentPageHTML += block.outerHTML;
        currentHeight += h;
      }
    }
    if (currentPageHTML) pages.push(currentPageHTML);
    document.body.removeChild(measurer);

    // Prepend chapter header as first page content
    const headerHTML = `<div class="bs-ch-header"><div class="bs-ch-label">C H A P T E R &nbsp; ${numeral}</div><h1 class="bs-ch-title">${title}</h1></div>`;
    if (pages.length > 0) {
      pages[0] = headerHTML + pages[0];
    } else {
      pages.push(headerHTML);
    }

    spreadPages = pages;
    spreadCurrentPage = 0;
    renderSpreadPages();

    document.getElementById('bs-prev-page')?.addEventListener('click', () => {
      if (spreadCurrentPage > 0) { spreadCurrentPage -= 2; renderSpreadPages(); }
    });
    document.getElementById('bs-next-page')?.addEventListener('click', () => {
      if (spreadCurrentPage + 2 < spreadPages.length) { spreadCurrentPage += 2; renderSpreadPages(); }
    });
  }

  function renderSpreadPages() {
    const leftEl = document.getElementById('bs-content');
    const rightEl = document.getElementById('bs-content-right');
    const pgLeft = document.getElementById('bs-pg-left');
    const pgRight = document.getElementById('bs-pg-right');
    const prevBtn = document.getElementById('bs-prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('bs-next-page') as HTMLButtonElement;

    if (leftEl) leftEl.innerHTML = spreadPages[spreadCurrentPage] || '';
    if (rightEl) rightEl.innerHTML = spreadPages[spreadCurrentPage + 1] || '';
    if (pgLeft) pgLeft.textContent = String(spreadCurrentPage + 1);
    if (pgRight) pgRight.textContent = spreadCurrentPage + 1 < spreadPages.length ? String(spreadCurrentPage + 2) : '';
    if (prevBtn) prevBtn.style.opacity = spreadCurrentPage === 0 ? '0.2' : '1';
    if (nextBtn) nextBtn.style.opacity = spreadCurrentPage + 2 >= spreadPages.length ? '0.2' : '1';
  }

  function closeSpread() {
    document.getElementById('book-spread-overlay')?.remove();
    document.body.style.overflow = '';
    spreadOpen = false;
  }

  document.getElementById('rd-spread-btn')?.addEventListener('click', () => {
    if (spreadOpen) closeSpread(); else openSpread();
  });
</script>

