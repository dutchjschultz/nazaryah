  }

  /* Chapter list */
  .bk-chapters { margin-top: 40px; }
  .bk-section-label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 auto 36px;
    max-width: 400px;
  }
  .bk-sl-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201,169,97,0.3), transparent);
  }
