<script>
  // Swap + to − when open
  document.querySelectorAll('.sa-detail').forEach((detail) => {
    detail.addEventListener('toggle', () => {
      const chevron = detail.querySelector('.sa-chevron') as HTMLElement;
      if (chevron) {
        chevron.textContent = (detail as HTMLDetailsElement).open ? '−' : '+';
      }
    });
  });
