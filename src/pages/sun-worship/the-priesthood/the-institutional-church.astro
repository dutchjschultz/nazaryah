</BaseLayout>

<script>
  document.querySelectorAll('.sw-button[data-writeup]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = (btn as HTMLElement).dataset.writeup;
      const panel = document.getElementById(`writeup-${key}`);
      if (!panel) return;
      const wasOpen = !panel.hidden;
      // Close all panels first
      document.querySelectorAll<HTMLElement>('.sw-writeup').forEach((p) => { p.hidden = true; });
      document.querySelectorAll<HTMLElement>('.sw-button').forEach((b) => b.classList.remove('is-active'));
      if (!wasOpen) {
        panel.hidden = false;
        btn.classList.add('is-active');
        // Scroll into view with a small offset
        setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'start' }), 60);
      }
    });
  });

  document.querySelectorAll('.sw-writeup-close').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.closest<HTMLElement>('.sw-writeup');
      if (panel) panel.hidden = true;
      document.querySelectorAll<HTMLElement>('.sw-button').forEach((b) => b.classList.remove('is-active'));
      // Scroll back up to the button grid
      document.querySelector('.sw-button-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

