    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #6a4820;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .sw-accordion-title {
    font-family: 'Cinzel', serif;
