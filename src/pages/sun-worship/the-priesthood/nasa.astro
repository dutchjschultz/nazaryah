  .sw-part-label {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #BA7517;
    font-weight: 700;
    white-space: nowrap;
    min-width: 80px;
  }

  .sw-part-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(0.85rem, 1.5vw, 1rem);
