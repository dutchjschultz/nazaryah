    margin: 0 auto 2.5rem;
    max-width: 560px;
  }

  .sw-accordion {
    max-width: 820px;
    margin: 0 auto;
    text-align: left;
  }

  .sw-detail { border-bottom: 1px solid #2a1a08; }
  .sw-detail:first-child { border-top: 1px solid #2a1a08; }

  .sw-summary {
