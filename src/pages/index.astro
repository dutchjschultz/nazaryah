---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Featured studies — the latest post from each of these 5 categories
const featuredCategories = [
  'Scripture Unfiltered',
  'Word Studies',
  'The Law Still Stands',
  'The Feasts',
  'The Scrolls',
] as const;

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedByDate = [...allPosts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// For each category, pick the most recent post (or null if none exists)
const displayPosts = featuredCategories.map((category) => ({
  category,
  post: sortedByDate.find((p) => p.data.category === category) ?? null,
}));
---

<BaseLayout
  title="Nazaryah - Biblical Studies with Scholarly Integrity"
  description="Explore Scripture through original languages, fresh perspectives, and rich historical context. A modern biblical studies platform for serious learners."
>
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <!-- Subtle grid texture overlay -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px);
      z-index: 0;
    "></div>

    <div class="hero-grid relative z-10">
      <!-- LEFT: Logo panel (dark background matches logo image) -->
      <div class="logo-panel">
        <img
          src="/images/nazaryah-logo.png"
          alt="Nazaryah — Separated Unto Yah"
          class="logo-panel-img"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Content -->
      <div class="content-panel">
        <p class="hero-eyebrow">Biblical Studies</p>
        <h1 class="hero-headline">
          The Doctrine Was Built<br>
          To Keep You <em>Comfortable.</em>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-body">
          Comfortable people don't ask questions. Nazaryah is for the ones who already started asking.
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="btn btn-primary">Explore Studies</a>
          <a href="/about" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      width: 100%;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 360px 1fr;
      min-height: 420px;
    }

    /* ── LEFT PANEL: dark, logo centered ── */
    .logo-panel {
      position: relative;
      background: #0f0a04;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.5rem;
      overflow: hidden;
    }

    /* Subtle warm radial glow behind the logo */
    .logo-panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 45%, rgba(180, 120, 30, 0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Corner ornaments */
    .logo-panel::after {
      content: '';
      position: absolute;
      top: 10px; left: 10px;
      width: 20px; height: 20px;
      border-top: 1.5px solid rgba(196, 154, 78, 0.45);
      border-left: 1.5px solid rgba(196, 154, 78, 0.45);
    }

    .logo-panel-img {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 320px;
      height: auto;
      object-fit: contain;
    }

    /* ── RIGHT PANEL ── */
    .content-panel {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1.4rem;
      padding: 3.5rem 3rem 3.5rem 3.5rem;
    }

    .hero-eyebrow {
      font-family: var(--font-display);
      font-size: 11px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-faded);
      opacity: 0.75;
      margin: 0;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--color-primary-text);
      margin: 0;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--gold-light, #c49a4e);
    }

    .hero-rule {
      width: 48px;
      height: 1.5px;
      background: var(--color-border-strong);
      opacity: 0.65;
    }

    .hero-body {
      font-family: var(--font-body);
      font-size: 1.15rem;
      line-height: 1.8;
      color: var(--color-secondary-text);
      max-width: 480px;
      margin: 0;
    }

    .hero-cta-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 0.25rem;
    }

    /* ── Responsive ── */
    @media (max-width: 820px) {
      .hero-grid {
        grid-template-columns: 1fr;
        min-height: unset;
      }

      .logo-panel {
        padding: 2rem 1.5rem;
        min-height: 220px;
      }

      .logo-panel-img {
        max-width: 260px;
      }

      .content-panel {
        padding: 2.5rem 1.5rem 2.5rem 1.5rem;
      }

      .hero-headline {
        font-size: 1.9rem;
      }
    }
  </style>

  <!-- Featured Studies — 5 across, one latest post per category -->
  <section class="py-20 md:py-24 border-t border-[var(--sand-dark)]">
    <div class="container mx-auto px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-3" style="font-family: var(--font-display); color: var(--deep-earth);">
          Featured Studies
        </h2>
        <p class="text-center mb-12 max-w-2xl mx-auto" style="color: var(--ink-faded);">
          The latest study from each of our core categories.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
          {displayPosts.map(({ category, post }) => (
            post ? (
              <article class="card group flex flex-col">
                <div class="p-6 flex flex-col flex-1">
                  <div class="tag mb-3" style="color: var(--bronze);">
                    {category}
                  </div>
                  <h3 class="text-lg font-semibold mb-3 leading-snug" style="font-family: var(--font-display); color: var(--deep-earth);">
                    <a href={`/blog/${post.slug}`} class="hover:text-[var(--bronze)] transition-colors" style="color: var(--deep-earth);">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-sm leading-relaxed mb-5 line-clamp-4 flex-1" style="color: var(--ink-faded);">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-xs pt-4 border-t border-[var(--sand-dark)]" style="color: var(--ink-faded); font-family: var(--font-body);">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <a
                      href={`/blog/${post.slug}`}
                      class="font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1"
                      style="color: var(--bronze);"
                    >
                      Read <span aria-hidden="true">&rarr;</span>
                    </a>
                  </div>
                </div>
              </article>
            ) : (
              <article class="card flex flex-col opacity-70">
                <div class="p-6 flex flex-col flex-1">
                  <div class="tag mb-3" style="color: var(--bronze);">
                    {category}
                  </div>
                  <h3 class="text-lg font-semibold mb-3 leading-snug" style="font-family: var(--font-display); color: var(--deep-earth);">
                    Coming soon
                  </h3>
                  <p class="text-sm leading-relaxed flex-1 italic" style="color: var(--ink-faded);">
                    The first study in this category has not been published yet.
                  </p>
                </div>
              </article>
            )
          ))}
        </div>
        <div class="text-center mt-12">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 font-medium transition-colors"
            style="font-family: var(--font-display); color: var(--bronze); letter-spacing: 1px;"
          >
            View All Studies <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="relative py-20 md:py-24 border-t border-[var(--sand-dark)]">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-3" style="font-family: var(--font-display); color: var(--deep-earth);">
          Our Approach
        </h2>
        <p class="text-center mb-14 max-w-2xl mx-auto" style="color: var(--ink-faded);">
          Four pillars that guide our biblical scholarship and research methodology.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="tile-card p-8 group">
            <h3 class="text-xl font-semibold mb-4" style="font-family: var(--font-display); color: var(--bronze);">
              Original Languages
            </h3>
            <p style="color: var(--ink-faded);" class="leading-relaxed">
              We engage directly with Hebrew and Greek texts, providing transliterations and contextual insights
              to deepen your understanding of Scripture's original meaning.
            </p>
          </div>
          <div class="tile-card p-8 group">
            <h3 class="text-xl font-semibold mb-4" style="font-family: var(--font-display); color: var(--bronze);">
              Historical Context
            </h3>
            <p style="color: var(--ink-faded);" class="leading-relaxed">
              Explore the Ancient Near East, Second Temple Judaism, and Greco-Roman world to understand
              the cultural and historical backdrop of biblical texts.
            </p>
          </div>
          <div class="tile-card p-8 group">
            <h3 class="text-xl font-semibold mb-4" style="font-family: var(--font-display); color: var(--bronze);">
              Fresh Perspectives
            </h3>
            <p style="color: var(--ink-faded);" class="leading-relaxed">
              We challenge traditional interpretations when evidence warrants, bringing new insights
              from contemporary scholarship and linguistic discoveries.
            </p>
          </div>
          <div class="tile-card p-8 group">
            <h3 class="text-xl font-semibold mb-4" style="font-family: var(--font-display); color: var(--bronze);">
              Scholarly Integrity
            </h3>
            <p style="color: var(--ink-faded);" class="leading-relaxed">
              All studies are thoroughly researched, properly cited, and maintain academic rigor
              while remaining accessible to serious learners at all levels.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-20 md:py-24 border-t border-[var(--sand-dark)]">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto">
        <div class="card p-10 text-center">
            <h2 class="text-3xl font-bold mb-4" style="font-family: var(--font-display); color: var(--deep-earth);">
              Stay Updated
            </h2>
            <p class="mb-8 leading-relaxed" style="color: var(--ink-faded);">
              Receive new studies and insights directly in your inbox. No spam, just quality biblical scholarship.
            </p>
            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input
              type="email"
              placeholder="Your email address"
              class="input-field flex-1"
              required
            />
            <button
              type="submit"
              class="btn btn-stone px-6 py-3 whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
