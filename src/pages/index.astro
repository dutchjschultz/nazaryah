---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nazaryah - Biblical Studies with Scholarly Integrity"
  description="Explore Scripture through original languages, fresh perspectives, and rich historical context. A modern biblical studies platform for serious learners."
>
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <!-- Subtle grid texture overlay -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px);
      z-index: 0;
    "></div>

    <div class="hero-grid relative z-10">
      <!-- LEFT: Logo panel (dark background matches logo image) -->
      <div class="logo-panel">
        <img
          src="/images/nazaryah-logo.png"
          alt="Nazaryah — Separated Unto Yah"
          class="logo-panel-img"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Content -->
      <div class="content-panel">
        <h1 class="hero-headline">
          The Doctrine Was Built<br>
          To Keep You <em>Comfortable.</em>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-body">
          Nazaryah goes back to the source — original languages, restored names, and the Torah your church quietly skipped. No denominations. No comfortable answers. Just the text.
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="btn btn-primary">Explore Studies</a>
          <a href="/about" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      width: 100%;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 5fr 8fr;
      width: 100%;
      max-width: 80rem;
      aspect-ratio: 5 / 1;
      overflow: hidden;
      border-radius: 4px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.22), 0 2px 8px rgba(0,0,0,0.15);
    }

    /* ── LEFT PANEL: dark, logo centered ── */
    .logo-panel {
      position: relative;
      background: #0f0a04;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.25rem;
      overflow: hidden;
    }

    /* Subtle warm radial glow behind the logo */
    .logo-panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 45%, rgba(180, 120, 30, 0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Corner ornaments */
    .logo-panel::after {
      content: '';
      position: absolute;
      top: 10px; left: 10px;
      width: 20px; height: 20px;
      border-top: 1.5px solid rgba(196, 154, 78, 0.45);
      border-left: 1.5px solid rgba(196, 154, 78, 0.45);
    }

    .logo-panel-img {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 85%;
      object-fit: contain;
    }

    /* ── RIGHT PANEL ── */
    .content-panel {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.55rem;
      padding: 1rem 2rem 1rem 2rem;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.75rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--color-primary-text);
      margin: 0;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--gold-light, #c49a4e);
    }

    .hero-rule {
      width: 48px;
      height: 1.5px;
      background: var(--color-border-strong);
      opacity: 0.65;
    }

    .hero-body {
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--color-secondary-text);
      margin: 0;
    }

    .hero-cta-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .pillar-grid {
        grid-template-columns: 1fr !important;
      }
    }

    @media (max-width: 720px) {
      .hero-section {
        padding: 1.5rem 1rem;
      }

      .hero-grid {
        grid-template-columns: 1fr;
        aspect-ratio: unset;
        max-width: 100%;
      }

      .logo-panel {
        padding: 1.75rem 1.5rem;
        min-height: 180px;
      }

      .logo-panel-img {
        max-width: 220px;
      }

      .content-panel {
        padding: 1.75rem 1.5rem;
        gap: 0.75rem;
      }

      .hero-headline {
        font-size: 1.6rem;
      }
    }
  </style>

  <!-- ========== Nine Doors — Home Page Grid ========== -->
  <section class="row-intro">
    <div class="row-intro-inner">
      <p class="row-intro-label">&#8213; Choose Your Path &#8213;</p>
      <div class="row-intro-door" aria-hidden="true">
        <svg viewBox="0 0 80 120" width="68" height="102" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
          <!-- Outer arched doorframe -->
          <path d="M 8 118 L 8 40 Q 8 8 40 8 Q 72 8 72 40 L 72 118 Z" />
          <!-- Inner door panel -->
          <path d="M 14 114 L 14 42 Q 14 14 40 14 Q 66 14 66 42 L 66 114 Z" opacity="0.55" />
          <!-- Horizontal cross rail at about 60% -->
          <line x1="14" y1="72" x2="66" y2="72" opacity="0.55" />
          <!-- Vertical centerline within top section -->
          <line x1="40" y1="14" x2="40" y2="72" opacity="0.45" />
          <!-- Handle / knob -->
          <circle cx="58" cy="92" r="2" fill="currentColor" opacity="0.9" />
          <!-- Keyhole detail -->
          <circle cx="40" cy="92" r="1.6" fill="currentColor" opacity="0.7" />
          <line x1="40" y1="93" x2="40" y2="99" opacity="0.7" />
          <!-- Glow rays above the arch -->
          <g opacity="0.45">
            <line x1="40" y1="4" x2="40" y2="0" />
            <line x1="20" y1="8" x2="16" y2="4" />
            <line x1="60" y1="8" x2="64" y2="4" />
          </g>
        </svg>
      </div>
      <h2>Nine Doors. Choose Yours.</h2>
      <p>Every door opens onto a different part of the work. Each one is a piece of the same picture: what modern Christianity hides, and what Scripture restores.</p>
      <div class="row-intro-rule" aria-hidden="true">
        <span></span><span class="gem">✦</span><span></span>
      </div>
    </div>
  </section>

  <div class="door-grid-bg">
  <section class="door-grid">

    <!-- ===== ROW 1 ===== -->

    <!-- Card: CHRISTIAN OR DEMONIC -->
    <a href="/christian-or-demonic" class="door demon">
      <div class="door-tag">A FIVE-PART EXAMINATION</div>
      <h3 class="door-title">Christian <em>or</em> Demonic?</h3>
      <p class="door-sub">Five pillars of modern Christianity. Five uncomfortable questions. <strong>Five answers the pulpit never gave you.</strong></p>
      <p class="pillars">
        <span>Prayer</span><span>Music</span><span>Canon</span><span>Translations</span><span>Symbols</span>
      </p>
      <span class="door-foot">Take the Examination</span>
    </a>

    <!-- Card: NEWS / FIELD NOTES -->
    <a href="/watchmans-desk" class="door news">
      <div class="door-tag">★ THE WATCHMAN'S DESK ★</div>
      <p class="dateline">22 April 2026 · Three Briefs</p>
      <h3 class="door-title">The Triumphal Arch Comes to Washington</h3>
      <p class="door-sub">On April 16 the federal Commission of Fine Arts approved a 250-foot Roman arch — copy of Napoleon's Sol Invictus monument. Unveiling targeted for July 4. The form is older than Rome. The date is older than the calendar.</p>
      <span class="door-foot">All Field Notes</span>
    </a>

    <!-- Card: STUDIES (MANUSCRIPT) -->
    <a href="/blog" class="door scripture">
      <div class="hebrew-letter">א</div>
      <div class="door-tag">SCRIPTURE UNFILTERED</div>
      <h3 class="door-title">The Studies</h3>
      <p class="door-sub">Verse by verse in the original Hebrew and Greek — recovering what was buried under tradition, denomination, and translation drift.</p>
      <div class="latest-study">
        <strong>★ Latest Study ★</strong>
        Grace, New Creation, and Covenant Loyalty
      </div>
      <span class="door-foot">All Bible Studies</span>
    </a>

    <!-- ===== ROW 2 ===== -->

    <!-- Card: SUN WORSHIP -->
    <a href="/sun-worship" class="door sun">
      <div class="sun-mark">☀</div>
      <div class="door-tag">THE OLDEST COUNTERFEIT</div>
      <h3 class="door-title">Sun Worship</h3>
      <p class="door-sub">From Babel to Easter morning to the obelisks of every Western capital — the religion that never died, only changed costumes. Trace the same rite from Heliopolis to your Sunday service.</p>
      <span class="door-foot">Open the Section</span>
    </a>

    <!-- Card: AMERICAN IDOLATRY -->
    <a href="/american-idolatry" class="door america">
      <div class="stripes-top"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
      <div class="blue-field">
        <div class="stars-row">★ ★ ★ ★ ★ ★ ★</div>
        <div class="door-tag">AMERICAN IDOLATRY</div>
      </div>
      <div class="body-area">
        <h3 class="door-title">The Babylon We Were Born Into<em>nine studies · one cornerstone</em></h3>
        <p class="door-sub">The patriotic holidays, monuments, oaths, and symbols Christians have been told are sacred — examined against what Scripture actually permits.</p>
        <span class="door-foot">Open the Section</span>
      </div>
      <div class="stripes-bottom"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
    </a>

    <!-- Card: BOOKS / LIBRARY -->
    <a href="/books" class="door books">
      <div class="spine-band-top"></div>
      <div class="spine-content">
        <div class="gold-mark">✦  ✦  ✦</div>
        <div class="door-tag">FROM THE LIBRARY</div>
        <h3 class="door-title">The Courtroom of Heaven</h3>
        <p class="door-title-secondary">Revelation Putting Modern Teaching on Trial</p>
        <p class="door-sub">Long-form teaching — the chapter studies, the Court Appeals, and the exhibits — that won't fit inside a blog post.</p>
        <span class="door-foot">Browse the Library</span>
      </div>
      <div class="spine-band-bottom"></div>
    </a>

    <!-- ===== ROW 3 ===== -->

    <!-- Card: TRINITY (TRIQUETRA SIGIL) -->
    <a href="/trinity" class="door trinity">
      <div class="sigil">
        <svg viewBox="0 0 120 120" width="110" height="110" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#7ee5a0" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round">
          <g transform="translate(60 62)">
            <path d="M 0 -32 C -18 -18 -18 18 0 32 C 18 18 18 -18 0 -32 Z" transform="rotate(0)" />
            <path d="M 0 -32 C -18 -18 -18 18 0 32 C 18 18 18 -18 0 -32 Z" transform="rotate(120)" />
            <path d="M 0 -32 C -18 -18 -18 18 0 32 C 18 18 18 -18 0 -32 Z" transform="rotate(240)" />
            <circle cx="0" cy="0" r="38" stroke-width="1.2" opacity="0.55" />
          </g>
        </svg>
      </div>
      <div class="door-tag">EXAMINING A SACRED COW</div>
      <h3 class="door-title">The Trinity</h3>
      <p class="door-sub">The symbol above is older than the church that claims it. So is the doctrine. <strong>Neither was given by Scripture.</strong> Trace where both actually came from — and what the text says instead.</p>
      <span class="door-foot">Open the Section</span>
    </a>

    <!-- Card: FOREIGN FIRE (BLUE FLAMES) -->
    <a href="/foreign-fire" class="door foreign-fire">
      <div class="door-tag">STRANGE FIRE</div>
      <h3 class="door-title">Foreign <em>Fire</em></h3>
      <p class="door-sub">Nadab and Abihu offered fire Yahuah did not command. The fire that came out from Yahuah consumed them. The modern church has built an altar of unauthorized worship and called it holy.
      <span class="verse-ref">Leviticus 10:1–2</span></p>
      <span class="door-foot">Read the Warning</span>
    </a>

    <!-- Card: HEBREW (SANDSTONE TABLET WITH PALEO YHWH) -->
    <a href="/hebrew" class="door hebrew">
      <div class="yhwh-display">
        <svg viewBox="0 0 320 100" width="260" height="82" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#3a2a14" stroke-width="5" stroke-linejoin="round" stroke-linecap="round">
          <g transform="translate(260, 15)">
            <line x1="10" y1="0" x2="10" y2="70" />
            <line x1="10" y1="5" x2="38" y2="-5" />
            <line x1="10" y1="30" x2="35" y2="22" />
            <line x1="10" y1="55" x2="38" y2="50" />
          </g>
          <g transform="translate(180, 15)">
            <path d="M 10 10 Q 10 0 20 0 Q 30 0 30 10 L 30 18" />
            <line x1="30" y1="18" x2="30" y2="72" />
          </g>
          <g transform="translate(100, 15)">
            <line x1="10" y1="0" x2="10" y2="70" />
            <line x1="10" y1="5" x2="38" y2="-5" />
            <line x1="10" y1="30" x2="35" y2="22" />
            <line x1="10" y1="55" x2="38" y2="50" />
          </g>
          <g transform="translate(20, 20)">
            <path d="M 5 0 L 25 5 L 20 25 L 40 25 L 38 55 L 55 60" />
          </g>
        </svg>
      </div>
      <div class="door-tag">THE FATHER'S NAME RESTORED</div>
      <h3 class="door-title">Hebrew</h3>
      <p class="door-sub">The four pictographs above are <em>YHWH</em> in paleo-Hebrew — the name the translators erased nearly seven thousand times. Word studies in the original language, restoring what was buried under Greek, Latin, and English.</p>
      <span class="door-foot">Open the Section</span>
    </a>

  </section>
  </div>

  <style>
    /* ===== ROW INTRO (matches the Catholicism / dark-burgundy theme) ===== */
    .row-intro {
      text-align: center;
      padding: 72px 24px 48px;
      font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(160, 20, 40, 0.22), transparent 70%),
        linear-gradient(180deg, #0a0608 0%, #170a0e 35%, #120608 100%);
      border-top: 1px solid #4a1820;
      border-bottom: 1px solid #2a1010;
      color: #f0e0bf;
      position: relative;
    }
    .row-intro-inner {
      max-width: 720px;
      margin: 0 auto;
      position: relative;
    }
    .row-intro-label {
      font-family: 'Cinzel', serif;
      font-size: 10px;
      letter-spacing: 0.4em;
      color: #7a3028;
      text-transform: uppercase;
      margin: 0 0 1.5rem 0;
    }
    .row-intro-door {
      display: flex;
      justify-content: center;
      margin-bottom: 1.5rem;
      color: #c49a4e;
      filter: drop-shadow(0 0 14px rgba(196, 154, 78, 0.25));
    }
    .row-intro-door svg {
      transition: transform 0.3s ease, filter 0.3s ease;
    }
    .row-intro:hover .row-intro-door svg {
      transform: translateY(-2px);
      filter: drop-shadow(0 0 18px rgba(196, 154, 78, 0.45));
    }
    .row-intro h2 {
      font-family: 'Cinzel', 'Playfair Display', Georgia, serif;
      font-size: clamp(1.9rem, 3.4vw, 2.6rem);
      color: #f0e0bf;
      margin: 0 0 14px 0;
      font-weight: 700;
      letter-spacing: -0.005em;
    }
    .row-intro p {
      color: #c4a46b;
      max-width: 620px;
      margin: 0 auto;
      font-style: italic;
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .row-intro-rule {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      margin-top: 28px;
      color: #8B1A2A;
    }
    .row-intro-rule span {
      display: block;
      height: 1px;
      width: 80px;
      background: currentColor;
      opacity: 0.55;
    }
    .row-intro-rule .gem {
      height: auto;
      width: auto;
      color: #c49a4e;
      font-size: 0.9rem;
      opacity: 0.9;
      background: transparent;
    }

    /* ===== THE GRID ===== */
    .door-grid-bg {
      background: linear-gradient(180deg, #120608 0%, #0a0608 100%);
      border-bottom: 1px solid #2a1010;
    }
    .door-grid {
      max-width: 1280px;
      margin: 0 auto;
      padding: 48px 24px 72px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      background: transparent;
      font-family: Georgia, 'EB Garamond', serif;
    }
    .door {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      min-height: 420px;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      box-shadow: 0 4px 14px rgba(0,0,0,0.12);
    }
    .door:hover {
      transform: translateY(-6px);
      box-shadow: 0 18px 36px rgba(0,0,0,0.22);
    }

    .door-tag {
      font-size: 0.68rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .door-title {
      font-family: 'Playfair Display', 'Cinzel', Georgia, serif;
      font-size: 1.85rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 12px;
    }
    .door-sub {
      font-size: 0.95rem;
      line-height: 1.55;
      margin-bottom: 20px;
      flex-grow: 1;
    }
    .door-foot {
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      font-weight: 700;
      padding-top: 14px;
      border-top: 1px solid currentColor;
      opacity: 0.85;
    }
    .door-foot::after { content: ' →'; }

    /* ============ CARD: NEWSPAPER (FIELD NOTES) ============ */
    .door.news {
      background: #f5f1e6;
      color: #1a1a1a;
      padding: 36px 30px 30px;
      border: 1px solid #c9c1ac;
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 32px, rgba(0,0,0,0.025) 32px, rgba(0,0,0,0.025) 33px);
    }
    .door.news .door-tag {
      color: #b8232a;
      font-family: 'Times New Roman', serif;
      border-top: 3px double #1a1a1a;
      border-bottom: 1px solid #1a1a1a;
      padding: 8px 0;
      text-align: center;
      margin-bottom: 20px;
    }
    .door.news .door-title {
      font-family: 'Times New Roman', Georgia, serif;
      text-align: center;
      line-height: 1;
      border-bottom: 1px solid #1a1a1a;
      padding-bottom: 16px;
      margin-bottom: 16px;
      font-style: italic;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      font-size: 1.7rem;
    }
    .door.news .dateline {
      font-family: 'Times New Roman', serif;
      font-size: 0.72rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6e5a3f;
      text-align: center;
      margin-bottom: 14px;
      font-weight: 700;
    }
    .door.news .door-sub {
      text-align: justify;
      font-size: 0.92rem;
      line-height: 1.5;
      font-family: 'Times New Roman', Georgia, serif;
    }
    .door.news .door-sub::first-letter {
      font-size: 2.4rem;
      float: left;
      line-height: 1;
      padding: 4px 8px 0 0;
      font-weight: 700;
      font-family: 'Playfair Display', serif;
    }
    .door.news .door-foot {
      color: #b8232a;
      border-top: 1px solid #1a1a1a;
    }

    /* ============ CARD: CHRISTIAN OR DEMONIC (FIRE) ============ */
    .door.demon {
      background:
        radial-gradient(ellipse at 50% 100%, #b8232a 0%, #6a0d10 35%, #1a0203 75%, #000 100%);
      color: #f7e4d0;
      padding: 36px 30px 30px;
      border: 1px solid #2a0506;
      position: relative;
    }
    .door.demon::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 30% 110%, rgba(255,160,40,0.4) 0%, transparent 25%),
        radial-gradient(circle at 70% 105%, rgba(255,80,20,0.5) 0%, transparent 30%),
        radial-gradient(circle at 50% 95%, rgba(255,200,80,0.3) 0%, transparent 20%);
      pointer-events: none;
      animation: flicker-red 4s ease-in-out infinite alternate;
    }
    @keyframes flicker-red {
      0%, 100% { opacity: 0.85; }
      40% { opacity: 1; }
      60% { opacity: 0.7; }
      80% { opacity: 0.95; }
    }
    .door.demon > * { position: relative; z-index: 1; }
    .door.demon .door-tag {
      color: #ffb070;
      font-weight: 800;
      letter-spacing: 0.4em;
    }
    .door.demon .door-title {
      color: #fff;
      text-shadow: 0 0 16px rgba(255,80,20,0.6), 0 2px 4px rgba(0,0,0,0.5);
      font-style: italic;
      line-height: 1;
      font-size: 2.1rem;
    }
    .door.demon .door-title em {
      color: #ff5018;
      font-style: italic;
      text-shadow: 0 0 20px #ff5018;
    }
    .door.demon .door-sub {
      color: #f0d8b8;
      font-size: 0.95rem;
    }
    .door.demon .door-sub strong {
      color: #ff8838;
      font-style: italic;
      font-weight: 600;
    }
    .door.demon .door-foot {
      color: #ffb070;
      border-color: rgba(255,176,112,0.4);
    }
    .door.demon .pillars {
      margin: 14px 0 16px;
      font-size: 0.85rem;
      color: #f7c89a;
      letter-spacing: 0.05em;
      line-height: 1.7;
    }
    .door.demon .pillars span {
      display: inline-block;
      margin-right: 12px;
      padding-right: 12px;
      border-right: 1px solid rgba(247,200,154,0.3);
    }
    .door.demon .pillars span:last-child { border-right: none; padding-right: 0; margin-right: 0; }

    /* ============ CARD: AMERICAN IDOLATRY (FLAG) ============ */
    .door.america {
      background: #f5f1e6;
      color: #0a1d3a;
      border: 1px solid #0a1d3a;
      padding: 0;
      overflow: hidden;
    }
    .door.america .stripes-top { display: flex; height: 16px; }
    .door.america .stripes-top span { flex: 1; }
