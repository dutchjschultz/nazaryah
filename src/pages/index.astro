---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get featured posts
const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const featuredPosts = allPosts
  .filter((post) => post.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// If no featured posts, get the 3 most recent
const displayPosts = featuredPosts.length > 0
  ? featuredPosts
  : allPosts
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .slice(0, 3);
---

<BaseLayout
  title="Nazaryah - Biblical Studies with Scholarly Integrity"
  description="Explore Scripture through original languages, fresh perspectives, and rich historical context. A modern biblical studies platform for serious learners."
>
  <!-- Hero Section -->
  <section class="relative py-20 md:py-28 lg:py-36 overflow-hidden bg-gradient-to-b from-[var(--color-surface-elevated)] via-[var(--color-background)] to-[var(--color-background)] dark:from-[var(--color-dark-surface-elevated)] dark:via-[var(--color-dark-background)] dark:to-[var(--color-dark-background)]">
    <!-- Corner ornaments -->
    <div class="corner-ornament corner-ornament--tl" aria-hidden="true"></div>
    <div class="corner-ornament corner-ornament--tr" aria-hidden="true"></div>
    <div class="corner-ornament corner-ornament--bl" aria-hidden="true"></div>
    <div class="corner-ornament corner-ornament--br" aria-hidden="true"></div>

    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

        <!-- Logo image — tastefully contained -->
        <div class="flex-shrink-0 hero-logo-frame">
          <img
            src="/images/nazaryah-logo.png"
            alt="Nazaryah — Separated Unto YAH"
            class="hero-logo-img"
          />
        </div>

        <!-- Text -->
        <div class="text-center lg:text-left flex-1">
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)] mb-6 leading-tight">
            Exploring Scripture with <span class="text-[var(--color-accent)] dark:text-[var(--color-dark-accent)]">Scholarly Integrity</span>
          </h1>
          <p class="text-lg md:text-xl text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed mb-10">
            Nazaryah is a modern biblical studies platform that bridges academic scholarship and general readership,
            emphasizing original languages, fresh perspectives, and rich contextual understanding without denominational bias.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start font-sans">
            <a href="/blog" class="btn btn-primary px-8 py-3">Explore Studies</a>
            <a href="/about" class="btn btn-outline px-8 py-3">Learn More</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Featured Studies -->
  {displayPosts.length > 0 && (
    <section class="py-20 md:py-24 border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)]">
      <div class="container mx-auto px-6">
        <div class="max-w-7xl mx-auto">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-center mb-3 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
            Featured Studies
          </h2>
          <p class="text-center text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] mb-12 max-w-2xl mx-auto">
            Dive into our latest research and insights on biblical texts, languages, and historical context.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
            {displayPosts.map((post) => (
              <article class="card group flex flex-col">
                <div class="p-8 flex flex-col flex-1">
                  <div class="text-xs font-sans font-semibold text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] mb-3 uppercase tracking-wider">
                    {post.data.category}
                  </div>
                  <h3 class="font-serif text-xl font-semibold mb-3 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
                    <a href={`/blog/${post.slug}`} class="hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] text-base leading-relaxed mb-6 line-clamp-4 flex-1">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-sm font-sans text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] pt-5 border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)]">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <a
                      href={`/blog/${post.slug}`}
                      class="text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1"
                    >
                      Read More <span aria-hidden="true">→</span>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
          <div class="text-center mt-12">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 font-sans text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] hover:text-[var(--color-accent-hover)] dark:hover:text-[var(--color-dark-accent-hover)] font-medium transition-colors"
            >
              View All Studies <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Our Approach -->
  <section class="relative py-20 md:py-24 border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)] bg-gradient-to-b from-[var(--color-surface-elevated)]/40 to-transparent dark:from-[var(--color-dark-surface-elevated)]/40 dark:to-transparent">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl font-bold text-center mb-3 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
          Our Approach
        </h2>
        <p class="text-center text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] mb-14 max-w-2xl mx-auto">
          Four pillars that guide our biblical scholarship and research methodology.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card p-8 group hover:border-[var(--color-accent)] dark:hover:border-[var(--color-dark-accent)] transition-all">
            <h3 class="font-serif text-xl font-semibold mb-4 text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] group-hover:text-[var(--color-accent-hover)] dark:group-hover:text-[var(--color-dark-accent-hover)] transition-colors">
              Original Languages
            </h3>
            <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed">
              We engage directly with Hebrew and Greek texts, providing transliterations and contextual insights
              to deepen your understanding of Scripture's original meaning.
            </p>
          </div>
          <div class="card p-8 group hover:border-[var(--color-accent)] dark:hover:border-[var(--color-dark-accent)] transition-all">
            <h3 class="font-serif text-xl font-semibold mb-4 text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] group-hover:text-[var(--color-accent-hover)] dark:group-hover:text-[var(--color-dark-accent-hover)] transition-colors">
              Historical Context
            </h3>
            <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed">
              Explore the Ancient Near East, Second Temple Judaism, and Greco-Roman world to understand
              the cultural and historical backdrop of biblical texts.
            </p>
          </div>
          <div class="card p-8 group hover:border-[var(--color-accent)] dark:hover:border-[var(--color-dark-accent)] transition-all">
            <h3 class="font-serif text-xl font-semibold mb-4 text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] group-hover:text-[var(--color-accent-hover)] dark:group-hover:text-[var(--color-dark-accent-hover)] transition-colors">
              Fresh Perspectives
            </h3>
            <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed">
              We challenge traditional interpretations when evidence warrants, bringing new insights
              from contemporary scholarship and linguistic discoveries.
            </p>
          </div>
          <div class="card p-8 group hover:border-[var(--color-accent)] dark:hover:border-[var(--color-dark-accent)] transition-all">
            <h3 class="font-serif text-xl font-semibold mb-4 text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] group-hover:text-[var(--color-accent-hover)] dark:group-hover:text-[var(--color-dark-accent-hover)] transition-colors">
              Scholarly Integrity
            </h3>
            <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] leading-relaxed">
              All studies are thoroughly researched, properly cited, and maintain academic rigor
              while remaining accessible to serious learners at all levels.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-20 md:py-24 border-t border-[var(--color-border)] dark:border-[var(--color-dark-border)]">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto">
        <div class="card p-10 text-center">
            <h2 class="font-serif text-3xl font-bold mb-4 text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)]">
              Stay Updated
            </h2>
            <p class="text-[var(--color-secondary-text)] dark:text-[var(--color-dark-secondary-text)] mb-8 leading-relaxed">
              Receive new studies and insights directly in your inbox. No spam, just quality biblical scholarship.
            </p>
            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto font-sans">
            <input
              type="email"
              placeholder="Your email address"
              class="flex-1 px-4 py-3 border border-[var(--color-border)] dark:border-[var(--color-dark-border)] rounded-lg bg-[var(--color-surface)] dark:bg-[var(--color-dark-surface)] text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)] placeholder:text-[var(--color-secondary-text)] dark:placeholder:text-[var(--color-dark-secondary-text)]"
              required
            />
            <button
              type="submit"
              class="btn btn-primary px-6 py-3 whitespace-nowrap"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
