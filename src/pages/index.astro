---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Featured studies — the latest post from each of these 5 categories
const featuredCategories = [
  'Scripture Unfiltered',
  'Word Studies',
  'The Law Still Stands',
  'The Feasts',
  'The Scrolls',
] as const;

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const sortedByDate = [...allPosts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// For each category, pick the most recent post (or null if none exists)
const displayPosts = featuredCategories.map((category) => ({
  category,
  post: sortedByDate.find((p) => p.data.category === category) ?? null,
}));
---

<BaseLayout
  title="Nazaryah - Biblical Studies with Scholarly Integrity"
  description="Explore Scripture through original languages, fresh perspectives, and rich historical context. A modern biblical studies platform for serious learners."
>
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <!-- Subtle grid texture overlay -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px);
      z-index: 0;
    "></div>

    <div class="hero-grid relative z-10">
      <!-- LEFT: Logo panel (dark background matches logo image) -->
      <div class="logo-panel">
        <img
          src="/images/nazaryah-logo.png"
          alt="Nazaryah — Separated Unto Yah"
          class="logo-panel-img"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Content -->
      <div class="content-panel">
        <p class="hero-eyebrow">Biblical Studies</p>
        <h1 class="hero-headline">
          The Doctrine Was Built<br>
          To Keep You <em>Comfortable.</em>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-body">
          Nazaryah goes back to the source — original languages, restored names, and the Torah your church quietly skipped. No denominations. No comfortable answers. Just the text.
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="btn btn-primary">Explore Studies</a>
          <a href="/about" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      width: 100%;
      padding: 2rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 5fr 8fr;
      width: 100%;
      max-width: 80rem;
      aspect-ratio: 13 / 4;
      overflow: hidden;
      border-radius: 4px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.22), 0 2px 8px rgba(0,0,0,0.15);
    }

    /* ── LEFT PANEL: dark, logo centered ── */
    .logo-panel {
      position: relative;
      background: #0f0a04;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.25rem;
      overflow: hidden;
    }

    /* Subtle warm radial glow behind the logo */
    .logo-panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 45%, rgba(180, 120, 30, 0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Corner ornaments */
    .logo-panel::after {
      content: '';
      position: absolute;
      top: 10px; left: 10px;
      width: 20px; height: 20px;
      border-top: 1.5px solid rgba(196, 154, 78, 0.45);
      border-left: 1.5px solid rgba(196, 154, 78, 0.45);
    }

    .logo-panel-img {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 85%;
      object-fit: contain;
    }

    /* ── RIGHT PANEL ── */
    .content-panel {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.65rem;
      padding: 1.5rem 2rem 1.5rem 2rem;
    }

    .hero-eyebrow {
      font-family: var(--font-display);
      font-size: 10px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-faded);
      opacity: 0.75;
      margin: 0;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.75rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--color-primary-text);
      margin: 0;
    }

    .hero-headline em {
      font-style: italic;
      color: var(--gold-light, #c49a4e);
    }

    .hero-rule {
      width: 48px;
      height: 1.5px;
      background: var(--color-border-strong);
      opacity: 0.65;
    }

    .hero-body {
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--color-secondary-text);
      margin: 0;
    }

    .hero-cta-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .pillar-grid {
        grid-template-columns: 1fr !important;
      }
    }

    @media (max-width: 720px) {
      .hero-section {
        padding: 1.5rem 1rem;
      }

      .hero-grid {
        grid-template-columns: 1fr;
        aspect-ratio: unset;
        max-width: 100%;
      }

      .logo-panel {
        padding: 1.75rem 1.5rem;
        min-height: 180px;
      }

      .logo-panel-img {
        max-width: 220px;
      }

      .content-panel {
        padding: 1.75rem 1.5rem;
        gap: 0.75rem;
      }

      .hero-headline {
        font-size: 1.6rem;
      }
    }
  </style>

  <!-- Christian or Demonic? — Five-Part Examination -->
  <section class="cod-section">
    <div class="cod-inner">

      <p class="cod-eyebrow"><span>A Five-Part Examination</span></p>

      <h2 class="cod-headline">
        Christian <span class="or">or</span> <span class="demonic">Demonic?</span>
      </h2>

      <p class="cod-subhead">
        Five pillars of modern Christianity. Five uncomfortable questions.
        Five answers the pulpit never gave you.
      </p>

      <p class="cod-verdict">Let Scripture &amp; History Decide</p>

      <div class="cod-grid">

        <!-- CARD 1: PRAYER -->
        <article class="cod-card" data-accent="prayer">
          <span class="cod-chapter">CHAPTER 01</span>
          <span class="cod-chapter-big">1</span>
          <p class="cod-card-topic">Prayer</p>
          <h3 class="cod-card-title">It's a Courtroom Word. Not a Feeling.</h3>
          <p class="cod-card-hook">
            Ask any believer what prayer means and you'll hear <em>"talking to God."</em>
            But the Hebrew word <strong>palal</strong> doesn't mean talking — it means
            to <strong>judge</strong> and <strong>mediate</strong>. Every Hebrew word for prayer
            is a job description. And only one Person fills it.
          </p>
          <div class="cod-card-links">
            <a href="/studies/prayer" class="cod-link">
              <span>Read the Study</span><span class="arrow">→</span>
            </a>
          </div>
        </article>

        <!-- CARD 2: MUSIC -->
        <article class="cod-card" data-accent="music">
          <span class="cod-chapter">CHAPTER 02</span>
          <span class="cod-chapter-big">2</span>
          <p class="cod-card-topic">Music</p>
          <h3 class="cod-card-title">The Sound of Self-Worship.</h3>
          <p class="cod-card-hook">
            Every believer can spot AC/DC. But the music on Sunday morning — the hypnotic
            loops, the build-and-release, the trance-inducing key changes — was
            <em>engineered</em>. Not by Yahuah. By the one whose tabrets and pipes were
            prepared in him on the day he was created.
          </p>
          <div class="cod-card-links">
            <a href="/studies/music" class="cod-link">
              <span>Read the Study</span><span class="arrow">→</span>
            </a>
          </div>
        </article>

        <!-- CARD 3: CANON (SPECIAL — TWO LINKS) -->
        <article class="cod-card" data-accent="canon">
          <span class="cod-chapter">CHAPTER 03</span>
          <span class="cod-chapter-big">3</span>
          <p class="cod-card-topic">The Canon</p>
          <h3 class="cod-card-title">Who Gave You the New Testament?</h3>
          <p class="cod-card-hook">
            Show me where Yahuah authorized it. Show me where the Messiah approved it.
            Show me where the apostles signed off. You <em>can't</em>.
            The only stamp it carries is from men already deep inside a religion
            forged by Constantine.
          </p>
          <div class="cod-card-links">
            <a href="/studies/canon" class="cod-link">
              <span>Read the Teaching</span><span class="arrow">→</span>
            </a>
            <a href="/studies/canon/parable" class="cod-link cod-link-mystery">
              <span><span class="sparkle">✦</span> Unveil the Mystery — Enter the Parable</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </article>

        <!-- CARD 4: TRANSLATIONS -->
        <article class="cod-card" data-accent="trans">
          <span class="cod-chapter">CHAPTER 04</span>
          <span class="cod-chapter-big">4</span>
          <p class="cod-card-topic">Translations</p>
          <h3 class="cod-card-title">You Haven't Been Reading the Word.</h3>
          <p class="cod-card-hook">
            The Father's name erased nearly <strong>seven thousand times</strong>.
            A Trinity verse inserted that was never in the Greek. The Hebrew vowel-pointed
            a thousand years after Messiah by men who rejected Him. You haven't been reading
            Scripture. You've been reading <em>an edition</em>.
          </p>
          <div class="cod-card-links">
            <a href="/studies/translations" class="cod-link">
              <span>Read the Study</span><span class="arrow">→</span>
            </a>
          </div>
        </article>

        <!-- CARD 5: LANGUAGE & SYMBOLS -->
        <article class="cod-card" data-accent="symbols">
          <span class="cod-chapter">CHAPTER 05</span>
          <span class="cod-chapter-big">5</span>
          <p class="cod-card-topic">Language &amp; Symbols</p>
          <h3 class="cod-card-title">Do You Know What You're Worshipping?</h3>
          <p class="cod-card-hook">
            The cross belonged to Tammuz. The fish belonged to Dagon. The candles were
            Mithraic. Dice were tools of <em>witchcraft</em>. And Ezekiel 8 already called
            bowing toward the sunrise <em>the greatest abomination</em> — long before
            anyone invented an Easter service.
          </p>
          <div class="cod-card-links">
            <a href="/studies/language-symbols" class="cod-link">
              <span>Read the Study</span><span class="arrow">→</span>
            </a>
          </div>
        </article>

      </div>

      <div class="cod-footer-line">
        <p>
          Every claim below is measured against the text in the languages it was given.
          No creeds. No councils. No comfortable conclusions.
        </p>
      </div>

    </div>
  </section>

  <style>
    /* ===========================================================
       "Christian or Demonic?" Home Page Feature Section
       Namespaced with cod- prefix — no collision with global styles
       =========================================================== */
    .cod-section {
      --cod-ink: #1a1a1a;
      --cod-ink-soft: #2c2c2c;
      --cod-gray: #595959;
      --cod-gray-light: #8a8a8a;
      --cod-navy: #1F3864;
      --cod-navy-deep: #142547;
      --cod-cream: #f7f3ea;
      --cod-paper: #faf8f3;
      --cod-rule: #d9d4c7;
      --cod-blood: #7a1a1a;
      --cod-gold: #a67f00;
      --cod-gold-bright: #c99a17;
      --cod-shadow: rgba(20, 37, 71, 0.12);

      background: var(--cod-paper);
      padding: 120px 24px 140px;
      font-family: Georgia, 'Times New Roman', serif;
      color: var(--cod-ink);
      position: relative;
      overflow: hidden;
    }

    .cod-section::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(31,56,100,0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(122,26,26,0.02) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    .cod-inner {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .cod-eyebrow {
      text-align: center;
      font-size: 13px;
      letter-spacing: 0.4em;
      color: var(--cod-gray);
      text-transform: uppercase;
      margin-bottom: 28px;
      font-weight: 600;
    }

    .cod-eyebrow span {
      display: inline-block;
      padding: 0 24px;
      position: relative;
    }

    .cod-eyebrow span::before,
    .cod-eyebrow span::after {
      content: "";
      position: absolute;
      top: 50%;
      width: 40px;
      height: 1px;
      background: var(--cod-gray-light);
    }

    .cod-eyebrow span::before { right: 100%; }
    .cod-eyebrow span::after  { left: 100%; }

    .cod-headline {
      text-align: center;
      font-size: clamp(2.2rem, 5.5vw, 4.2rem);
      line-height: 1.05;
      font-weight: 400;
      color: var(--cod-ink);
      margin: 0 0 24px 0;
      letter-spacing: -0.02em;
    }

    .cod-headline .or {
      font-style: italic;
      color: var(--cod-gray);
      font-weight: 300;
      display: inline-block;
      margin: 0 0.15em;
    }

    .cod-headline .demonic {
      color: var(--cod-blood);
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .cod-subhead {
      text-align: center;
      font-size: 1.15rem;
      font-style: italic;
      color: var(--cod-gray);
      max-width: 680px;
      margin: 0 auto 16px;
      line-height: 1.55;
    }

    .cod-verdict {
      text-align: center;
      font-size: 0.95rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--cod-navy);
      font-weight: 600;
      margin-bottom: 80px;
    }

    .cod-verdict::before,
    .cod-verdict::after {
      content: " ◆ ";
      color: var(--cod-navy);
      margin: 0 14px;
      opacity: 0.5;
    }

    .cod-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      margin-bottom: 40px;
    }

    @media (max-width: 980px) {
      .cod-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .cod-grid { grid-template-columns: 1fr; }
    }

    .cod-card {
      background: linear-gradient(180deg, #fefdfa 0%, var(--cod-paper) 100%);
      border: 1px solid var(--cod-rule);
      padding: 34px 30px 28px;
      position: relative;
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      display: flex;
      flex-direction: column;
      min-height: 400px;
      box-shadow: 0 2px 8px var(--cod-shadow);
    }

    .cod-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(20, 37, 71, 0.18);
      border-color: var(--cod-navy);
    }

    .cod-chapter {
      position: absolute;
      top: 22px;
      right: 26px;
      font-size: 0.7rem;
      letter-spacing: 0.3em;
      color: var(--cod-gray-light);
      font-weight: 600;
    }

    .cod-chapter-big {
      position: absolute;
      bottom: -12px;
      right: -6px;
      font-size: 130px;
      line-height: 1;
      font-weight: 700;
      color: var(--cod-navy);
      opacity: 0.04;
      pointer-events: none;
      user-select: none;
    }

    .cod-card-topic {
      font-size: 0.72rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--cod-navy);
      font-weight: 700;
      margin-bottom: 16px;
    }

    .cod-card-title {
      font-size: 1.5rem;
      line-height: 1.2;
      font-weight: 600;
      color: var(--cod-ink);
      margin: 0 0 16px 0;
      letter-spacing: -0.01em;
    }

    .cod-card-hook {
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--cod-ink-soft);
      margin: 0 0 24px 0;
      flex-grow: 1;
    }

    .cod-card-hook strong {
      color: var(--cod-navy);
      font-weight: 600;
    }

    .cod-card-hook em {
      color: var(--cod-blood);
      font-style: italic;
      font-weight: 500;
    }

    .cod-card-links {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: auto;
      padding-top: 18px;
      border-top: 1px solid var(--cod-rule);
      position: relative;
      z-index: 2;
    }

    .cod-link {
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.98rem;
      font-weight: 600;
      color: var(--cod-navy);
      text-decoration: none;
      padding: 10px 0;
      border-bottom: 1px solid transparent;
      transition: all 0.25s ease;
      letter-spacing: 0.02em;
    }

    .cod-link:hover {
      color: var(--cod-navy-deep);
      border-bottom-color: var(--cod-navy);
      padding-left: 4px;
    }

    .cod-link .arrow {
      font-size: 1.2em;
      transition: transform 0.25s ease;
    }

    .cod-link:hover .arrow {
      transform: translateX(4px);
    }

    .cod-link-mystery {
      background: linear-gradient(135deg, var(--cod-navy) 0%, var(--cod-navy-deep) 100%);
      color: var(--cod-gold-bright);
      padding: 12px 16px;
      border: 1px solid var(--cod-navy-deep);
      font-style: italic;
      font-size: 0.88rem;
      letter-spacing: 0.03em;
      position: relative;
      overflow: hidden;
      margin-top: 4px;
    }

    .cod-link-mystery::before {
      content: "";
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(201, 154, 23, 0.15), transparent);
      transition: left 0.6s ease;
    }

    .cod-link-mystery:hover {
      color: #fff;
      border-color: var(--cod-gold-bright);
      padding-left: 24px;
      border-bottom-color: var(--cod-gold-bright);
    }

    .cod-link-mystery:hover::before {
      left: 100%;
    }

    .cod-link-mystery .sparkle {
      color: var(--cod-gold-bright);
      margin-right: 10px;
      font-size: 0.9em;
    }

    .cod-card[data-accent="prayer"]   { border-top: 3px solid var(--cod-navy); }
    .cod-card[data-accent="music"]    { border-top: 3px solid var(--cod-navy); }
    .cod-card[data-accent="canon"]    { border-top: 3px solid var(--cod-blood); }
    .cod-card[data-accent="trans"]    { border-top: 3px solid var(--cod-navy); }
    .cod-card[data-accent="symbols"]  { border-top: 3px solid var(--cod-navy); }

    .cod-card[data-accent="canon"] { min-height: 440px; }

    .cod-footer-line {
      text-align: center;
      margin-top: 60px;
      padding-top: 40px;
      border-top: 1px solid var(--cod-rule);
    }

    .cod-footer-line p {
      font-size: 1rem;
      font-style: italic;
      color: var(--cod-gray);
      max-width: 620px;
      margin: 0 auto;
      line-height: 1.6;
    }

    @media (max-width: 980px) {
      .cod-card-title { font-size: 1.65rem; }
      .cod-card-hook { font-size: 1rem; }
    }

    @media (max-width: 640px) {
      .cod-section { padding: 80px 20px 100px; }
      .cod-card { padding: 32px 28px 28px; min-height: auto; }
      .cod-card[data-accent="canon"] { min-height: auto; }
      .cod-chapter-big { font-size: 120px; }
      .cod-verdict { margin-bottom: 56px; font-size: 0.82rem; }
      .cod-verdict::before,
      .cod-verdict::after { margin: 0 6px; }
    }

    @media (prefers-reduced-motion: no-preference) {
      .cod-card {
        opacity: 0;
        transform: translateY(20px);
        animation: codReveal 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      }
      .cod-card:nth-child(1) { animation-delay: 0.05s; }
      .cod-card:nth-child(2) { animation-delay: 0.15s; }
      .cod-card:nth-child(3) { animation-delay: 0.25s; }
      .cod-card:nth-child(4) { animation-delay: 0.35s; }
      .cod-card:nth-child(5) { animation-delay: 0.45s; }

      @keyframes codReveal {
        to { opacity: 1; transform: translateY(0); }
      }
    }
  </style>

  <!-- Featured Studies — 5 across, one latest post per category -->
  <section class="py-20 md:py-24 border-t border-[var(--sand-dark)]">
    <div class="container mx-auto px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-3" style="font-family: var(--font-display); color: var(--deep-earth);">
          Featured Studies
        </h2>
        <p class="text-center mb-12 max-w-2xl mx-auto" style="color: var(--ink-faded);">
          The latest study from each of our core categories.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
          {displayPosts.map(({ category, post }) => (
            post ? (
              <article class="card group flex flex-col">
                <div class="p-6 flex flex-col flex-1">
                  <div class="tag mb-3" style="color: var(--bronze);">
                    {category}
                  </div>
                  <h3 class="text-lg font-semibold mb-3 leading-snug" style="font-family: var(--font-display); color: var(--deep-earth);">
                    <a href={`/blog/${post.slug}`} class="hover:text-[var(--bronze)] transition-colors" style="color: var(--deep-earth);">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-sm leading-relaxed mb-5 line-clamp-4 flex-1" style="color: var(--ink-faded);">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-xs pt-4 border-t border-[var(--sand-dark)]" style="color: var(--ink-faded); font-family: var(--font-body);">
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <a
                      href={`/blog/${post.slug}`}
                      class="font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1"
                      style="color: var(--bronze);"
                    >
                      Read <span aria-hidden="true">&rarr;</span>
                    </a>
                  </div>
                </div>
              </article>
            ) : (
              <article class="card flex flex-col opacity-70">
                <div class="p-6 flex flex-col flex-1">
                  <div class="tag mb-3" style="color: var(--bronze);">
                    {category}
                  </div>
                  <h3 class="text-lg font-semibold mb-3 leading-snug" style="font-family: var(--font-display); color: var(--deep-earth);">
                    Coming soon
                  </h3>
                  <p class="text-sm leading-relaxed flex-1 italic" style="color: var(--ink-faded);">
                    The first study in this category has not been published yet.
                  </p>
                </div>
              </article>
            )
          ))}
        </div>
        <div class="text-center mt-12">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 font-medium transition-colors"
            style="font-family: var(--font-display); color: var(--bronze); letter-spacing: 1px;"
          >
            View All Studies <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section style="font-family: Georgia, 'Times New Roman', serif; background: #0E0C08; padding: 2.5rem 1.5rem; text-align: center;">

    <h2 style="font-size: 1.6rem; font-weight: 700; color: #C9A84C; letter-spacing: 0.06em; font-variant: small-caps; margin-bottom: 0.6rem;">Our Approach</h2>

    <!-- Decorative Rule -->
    <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 1.25rem;">
      <span style="display: block; height: 1px; width: 120px; background: #C9A84C; opacity: 0.5;"></span>
      <svg width="12" height="12" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="12" height="12" stroke="#C9A84C" stroke-width="1" fill="none" transform="rotate(45 7 7)"/>
      </svg>
      <span style="display: block; height: 1px; width: 120px; background: #C9A84C; opacity: 0.5;"></span>
    </div>

    <!-- Intro Paragraph -->
    <p style="font-size: 0.92rem; color: #A89878; margin: 0 auto 2rem; font-style: italic; max-width: 780px; line-height: 1.8;">
      Most of what is taught in modern churches rests on centuries of tradition, mistranslation, and the decisions of councils — not on the plain text of Scripture. Our goal is simple: go back to the source. We study the Word as it was written, in the languages it was given, under the names
      <em style="color: #E8E0CC; font-style: normal; font-weight: bold;">Yahuah</em> and
      <em style="color: #E8E0CC; font-style: normal; font-weight: bold;">Yahushua</em>
      — because truth does not fear examination. Every study you find here is built on these four pillars.
    </p>

    <!-- 2x2 Pillar Grid -->
    <div class="pillar-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; max-width: 1200px; margin: 0 auto;">

      <!-- Card 1: Original Languages -->
      <div style="background: #1a1710; border: 1px solid #3a3020; border-top: 2px solid #C9A84C; border-radius: 4px; padding: 1rem 1.5rem; text-align: left; display: flex; flex-direction: row; align-items: flex-start; gap: 1.1rem;">
        <svg style="width: 28px; height: 28px; flex-shrink: 0; margin-top: 3px;" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="6" width="20" height="26" rx="2" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
          <line x1="8" y1="12" x2="20" y2="12" stroke="#C9A84C" stroke-width="1.2"/>
          <line x1="8" y1="16" x2="20" y2="16" stroke="#C9A84C" stroke-width="1.2"/>
          <line x1="8" y1="20" x2="16" y2="20" stroke="#C9A84C" stroke-width="1.2"/>
          <text x="24" y="19" font-size="13" fill="#C9A84C" font-family="serif" font-weight="bold">א</text>
        </svg>
        <div style="flex: 1;">
          <div style="font-size: 0.9rem; font-weight: 700; color: #C9A84C; font-variant: small-caps; letter-spacing: 0.06em; margin-bottom: 0.4rem; padding-bottom: 0.35rem; border-bottom: 1px solid #3a3020;">Original Languages &amp; True Names</div>
          <p style="font-size: 0.83rem; color: #A89878; line-height: 1.65; margin: 0;">We work directly from Hebrew and Greek manuscripts, restoring what translators obscured. The Father's name is <strong style="color: #E8E0CC; font-weight: bold;">Yahuah</strong>. The Messiah's name is <strong style="color: #E8E0CC; font-weight: bold;">Yahushua</strong>. Names carry identity, covenant, and authority — we will not set them aside for tradition's comfort.</p>
        </div>
      </div>

      <!-- Card 2: Torah -->
      <div style="background: #1a1710; border: 1px solid #3a3020; border-top: 2px solid #C9A84C; border-radius: 4px; padding: 1rem 1.5rem; text-align: left; display: flex; flex-direction: row; align-items: flex-start; gap: 1.1rem;">
        <svg style="width: 28px; height: 28px; flex-shrink: 0; margin-top: 3px;" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="18,4 32,30 4,30" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
          <line x1="18" y1="12" x2="18" y2="24" stroke="#C9A84C" stroke-width="1.2"/>
          <circle cx="18" cy="27" r="1.5" fill="#C9A84C"/>
        </svg>
        <div style="flex: 1;">
          <div style="font-size: 0.9rem; font-weight: 700; color: #C9A84C; font-variant: small-caps; letter-spacing: 0.06em; margin-bottom: 0.4rem; padding-bottom: 0.35rem; border-bottom: 1px solid #3a3020;">Torah as the Foundation</div>
          <p style="font-size: 0.83rem; color: #A89878; line-height: 1.65; margin: 0;">The Law was never abolished. <strong style="color: #E8E0CC; font-weight: bold;">Yahushua</strong> said He came to fulfill it, not end it (Matt. 5:17). Salvation comes through the Messiah alone, but that salvation leads us <strong style="color: #E8E0CC; font-weight: bold;">back</strong> to the Torah — not away from it. We reject the lawless grace taught in most modern pulpits.</p>
        </div>
      </div>

      <!-- Card 3: Exposing Tradition -->
      <div style="background: #1a1710; border: 1px solid #3a3020; border-top: 2px solid #C9A84C; border-radius: 4px; padding: 1rem 1.5rem; text-align: left; display: flex; flex-direction: row; align-items: flex-start; gap: 1.1rem;">
        <svg style="width: 28px; height: 28px; flex-shrink: 0; margin-top: 3px;" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="18" cy="18" r="13" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
          <line x1="18" y1="8" x2="18" y2="14" stroke="#C9A84C" stroke-width="1.5"/>
          <circle cx="18" cy="22" r="4" stroke="#C9A84C" stroke-width="1.2" fill="none"/>
        </svg>
        <div style="flex: 1;">
          <div style="font-size: 0.9rem; font-weight: 700; color: #C9A84C; font-variant: small-caps; letter-spacing: 0.06em; margin-bottom: 0.4rem; padding-bottom: 0.35rem; border-bottom: 1px solid #3a3020;">Exposing Tradition's Errors</div>
          <p style="font-size: 0.83rem; color: #A89878; line-height: 1.65; margin: 0;">Creeds and councils have buried Scripture under man-made theology. We examine doctrines like the Trinity, Sunday worship, pagan-rooted holidays, and the immortal soul — because <strong style="color: #E8E0CC; font-weight: bold;">Yahuah</strong> demands we worship Him in <strong style="color: #E8E0CC; font-weight: bold;">truth</strong>, not inherited assumption.</p>
        </div>
      </div>

      <!-- Card 4: Scripture Authority -->
      <div style="background: #1a1710; border: 1px solid #3a3020; border-top: 2px solid #C9A84C; border-radius: 4px; padding: 1rem 1.5rem; text-align: left; display: flex; flex-direction: row; align-items: flex-start; gap: 1.1rem;">
        <svg style="width: 28px; height: 28px; flex-shrink: 0; margin-top: 3px;" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="6" y="8" width="24" height="20" rx="2" stroke="#C9A84C" stroke-width="1.5" fill="none"/>
          <line x1="12" y1="8" x2="12" y2="28" stroke="#C9A84C" stroke-width="1"/>
          <line x1="6" y1="18" x2="30" y2="18" stroke="#C9A84C" stroke-width="1"/>
        </svg>
        <div style="flex: 1;">
          <div style="font-size: 0.9rem; font-weight: 700; color: #C9A84C; font-variant: small-caps; letter-spacing: 0.06em; margin-bottom: 0.4rem; padding-bottom: 0.35rem; border-bottom: 1px solid #3a3020;">Scripture as Sole Authority</div>
          <p style="font-size: 0.83rem; color: #A89878; line-height: 1.65; margin: 0;">No rabbinical commentary, no church council, no denominational creed stands above the written Word. Every claim is measured against Scripture in its original context. If it cannot be shown plainly from the text, <strong style="color: #E8E0CC; font-weight: bold;">we will say so honestly</strong>.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Newsletter -->
