---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeCard from '../components/HomeCard.astro';
---

<BaseLayout
  title="Nazaryah - Biblical Studies with Scholarly Integrity"
  description="Explore Scripture through original languages, fresh perspectives, and rich historical context. A modern biblical studies platform for serious learners."
>
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <!-- Subtle grid texture overlay -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px),
        repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.022) 40px);
      z-index: 0;
    "></div>

    <div class="hero-grid relative z-10">
      <!-- LEFT: Logo panel (dark background matches logo image) -->
      <div class="logo-panel">
        <img
          src="/images/nazaryah-logo.png"
          alt="Nazaryah — Separated Unto Yah"
          class="logo-panel-img"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- RIGHT: Content -->
      <div class="content-panel">
        <div class="hero-eyebrow">Separated Unto Yahuah</div>
        <h1 class="hero-headline">
          The doctrine was built<br>
          to keep you <em>comfortable.</em>
        </h1>
        <div class="hero-rule"></div>
        <div class="hero-body-row">
          <p class="hero-body">
            Nazaryah goes back to the source — original languages, restored names, and the Torah your church quietly skipped. No denominations. No comfortable answers. Just the text.
          </p>
          <div class="hero-cta-stack">
            <a href="/doctrines" class="hero-cta" aria-label="Start here — Doctrines">
              <span class="hero-cta-badge"><span class="star" aria-hidden="true">★</span> Start Here</span>
              <span class="hero-cta-label">Doctrines</span>
              <span class="hero-cta-arrow" aria-hidden="true">→</span>
            </a>
            <a href="/books" class="hero-cta hero-cta--ghost" aria-label="Read — Published Books">
              <span class="hero-cta-badge"><span class="star" aria-hidden="true">★</span> Read</span>
              <span class="hero-cta-label">Published Books</span>
              <span class="hero-cta-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      width: 100%;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 5fr 8fr;
      width: 100%;
      max-width: 80rem;
      /* Aspect ratio dropped — the second stacked CTA needs vertical room
         and the box now sizes to its content. min-height keeps the box
         from collapsing on copy changes. */
      min-height: 16rem;
      overflow: hidden;
      border-radius: 4px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.22), 0 2px 8px rgba(0,0,0,0.15);
    }

    /* ── LEFT PANEL: dark, logo centered ── */
    .logo-panel {
      position: relative;
      background: #0f0a04;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.25rem;
      overflow: hidden;
    }

    /* Subtle warm radial glow behind the logo */
    .logo-panel::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 45%, rgba(180, 120, 30, 0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Corner ornaments */
    .logo-panel::after {
      content: '';
      position: absolute;
      top: 10px; left: 10px;
      width: 20px; height: 20px;
      border-top: 1.5px solid rgba(196, 154, 78, 0.45);
      border-left: 1.5px solid rgba(196, 154, 78, 0.45);
    }

    .logo-panel-img {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 85%;
      object-fit: contain;
    }

    /* ── RIGHT PANEL ── */
    .content-panel {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.6rem;
      padding: 1rem 2rem;
    }

    .hero-eyebrow {
      color: #6b4d12;
      font-family: var(--font-display, 'Cinzel', Georgia, serif);
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 0.15rem;
    }
    .hero-eyebrow::before {
      content: '\25C6  '; /* ◆ */
      color: #d4a531;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(1.25rem, 2.1vw, 1.85rem);
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: -0.005em;
      color: var(--color-primary-text);
      margin: 0;
    }

    .hero-headline em {
      font-style: italic;
      color: #6b4d12;
      font-weight: 600;
    }

    .hero-rule {
      width: 50px;
      height: 2px;
      background: #d4a531;
      opacity: 0.85;
      margin-top: 0.1rem;
    }

    /* Body + CTA share one horizontal row so the button hangs to the
       right of the paragraph instead of dropping below the hero box. */
    .hero-body-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-top: 0.4rem;
    }

    .hero-body {
      font-family: var(--font-body);
      font-size: 0.92rem;
      line-height: 1.5;
      color: var(--color-secondary-text);
      /* Cap the column so it never bleeds past the end of the headline
         word "COMFORTABLE." — leaves room for the CTA on the right. */
      flex: 1 1 0;
      max-width: 26rem;
      margin: 0;
    }

    /* Vertical stack for the two CTAs — primary on top, ghost secondary
       beneath. Aligned to the start of the column so both buttons start
       at the same left edge. */
    .hero-cta-stack {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      flex: 0 0 auto;
      align-self: center;
    }

    /* ── "Start Here · Doctrines" CTA — single gold pill with badge inside ── */
    .hero-cta {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      flex: 0 0 auto;
      align-self: center;
      padding: 0.85rem 1.6rem;
      background: linear-gradient(180deg, #f0c450 0%, #d4a531 100%);
      color: #1a0e06;
      text-decoration: none;
      font-family: var(--font-display, 'Cinzel', 'Playfair Display', Georgia, serif);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border: 2px solid #a87f1f;
      border-radius: 4px;
      box-shadow: 0 4px 12px -2px rgba(168, 127, 31, 0.45);
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    .hero-cta:hover {
      transform: translateY(-1px);
      background: linear-gradient(180deg, #d4a531 0%, #a87f1f 100%);
      box-shadow: 0 6px 16px -2px rgba(168, 127, 31, 0.55);
    }

    .hero-cta-badge {
      background: #1a0e06;
      color: #f0c450;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      font-weight: 700;
      padding: 0.32rem 0.7rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .hero-cta-badge .star {
      margin-right: 0.2rem;
    }

    .hero-cta-label {
      font-size: 1rem;
      font-weight: 700;
      color: #1a0e06;
    }
    .hero-cta-arrow {
      font-size: 1rem;
      line-height: 1;
      transition: transform 0.2s ease;
    }
    .hero-cta:hover .hero-cta-arrow {
      transform: translateX(3px);
    }

    /* Ghost variant — same compound shape as primary but transparent
       background with a gold outline. Visually subordinate so Doctrines
       stays the dominant "Start Here" entry point. */
    .hero-cta--ghost {
      background: transparent;
      border-color: #a87f1f;
      color: #6b4d12;
      padding: 0.65rem 1.3rem;
      font-size: 0.82rem;
      box-shadow: none;
    }
    .hero-cta--ghost .hero-cta-badge {
      background: #1a0e06;
      color: #f0c450;
      font-size: 0.55rem;
      padding: 0.25rem 0.55rem;
    }
    .hero-cta--ghost .hero-cta-label,
    .hero-cta--ghost .hero-cta-arrow {
      color: #6b4d12;
      font-size: 0.85rem;
    }
    .hero-cta--ghost:hover {
      transform: translateY(-1px);
      background: rgba(168, 127, 31, 0.1);
      border-color: #6b4d12;
      box-shadow: 0 4px 10px -3px rgba(168, 127, 31, 0.3);
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .pillar-grid {
        grid-template-columns: 1fr !important;
      }
    }

    @media (max-width: 720px) {
      .hero-section {
        padding: 1.5rem 1rem;
      }

      .hero-grid {
        grid-template-columns: 1fr;
        aspect-ratio: unset;
        max-width: 100%;
      }

      .logo-panel {
        padding: 1.75rem 1.5rem;
        min-height: 180px;
      }

      .logo-panel-img {
        max-width: 220px;
      }

      .content-panel {
        padding: 1.75rem 1.5rem;
        gap: 0.75rem;
      }

      .hero-headline {
        font-size: 1.6rem;
      }

      /* Stack body + button vertically once the hero collapses to one column */
      .hero-body-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }

      .hero-body {
        max-width: 100%;
      }
    }
  </style>

  <!-- ============================================================
       PERSONAL TOOLS — contained split-screen feature band
       ============================================================ -->
  <div class="personal-tools-wrap">
    <section class="personal-tools" aria-label="Personal study tools">
      <a href="/christian-or-demonic" class="tool-half tool-red">
        <div class="tool-eyebrow">Test what you were taught</div>
        <h2 class="tool-title">Christian <em>or</em> Demonic?</h2>
        <p class="tool-catchphrase">Five pillars. Five hard questions.</p>
        <span class="tool-cta">Begin the Examination →</span>
      </a>
      <a href="/pathway" class="tool-half tool-green">
        <div class="tool-eyebrow">Build your own study</div>
        <h2 class="tool-title"><em>Pathways</em></h2>
        <p class="tool-catchphrase">Bite-sized studies. Your own pace.</p>
        <span class="tool-cta">Walk the Path →</span>
      </a>
    </section>
  </div>

  <!-- ============================================================
       GRID A — THE COUNTERFEITS
       ============================================================ -->
  <section class="home-grid-section">
    <div class="home-grid-container">
      <div class="home-grid-header">
        <p class="home-grid-eyebrow">What modern Christianity got wrong</p>
        <div class="home-grid-ornament" aria-hidden="true">◆</div>
        <h2 class="home-grid-title">The Counterfeits</h2>
        <p class="home-grid-subtitle">Four doctrines, symbols, and institutions the pulpit never held up to the text.</p>
      </div>
      <div class="home-grid-4">
        <HomeCard
          href="/trinity"
          color="emerald"
          icon="✡"
          eyebrow="Examining a sacred cow"
          title='The <em>Trinity</em>'
          description="Three Gods in one — or one Father quietly hidden behind the doctrine?"
          cta="Examine the Doctrine"
        />
        <HomeCard
          href="/sun-worship"
          color="amber"
          icon="☀"
          eyebrow="The oldest counterfeit"
          title='Sun <em>Worship</em>'
          description="From Babel to Easter morning to the obelisks of every capital city."
          cta="Trace the Pattern"
        />
        <HomeCard
          href="/catholicism"
          color="violet"
          icon="†"
          eyebrow="The mother church"
          title='<em>Catholicism</em>'
          description="The institution that crowned itself — and the daughters who never left home."
          cta="Open the Indictment"
        />
        <HomeCard
          href="/foreign-fire"
          color="charcoal"
          icon="🜂"
          eyebrow="Strange fire on the altar"
          title='Foreign <em>Fire</em>'
          description="Worship Yahuah did not command. Nadab and Abihu would recognize it."
          cta="Read the Warning"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       GRID B — RESTORATION
       ============================================================ -->
  <section class="home-grid-section">
    <div class="home-grid-container">
      <div class="home-grid-header">
        <p class="home-grid-eyebrow">What the text actually says</p>
        <div class="home-grid-ornament" aria-hidden="true">◆</div>
        <h2 class="home-grid-title">Restoration</h2>
        <p class="home-grid-subtitle">Four threads pulling the original signal back through the noise.</p>
      </div>
      <div class="home-grid-4">
        <HomeCard
          href="/blog"
          color="sepia"
          icon="א"
          eyebrow="Scripture unfiltered"
          title='The <em>Studies</em>'
          description="Word studies, doctrines, and topical deep-dives — the full archive."
          cta="All Studies"
        />
        <HomeCard
          href="/calendar"
          color="indigo"
          icon="☾"
          eyebrow="Set in the lights"
          title='The <em>Calendar</em>'
          description="Aviv, the renewed moon, the Sabbath. The way Yahuah set the seasons."
          cta="Open the Calendar"
        />
        <HomeCard
          href="/hebrew"
          color="oxblood"
          icon="ב"
          eyebrow="The language of Yahuah"
          title='<em>Hebrew</em>'
          description="Restored names, root words, and the meanings translation flattened."
          cta="Study the Roots"
        />
        <HomeCard
          href="/hidden-gems"
          color="teal"
          icon="◈"
          eyebrow="Buried in plain sight"
          title='Hidden <em>Gems</em>'
          description="The verses your pastor flipped past — and what they actually mean."
          cta="Dig In"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       GRID C — LIVING THE TORAH
       ============================================================ -->
  <section class="home-grid-section">
    <div class="home-grid-container">
      <div class="home-grid-header">
        <p class="home-grid-eyebrow">Walking it out</p>
        <div class="home-grid-ornament" aria-hidden="true">◆</div>
        <h2 class="home-grid-title">Living the Torah</h2>
        <p class="home-grid-subtitle">What obedience looks like in a culture built to oppose it.</p>
      </div>
      <div class="home-grid-4">
        <HomeCard
          href="/hollywood"
          color="blackgold"
          icon="◉"
          eyebrow="Raised on magic"
          title='<em>Hollywood</em>'
          description="Wizards as heroes. Witches as misunderstood. Catechism in disguise."
          cta="Open the Section"
        />
        <HomeCard
          href="/american-idolatry"
          color="navy"
          icon="★"
          eyebrow="The flag on the pulpit"
          title='American <em>Idolatry</em>'
          description="When country becomes covenant and patriotism becomes worship."
          cta="Examine It"
        />
        <HomeCard
          href="/holidays"
          color="burgundy"
          icon="✦"
          eyebrow="Christmas · Easter · Sunday"
          title='The <em>Holidays</em>'
          description="Days the church kept that the text never named — and the Feasts it forgot."
          cta="Trace the Origins"
        />
        <HomeCard
          href="/ekklesia"
          color="stone"
          icon="⌂"
          eyebrow="What the church is not"
          title='<em>Ekklesia</em>'
          description="The institution called &ldquo;church&rdquo; — and how far it drifted from the assembly."
          cta="Recover the Pattern"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       FROM THE DESK — compressed: 2 brief cards + archive button
       ============================================================ -->
  <section class="desk-section">
    <div class="desk-container">
      <div class="desk-header">
        <h2 class="desk-title"><em>From the Desk</em></h2>
        <p class="desk-sub">A brief on the news. A study worth reading right now.</p>
      </div>
      <div class="desk-grid">
        <a href="/watchmans-desk" class="desk-brief">
          <div class="desk-brief-eyebrow">★ The Watchman&rsquo;s Desk ★</div>
          <div class="desk-brief-meta">5 May 2026 · Brief</div>
          <h3 class="desk-brief-title">The Triumphal Arch Comes to Washington</h3>
          <div class="desk-brief-divider"></div>
          <div class="desk-brief-body">
            <span class="desk-drop-cap">O</span>n April 16 the federal Commission of Fine Arts approved a 250-foot Roman arch — copy of Napoleon&rsquo;s Sol Invictus monument. Unveiling targeted for July 4. The form is older than Rome. The date is older than the calendar.
          </div>
          <div class="desk-readmore">Read the Brief →</div>
        </a>
        <a href="/american-idolatry/memorial-veterans-day" class="desk-brief">
          <div class="desk-brief-eyebrow">★ Study · American Idolatry ★</div>
          <div class="desk-brief-meta">Memorial Day · Approaching</div>
          <h3 class="desk-brief-title">When Sacrifice Becomes Worship</h3>
          <div class="desk-brief-divider"></div>
          <div class="desk-brief-body">
            <span class="desk-drop-cap">M</span>emorial Day is approaching. The flag-draped coffins, the moment of silence, the &ldquo;they died so you could live.&rdquo; Held up honestly against what the text actually says about whose blood saves and whose sacrifice matters.
          </div>
          <div class="desk-readmore">Read the Study →</div>
        </a>
      </div>
      <div class="desk-archive-cta">
        <a href="/watchmans-desk" class="hero-cta" aria-label="Browse all briefs">
          <span class="hero-cta-badge"><span class="star" aria-hidden="true">★</span> Archive</span>
          <span class="hero-cta-label">Browse All Briefs</span>
          <span class="hero-cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    /* ============================================================
       PERSONAL TOOLS BAND
       Contained split-screen — capped at 1280px, centered, with
       rounded corners and a strong shadow lift. Both halves clickable.
       ============================================================ */
    .personal-tools-wrap {
      padding: 3.125rem 1.5rem 1.875rem; /* 50px / 30px vertical */
    }

    .personal-tools {
      display: grid;
      grid-template-columns: 1fr 1fr;
      max-width: 80rem;
      margin: 0 auto;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    }

    .tool-half {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 2.375rem 2.5rem; /* 38px / 40px */
      min-height: 13.75rem;     /* 220px */
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: filter 0.3s ease;
    }
    .tool-half::before {
      content: '';
      position: absolute;
      top: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 80%;
      height: 100%;
      background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.06) 0%, transparent 60%);
      pointer-events: none;
    }
    .tool-half:hover { filter: brightness(1.1); }

    .tool-red {
      background: radial-gradient(ellipse at 50% 30%, #5a0a0a 0%, #2a0303 70%, #1a0000 100%);
      border-right: 1px solid rgba(212, 175, 55, 0.25);
    }
    .tool-green {
      background: radial-gradient(ellipse at 50% 30%, #1a4a30 0%, #0d2818 70%, #051a0d 100%);
    }

    .tool-eyebrow {
      font-family: 'Cinzel', serif;
      font-size: 0.625rem;     /* 10px */
      letter-spacing: 0.25em;  /* 4px */
      color: #d4af37;
      margin-bottom: 0.875rem; /* 14px */
      font-weight: 600;
      text-transform: uppercase;
      z-index: 2;
    }

    /* Title MUST stay on one line — that is the whole point of the
       46px size and the contained band. Use white-space: nowrap. */
    .tool-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-style: italic;
      font-size: 2.875rem;     /* 46px */
      line-height: 1;
      color: #f5e6c8;
      margin-bottom: 0.75rem;  /* 12px */
      z-index: 2;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
      white-space: nowrap;
    }
    .tool-title em {
      color: #d4af37;
      font-weight: 600;
    }

    .tool-catchphrase {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      font-size: 1.125rem;     /* 18px */
      color: #e8d9b8;
      margin-bottom: 1.25rem;  /* 20px */
      z-index: 2;
      line-height: 1.3;
    }

    /* CTA gets a centered 60px gold hairline ABOVE it (decorative
       pseudo-element rather than a flush border-top). */
    .tool-cta {
      position: relative;
      font-family: 'Cinzel', serif;
      font-size: 0.625rem;     /* 10px */
      letter-spacing: 0.3em;   /* 3px-equivalent at this size */
      color: #d4af37;
      text-transform: uppercase;
      font-weight: 600;
      z-index: 2;
      padding-top: 0.75rem;    /* 12px */
    }
    .tool-cta::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 1px;
      background: rgba(212, 175, 55, 0.4);
    }

    /* ============================================================
       GRID SECTIONS — Counterfeits, Restoration, Living the Torah
       ============================================================ */
    .home-grid-section {
      background: #0a0a0a;
      padding: 5rem 0 4rem;
      border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    }

    .home-grid-container {
      max-width: 80rem;
      margin: 0 auto;
      padding: 0 2.5rem;
    }

    .home-grid-header {
      text-align: center;
      margin-bottom: 3.2rem;
    }
    .home-grid-eyebrow {
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      color: #d4af37;
      margin: 0 0 1rem;
      text-transform: uppercase;
      font-weight: 600;
    }
    .home-grid-ornament {
      color: #d4af37;
      font-size: 0.7rem;
      margin: 0 1rem 0.6rem;
    }
    .home-grid-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-style: italic;
      font-size: clamp(2.2rem, 4.5vw, 3.2rem);
      color: #f5e6c8;
      margin: 0 0 1.1rem;
      font-weight: 500;
    }
    .home-grid-subtitle {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      font-size: 1.05rem;
      color: #a09078;
      max-width: 38rem;
      margin: 0 auto;
      line-height: 1.5;
    }

    .home-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }

    /* ============================================================
       FROM THE DESK — compressed
       ============================================================ */
    .desk-section {
      background: #0a0a0a;
      padding: 5rem 0;
    }
    .desk-container {
