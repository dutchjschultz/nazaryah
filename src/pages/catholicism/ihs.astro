    position: sticky;
    top: 0;
    z-index: 10;
  }

  .sw-mode-divider { color: #4a1020; font-size: 0.65rem; letter-spacing: 4px; }

  .sw-mode-btn {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
