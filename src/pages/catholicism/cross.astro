      <h1 class="sw-title">The Cross</h1>
      <p class="sw-sub">
        The mark of Tammuz — how a Babylonian sun-god’s symbol became the emblem of Christianity
      </p>
    </section>

    <!-- ── MODE BAR ── -->
    <div class="sw-mode-bar">
      <button id="btn-quick" class="sw-mode-btn sw-mode-active" data-tip="The 90-second version.">&#9654; Quick Read</button>
