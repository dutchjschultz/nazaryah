     Override the original cgl-term to render as a flex row, and add
     xm-cgl-label. */
  .xm-cgl-details > .xm-cgl-term {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem 0.45rem;
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #d0b890;
    border-bottom: none;
  }

  .xm-cgl-label {
    flex: 1;
  }

  .xm-cgl-details > .xm-cgl-def {
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    font-size: 0.95rem;
    line-height: 1.78;
    color: #c4ad84;
    text-transform: none;
    letter-spacing: normal;
    font-weight: normal;
    padding: 0 1.75rem 1rem 3.75rem;
    margin: 0;
    border-bottom: 1px solid #1e1208;
  }

  .xm-cgl-details > .xm-cgl-term-last + .xm-cgl-def {
    border-bottom: none;
  }

  /* Glossary summary in the new content places a Glossary label + a generic
     xm-chevron inline (no xm-cgl-summary-text wrapper, no xm-cgl-chevron). */
  .xm-cgl-summary {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #c4a46b;
    font-weight: 700;
  }

  .xm-cgl-summary > .xm-chevron {
    font-size: 1.2rem;
    color: #6a2a9a;
    min-width: 1.25rem;
    text-align: center;
    font-family: 'Cinzel', serif;
  }

  @media (max-width: 600px) {
    .xm-cgl-details > .xm-cgl-def { padding-left: 1.75rem; }
  }
</style>

<script>
  // Accordion item chevron toggle
  document.querySelectorAll('.xm-detail').forEach((detail) => {
    detail.addEventListener('toggle', () => {
      const chevron = detail.querySelector('.xm-chevron') as HTMLElement;
      if (chevron) {
        chevron.textContent = (detail as HTMLDetailsElement).open ? '−' : '+';
      }
    });
  });

  // Glossary chevron toggle — supports both the original .xm-cgl-chevron and the
  // new content's inline .xm-chevron inside .xm-cgl-summary.
  const cglDetails = document.querySelector('.xm-cgl-details') as HTMLDetailsElement | null;
  if (cglDetails) {
    cglDetails.addEventListener('toggle', () => {
      const chevron = cglDetails.querySelector('.xm-cgl-summary .xm-chevron, .xm-cgl-chevron') as HTMLElement;
      if (chevron) {
        chevron.textContent = cglDetails.open ? '−' : '+';
      }
    });
  }
</script>
