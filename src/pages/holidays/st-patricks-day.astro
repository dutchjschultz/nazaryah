<BaseLayout
  title="Unmasking St. Patrick's Day — 15 Pagan Origins — Nazaryah"
  description="Patrick is celebrated for doing exactly what Yahuah forbids. This study traces 15 St. Patrick's Day traditions back to their pagan and syncretic roots and holds each one against Scripture."
>
  <div class="xm-wrap">

    <!-- ── HERO ── -->
    <section class="xm-hero">
      <p class="xm-series">&#8213; Unmasking the Holidays · March &#8213;</p>
      <h1 class="xm-title">Unmasking St. Patrick's Day</h1>
      <p class="xm-sub">The Pagan Origins Behind 15 Traditions the World Celebrates</p>
    </section>

    <!-- ── SERIES NAV ── -->
    <nav class="xm-series-nav">
      <a href="/holidays">Overview</a>
