<script>
  // Accordion item chevron toggle
  document.querySelectorAll('.xm-detail').forEach((detail) => {
    detail.addEventListener('toggle', () => {
      const chevron = detail.querySelector('.xm-chevron') as HTMLElement;
      if (chevron) {
        chevron.textContent = (detail as HTMLDetailsElement).open ? '−' : '+';
      }
    });
  });

  // Glossary chevron toggle (the may-day glossary reuses .xm-chevron inside .xm-cgl-summary)
  const cglDetails = document.querySelector('.xm-cgl-details') as HTMLDetailsElement | null;
  if (cglDetails) {
    cglDetails.addEventListener('toggle', () => {
      const chevron = cglDetails.querySelector('.xm-cgl-summary .xm-chevron') as HTMLElement;
      if (chevron) {
        chevron.textContent = cglDetails.open ? '−' : '+';
      }
    });
  }

  // Open #anchor target on load
  (function() {
    function openTarget() {
      const hash = window.location.hash;
      if (!hash || hash.length < 2) return;
      let el: Element | null;
      try { el = document.querySelector(hash); } catch (e) { return; }
      if (el && el.tagName === 'DETAILS') {
        (el as HTMLDetailsElement).open = true;
        setTimeout(() => el!.scrollIntoView({ behavior: 'smooth', block: 'start' }), 120);
      }
    }
    window.addEventListener('DOMContentLoaded', openTarget);
    window.addEventListener('hashchange', openTarget);
  })();
</script>
