---
// src/pages/hollywood/index.astro  ·  0714 V2
// The Hollywood section page. TWO category sections. Nothing above them,
// nothing between them. The old "Choose a Studio" block and the invented
// Craft/Stars/Score card row are both replaced by this.
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories } from "../../data/hollywood.js";
import CategorySection from "../../components/CategorySection.astro";
---

<BaseLayout
  title="Hollywood — The Stories Being Told to a Generation | Nazaryah"
  description="Hollywood in two categories: Studios & Genre — who made it and what kind it is — and The Craft — how it works on you. Every study slows the reel down one frame at a time."
>
<div class="hw-shell">
<main class="wrap">
  <p class="eyebrow reveal">The Modern Pulpit</p>
  <h1 class="reveal">Hollywood</h1>
  <p class="subtitle reveal">The stories being told to a generation</p>

  <!-- The word, explained once, up front. -->
  <p class="reels-note reveal">
    Every study on this page is a <strong>reel</strong> — a strip of still images
    wound tight and spun so fast the eye can no longer tell one frame from the next.
    That blur <em>is</em> the trick. Each reel slows it down, stops it on a single
    frame, and holds it still long enough to ask the one thing the machine is built
    to keep you from asking: <em>what is really on it?</em>
  </p>

  <hr class="rule" />

  {/* ── Category rail (desktop) + accordion (mobile). Container swap only:
       CategorySection and its cards/links/props are untouched — this markup
       just rearranges how the two sections are reached. ── */}
  <div class="cat-rail">
    {categories.map((c, i) => (
      <input type="radio" name="hw-cat" id={`hw-cat-${i}`} class="cat-rail-radio" checked={i === 0} />
    ))}
    <div class="cat-rail-list">
      {categories.map((c, i) => (
        <label for={`hw-cat-${i}`} class="cat-rail-item">
          <span class="cat-rail-name">{c.title}</span>
          <span class="cat-rail-tag">{c.tagline}</span>
        </label>
      ))}
    </div>
    <div class="cat-rail-panels">
      {categories.map((c) => (
        <div class="cat-rail-panel"><CategorySection category={c} /></div>
      ))}
    </div>
  </div>

  <div class="cat-accordion">
    {categories.map((c, i) => (
      <details class="cat-acc-item" open={i === 0}>
        <summary class="cat-acc-summary">{c.title}</summary>
        <div class="cat-acc-body"><CategorySection category={c} /></div>
      </details>
    ))}
  </div>

  <footer class="hw-footer reveal">nazaryah.com</footer>
</main>
</div>
</BaseLayout>

<style>
  /* Dark-gold house theme, scoped to this page's shell so it never leaks to the
     global header/footer. CategorySection inherits these tokens. */
  .hw-shell {
    --bg: #160a0c;
    --bg-raise: #201114;
    --ink: #ece1cd;
    --ink-soft: #b6a58f;
    --parchment: #ecd8a6;
    --gold: #c99a44;
    --gold-soft: #a98a53;
    --rule: rgba(201, 154, 68, 0.22);
    --display: "Cormorant Garamond", Georgia, serif;
    --body: "EB Garamond", Georgia, serif;

    background:
      radial-gradient(120% 80% at 50% -10%, #241318 0%, rgba(0,0,0,0) 55%),
      radial-gradient(140% 120% at 50% 0%, #1d1012 0%, var(--bg) 60%);
    background-color: var(--bg);
    min-height: 80vh;
  }

  .wrap { margin: 0 auto; padding: clamp(2.6rem,7vw,5.5rem) 0 4rem; color: var(--ink); font-family: var(--body); }

  .eyebrow { text-align: center; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.32em; color: var(--gold); font-size: 0.92rem; margin: 0 0 1.2rem; }
  .eyebrow::before, .eyebrow::after { content: "—"; color: var(--gold-soft); margin: 0 0.7em; }

  h1 { font-family: var(--display); font-variant-caps: small-caps; font-weight: 600; color: var(--parchment); text-align: center; line-height: 1.05; letter-spacing: 0.015em; font-size: clamp(2.8rem, 1.5rem + 5vw, 5rem); margin: 0 0 1rem; }
  .subtitle { text-align: center; font-style: italic; color: var(--gold-soft); font-size: clamp(1.1rem,1rem+0.5vw,1.35rem); margin: 0 auto 2.6rem; }

  .reels-note { max-width: 42rem; margin: 0 auto; padding: 0 1.4rem; font-size: 1.04em; line-height: 1.85; color: var(--ink); }
  .reels-note strong { color: var(--parchment); font-weight: 600; }
  .reels-note em { color: var(--parchment); font-style: italic; }

  hr.rule { border: 0; height: 1px; background: var(--rule); margin: 3.4rem auto; max-width: 22rem; }

  .hw-footer { text-align: center; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--rule); font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.22em; color: var(--gold); font-size: 0.95rem; }

  .reveal { opacity: 0; transform: translateY(14px); animation: rise 0.7s ease forwards; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; animation: none; } }
  @keyframes rise { to { opacity: 1; transform: none; } }

  /* ============================================================
     CATEGORY RAIL — CSS-only tabs (hidden radios + :checked ~).
     No JS, no hydration. Left rail selects; right panel shows that
     category's CategorySection. Cards/links/hover behaviour untouched.
     ============================================================ */
  .cat-rail {
    position: relative;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2.4rem;
    align-items: start;
    max-width: 62rem;
    margin: 0 auto;
  }

  /* Radios: visually hidden but still focusable (clipped sr-only pattern —
     NOT display:none / visibility:hidden, which would drop keyboard focus). */
  .cat-rail-radio {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px; border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .cat-rail-list {
    position: sticky; top: 1.5rem;
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .cat-rail-item {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 0.7rem 0.9rem;
    cursor: pointer;
    border-left: 2px solid transparent;
    border-radius: 0 3px 3px 0;
    color: var(--ink-soft);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .cat-rail-name { font-family: var(--display); font-variant-caps: small-caps; font-weight: 600; font-size: 1.15rem; letter-spacing: 0.03em; line-height: 1.1; }
  .cat-rail-tag  { font-size: 0.78rem; font-style: italic; color: var(--gold-soft); line-height: 1.3; }

  /* Hover = visual affordance ONLY. Selection is the radio, never hover. */
  .cat-rail-item:hover { color: var(--parchment); background: rgba(201,154,68,0.06); }

  /* Panels: overflow visible so nothing inside is ever clipped; min-height
     (not height) softens the jump between the 4-card and 7-card categories. */
  .cat-rail-panels { position: relative; overflow: visible; min-height: 22rem; }
  .cat-rail-panel  { display: none; overflow: visible; }

  /* Checked → reveal matching panel (rules cover up to 8 categories). */
  .cat-rail-radio:nth-of-type(1):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(1),
  .cat-rail-radio:nth-of-type(2):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(2),
  .cat-rail-radio:nth-of-type(3):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(3),
  .cat-rail-radio:nth-of-type(4):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(4),
  .cat-rail-radio:nth-of-type(5):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(5),
  .cat-rail-radio:nth-of-type(6):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(6),
  .cat-rail-radio:nth-of-type(7):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(7),
  .cat-rail-radio:nth-of-type(8):checked ~ .cat-rail-panels > .cat-rail-panel:nth-child(8) { display: block; }

  /* Checked → light the matching rail item. */
  .cat-rail-radio:nth-of-type(1):checked ~ .cat-rail-list > .cat-rail-item:nth-child(1),
  .cat-rail-radio:nth-of-type(2):checked ~ .cat-rail-list > .cat-rail-item:nth-child(2),
  .cat-rail-radio:nth-of-type(3):checked ~ .cat-rail-list > .cat-rail-item:nth-child(3),
  .cat-rail-radio:nth-of-type(4):checked ~ .cat-rail-list > .cat-rail-item:nth-child(4),
  .cat-rail-radio:nth-of-type(5):checked ~ .cat-rail-list > .cat-rail-item:nth-child(5),
  .cat-rail-radio:nth-of-type(6):checked ~ .cat-rail-list > .cat-rail-item:nth-child(6),
  .cat-rail-radio:nth-of-type(7):checked ~ .cat-rail-list > .cat-rail-item:nth-child(7),
  .cat-rail-radio:nth-of-type(8):checked ~ .cat-rail-list > .cat-rail-item:nth-child(8) {
    color: var(--parchment);
    border-left-color: var(--gold);
    background: rgba(201,154,68,0.10);
  }

  /* Visible keyboard focus: outline the active rail item when its radio is focused. */
  .cat-rail-radio:nth-of-type(1):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(1),
  .cat-rail-radio:nth-of-type(2):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(2),
  .cat-rail-radio:nth-of-type(3):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(3),
  .cat-rail-radio:nth-of-type(4):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(4),
  .cat-rail-radio:nth-of-type(5):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(5),
  .cat-rail-radio:nth-of-type(6):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(6),
  .cat-rail-radio:nth-of-type(7):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(7),
  .cat-rail-radio:nth-of-type(8):focus-visible ~ .cat-rail-list > .cat-rail-item:nth-child(8) {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }

  /* ── Mobile (<768px): rail collapses to native <details> accordions. ── */
  .cat-accordion { display: none; max-width: 62rem; margin: 0 auto; padding: 0 1.4rem; }
  .cat-acc-item { border-top: 1px solid var(--rule); }
  .cat-acc-item:last-of-type { border-bottom: 1px solid var(--rule); }
  .cat-acc-summary {
    cursor: pointer; list-style: none;
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 1.1rem 0.2rem;
    font-family: var(--display); font-variant-caps: small-caps; font-weight: 600;
    font-size: 1.4rem; letter-spacing: 0.03em; color: var(--parchment);
  }
  .cat-acc-summary::-webkit-details-marker { display: none; }
  .cat-acc-summary::after { content: "+"; color: var(--gold); font-weight: 400; }
  .cat-acc-item[open] .cat-acc-summary::after { content: "\2013"; }
  .cat-acc-summary:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .cat-acc-body { overflow: visible; padding-bottom: 0.5rem; }

  @media (max-width: 767px) {
    .cat-rail { display: none; }
    .cat-accordion { display: block; }
  }
</style>
