---
// src/pages/hollywood/the-craft/[reel].astro  ·  0714 V1
// Auto-generates a themed "In production" page for every reel whose
// status is not "live". When you flip a reel to "live" in craft.js
// and add its real page, this stub stops generating for that slug —
// no collision, nothing to delete.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { reels } from '../../../data/craft.js';

export function getStaticPaths() {
  return reels
    .filter((r) => r.status !== "live")
    .map((r) => ({ params: { reel: r.slug }, props: { reel: r } }));
}

const { reel } = Astro.props;
---

<BaseLayout
  title={`${reel.title} — The Craft, Hollywood | Nazaryah`}
  description={reel.tagline}
>
<div class="craft-shell">
<main class="wrap">
  <p class="eyebrow reveal">The Craft — Hollywood</p>
  <h1 class="reveal">{reel.title}</h1>
  <p class="subtitle reveal">{reel.tagline}</p>

  <hr class="rule" />

  <div class="soon reveal">
    <span class="soon-mark">In Production</span>
    <p class="soon-body">
      {reel.soon ?? "This reel is being wound. The study is written the way every study on this site is written — slowly, from the Word, one frame at a time — and it will appear here when it is ready to be tested rather than merely believed."}
    </p>
    <p class="soon-verses">Anchored in {reel.verses}</p>
  </div>

  <a class="back reveal" href="/hollywood/the-craft">← Back to The Craft</a>

  <footer class="craft-footer reveal">nazaryah.com</footer>
</main>
</div>
</BaseLayout>

<style>
  /* Dark-gold theme, scoped to this page's shell so it never leaks to the
     global header/footer. Mirrors the house palette (bg #160a0c, gold #c99a44). */
  .craft-shell {
    --bg: #160a0c;
    --bg-raise: #201114;
    --ink: #ece1cd;
    --ink-soft: #b6a58f;
    --parchment: #ecd8a6;
    --gold: #c99a44;
    --gold-soft: #a98a53;
    --rule: rgba(201, 154, 68, 0.22);
    --display: "Cormorant Garamond", Georgia, serif;
    --body: "EB Garamond", Georgia, serif;
    --maxw: 46rem;

    background:
      radial-gradient(120% 80% at 50% -10%, #241318 0%, rgba(0,0,0,0) 55%),
      radial-gradient(140% 120% at 50% 0%, #1d1012 0%, var(--bg) 60%);
    background-color: var(--bg);
    min-height: 80vh;
  }

  .wrap { max-width: var(--maxw); margin: 0 auto; padding: clamp(2.6rem,7vw,5.5rem) 1.4rem 4rem; color: var(--ink); font-family: var(--body); text-align: center; }

  .eyebrow { font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.32em; color: var(--gold); font-size: 0.92rem; margin: 0 0 1.4rem; }
  .eyebrow::before, .eyebrow::after { content: "—"; color: var(--gold-soft); margin: 0 0.7em; }
  h1 { font-family: var(--display); font-variant-caps: small-caps; font-weight: 600; color: var(--parchment); line-height: 1.08; letter-spacing: 0.015em; font-size: clamp(2.2rem,1.3rem+3.6vw,3.7rem); margin: 0 0 1.1rem; }
  .subtitle { font-style: italic; color: var(--ink-soft); font-size: clamp(1.1rem,1rem+0.5vw,1.35rem); max-width: 34rem; margin: 0 auto; line-height: 1.5; }

  hr.rule { border: 0; height: 1px; background: var(--rule); margin: 3.4rem auto; max-width: 20rem; }

  .soon { max-width: 34rem; margin: 0 auto; }
  .soon-mark { display: inline-block; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.22em; color: var(--gold); border: 1px solid var(--gold-soft); border-radius: 2px; padding: 0.45rem 1.1rem; font-size: 0.95rem; margin-bottom: 1.6rem; }
  .soon-body { color: var(--ink); font-size: 1.06em; line-height: 1.8; margin: 0 0 1.2rem; }
  .soon-verses { color: var(--gold-soft); font-style: italic; font-size: 0.9rem; letter-spacing: 0.05em; margin: 0; }

  .back { display: inline-block; margin-top: 2.8rem; color: var(--gold); text-decoration: none; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.1em; }
  .back:hover { color: var(--parchment); }
  .back:focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; }

  .craft-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--rule); font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.22em; color: var(--gold); font-size: 0.95rem; }

  .reveal { opacity: 0; transform: translateY(14px); animation: rise 0.7s ease forwards; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; animation: none; } }
  @keyframes rise { to { opacity: 1; transform: none; } }
</style>
