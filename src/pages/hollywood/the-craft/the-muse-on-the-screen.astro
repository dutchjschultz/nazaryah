    --maxw: 46rem;

    background:
      radial-gradient(120% 80% at 50% -10%, #241318 0%, rgba(0,0,0,0) 55%),
      radial-gradient(140% 120% at 50% 0%, #1d1012 0%, var(--bg) 60%);
    background-color: var(--bg);
    min-height: 80vh;
  }

  .wrap {
    max-width: var(--maxw); margin: 0 auto;
    padding: clamp(2.6rem, 7vw, 5.5rem) 1.4rem 4rem;
    color: var(--ink); font-family: var(--body);
    font-size: clamp(1.06rem, 0.9rem + 0.6vw, 1.22rem);
    line-height: 1.85; letter-spacing: 0.006em;
  }

  .eyebrow { text-align: center; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.32em; color: var(--gold); font-size: 0.92rem; margin: 0 0 1.4rem; }
  .eyebrow::before, .eyebrow::after { content: "—"; color: var(--gold-soft); margin: 0 0.7em; }

  h1 { font-family: var(--display); font-variant-caps: small-caps; font-weight: 600; color: var(--parchment); text-align: center; line-height: 1.08; letter-spacing: 0.015em; font-size: clamp(2.2rem, 1.3rem + 3.6vw, 3.7rem); margin: 0 0 1.1rem; }
  .subtitle { text-align: center; font-style: italic; color: var(--ink-soft); font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem); max-width: 34rem; margin: 0 auto 2.6rem; line-height: 1.5; }

  .lede { font-size: 1.06em; }
  .lede::first-letter { font-family: var(--display); float: left; color: var(--gold); font-size: 3.4em; line-height: 0.72; padding: 0.05em 0.12em 0 0; font-weight: 600; }

  p { margin: 0 0 1.35rem; }
  strong { color: var(--parchment); font-weight: 600; }
  em { color: var(--ink); }

  h2 { font-family: var(--display); font-variant-caps: small-caps; font-weight: 600; color: var(--gold); letter-spacing: 0.03em; font-size: clamp(1.5rem, 1.2rem + 1vw, 1.95rem); line-height: 1.15; margin: 3rem 0 1rem; }
  h2::before { content: ""; display: block; width: 2.4rem; height: 1px; background: var(--gold-soft); opacity: 0.7; margin-bottom: 1.1rem; }

  blockquote { margin: 1.7rem 0; padding: 1.05rem 1.3rem 1.05rem 1.5rem; background: var(--bg-raise); border-left: 3px solid var(--gold); border-radius: 2px; }
  blockquote p { margin: 0; font-style: italic; color: #f2e9d6; line-height: 1.7; }
  blockquote cite { display: block; margin-top: 0.55rem; font-style: normal; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.12em; color: var(--gold); font-size: 0.95rem; }

  .callout { margin: 2.6rem 0 0.5rem; padding: 1.1rem 1.3rem 1.1rem 1.2rem; background: linear-gradient(90deg, rgba(201,154,68,0.10), rgba(201,154,68,0.02)); border-left: 3px solid var(--gold); border-radius: 2px; display: flex; gap: 0.9rem; align-items: flex-start; }
  .callout .arrow { color: var(--gold); font-size: 1.15rem; line-height: 1.6; flex: 0 0 auto; }
  .callout p { margin: 0; }
  .callout b { color: var(--parchment); font-weight: 600; }

  .back-wrap { margin: 2.6rem 0 0; text-align: center; }
  .back { color: var(--gold); text-decoration: none; font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.1em; }
  .back:hover { color: var(--parchment); }

  a { color: var(--gold); }
  a:focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; border-radius: 2px; }

  hr.rule { border: 0; height: 1px; background: var(--rule); margin: 3.4rem 0; }

  .craft-footer { text-align: center; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--rule); font-family: var(--display); font-variant-caps: small-caps; letter-spacing: 0.22em; color: var(--gold); font-size: 0.95rem; }

