---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all published posts
const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

// Sort by date, most recent first
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// All defined categories (shown even if no posts exist yet)
const allCategories = [
  'Book-by-Book Commentary',
  'Books',
  'Exegetical Studies',
  'Fresh Perspectives',
  'Historical Context',
  'Parables',
  'Theological Themes',
  'Trinity Busters',
  'Word Studies',
];
---

<BaseLayout
  title="Biblical Studies & Theological Insights - Nazaryah Blog"
  description="Explore in-depth biblical studies covering exegesis, theology, historical context, and fresh perspectives on Scripture."
>
  <div class="py-16 md:py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4" style="font-family: var(--font-display); color: var(--deep-earth);">
            Biblical Studies
          </h1>
          <p class="text-lg max-w-3xl mx-auto" style="color: var(--ink-faded);">
            In-depth explorations of Scripture through original languages, historical context, and scholarly analysis
          </p>
        </div>

        <!-- Category Filter -->
        <div class="mb-12">
          <div class="flex flex-wrap gap-3 justify-center" style="font-family: var(--font-display);">
            <button
              class="category-filter px-4 py-2 rounded border border-[var(--sand-dark)] text-xs font-semibold tracking-widest uppercase transition-all hover:bg-[var(--stone)] hover:text-[var(--linen)] hover:border-[var(--stone)] active"
              data-category="all"
            >
              All Posts
            </button>
            {allCategories.map((category) => (
              <button
                class="category-filter px-4 py-2 rounded border border-[var(--sand-dark)] text-xs font-semibold tracking-widest uppercase transition-all hover:bg-[var(--stone)] hover:text-[var(--linen)] hover:border-[var(--stone)]"
                data-category={category}
              >
                {category}
              </button>
            ))}
          </div>
        </div>

        <!-- Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
          {sortedPosts.map((post) => (
            <article
              class="post-item card overflow-hidden"
              data-category={post.data.category}
            >
              <div class="p-6">
                <div class="tag mb-2" style="color: var(--bronze);">
                  {post.data.category}
                </div>
                <h2 class="text-xl font-semibold mb-3" style="font-family: var(--font-display); color: var(--deep-earth);">
                  <a
                    href={`/blog/${post.slug}`}
                    class="hover:text-[var(--bronze)] transition-colors"
                    style="color: var(--deep-earth);"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-sm mb-4 line-clamp-3" style="color: var(--ink-faded);">
                  {post.data.description}
                </p>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-xs px-2 py-1 rounded" style="background: var(--parchment-dark); color: var(--ink-faded); font-family: var(--font-body);">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <div class="flex items-center justify-between text-xs pt-4 border-t border-[var(--sand-dark)]" style="color: var(--ink-faded);">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <a
                    href={`/blog/${post.slug}`}
                    class="hover:underline"
                    style="color: var(--bronze);"
                  >
                    Read More &rarr;
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        {sortedPosts.length === 0 && (
          <div class="text-center py-20">
            <p class="text-lg" style="color: var(--ink-faded);">
              No posts published yet. Check back soon!
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.category-filter');
    const postCards = document.querySelectorAll('.post-item');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        // Update active state
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Filter posts
        postCards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          if (category === 'all' || cardCategory === category) {
            (card as HTMLElement).style.display = 'block';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
