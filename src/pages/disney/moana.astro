    min-height: 80vh;
  }

  .sw-mode-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: rgba(6, 8, 16, 0.97);
    border-bottom: 1px solid #141c38;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .sw-mode-divider {
    color: #1a2448;
