    text-align: center;
    padding: 4rem 1.5rem 3.5rem;
    border-bottom: 1px solid #1a2448;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(30, 50, 160, 0.2), transparent 70%),
      linear-gradient(180deg, #040610 0%, #0c1020 100%);
  }

  .sw-back {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 2px;
    color: #3a4870;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .sw-back:hover { color: #c4a46b; }

  .sw-label {
    font-family: 'Cinzel', serif;
