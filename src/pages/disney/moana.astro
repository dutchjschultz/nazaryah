  }

  .sw-summary-block {
    max-width: 620px;
    margin: 0 auto 2.5rem;
    background: rgba(10, 20, 80, 0.15);
    border: 1px solid #1a2448;
    border-top: 2px solid #1E3A8B;
    border-radius: 4px;
    padding: 1.5rem 1.75rem;
    text-align: left;
  }

  .sw-summary-label {
    font-family: 'Cinzel', serif;
