    top: 0.9rem;
  }

  .sw-footer-quote {
    text-align: center;
    padding: 3.5rem 1.5rem;
    background: linear-gradient(180deg, #080c18 0%, #040608 100%);
  }

  .sw-summary-block {
    max-width: 620px;
    margin: 0 auto 2.5rem;
    background: rgba(10, 20, 80, 0.15);
    border: 1px solid #1a2448;
    border-top: 2px solid #1E3A8B;
    border-radius: 4px;
    padding: 1.5rem 1.75rem;
    text-align: left;
  }

  .sw-summary-label {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 2px;
    color: #3A5AAA;
    text-transform: uppercase;
    margin-bottom: 0.75rem !important;
  }

  .sw-summary-text {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #c4ad84;
    font-style: italic;
    margin: 0 !important;
  }

  .sw-quote-text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-style: italic;
    color: #c4a46b;
    max-width: 600px;
    margin: 0 auto 0.5rem;
    line-height: 1.65;
  }

  .sw-quote-ref {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: #2a3858;
    text-transform: uppercase;
  }
</style>
