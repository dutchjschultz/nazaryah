    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: rgba(6, 8, 16, 0.97);
    border-bottom: 1px solid #141c38;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .sw-mode-divider {
    color: #1a2448;
    font-size: 0.65rem;
    letter-spacing: 4px;
  }

  .sw-mode-btn {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.45rem 1.1rem;
    border-radius: 20px;
    border: 1px solid #2a3a60;
    background: transparent;
    color: #7a90c0;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .sw-mode-btn:not(.sw-mode-active):hover {
    color: #c4a46b;
    border-color: rgba(60, 100, 186, 0.4);
    background: rgba(20, 40, 100, 0.1);
  }

  .sw-mode-active {
    background: rgba(30, 58, 139, 0.25);
    border-color: rgba(60, 100, 186, 0.45);
    color: #c4a46b;
  }

  .sw-mode-btn[data-tip]::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(4, 6, 14, 0.97);
    color: #c4ad84;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    font-size: 0.72rem;
    letter-spacing: 0.5px;
    text-transform: none;
    font-weight: normal;
    white-space: nowrap;
    padding: 0.35rem 0.8rem;
    border-radius: 4px;
    border: 1px solid #1a2448;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 20;
  }

  .sw-mode-btn:hover[data-tip]::after {
    opacity: 1;
  }

  .sw-hero {
    text-align: center;
    padding: 4rem 1.5rem 3.5rem;
    border-bottom: 1px solid #1a2448;
