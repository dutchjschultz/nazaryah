    description: 'A short sentence about why this person or site is worth your time. Replace this with your own words.',
    href: '#',
  },
];
---

<BaseLayout
  title="Contact & Connections - Nazaryah"
  description="Get in touch with Nazaryah and discover teachers and resources worth your time."
>
  <div class="py-16 md:py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">

        <!-- Header -->
        <h1 class="text-center mb-4" style="font-family: var(--font-display); color: var(--deep-earth);">
          Contact & Connections
        </h1>
        <p class="text-center text-lg mb-12" style="color: var(--ink-faded);">
          Reach out with questions or feedback — and explore the teachers and resources that have shaped the scholarship behind this site.
        </p>

        <!-- Contact Form -->
        <div class="card p-8 mb-10">
          <form name="contact" method="POST" action="/thanks" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />
            <div>
              <label for="name" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="input-field w-full"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="input-field w-full"
                placeholder="your.email@example.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Subject *
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="input-field w-full"
                placeholder="What's this about?"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="input-field w-full"
                placeholder="Share your thoughts, questions, or suggestions..."
              ></textarea>
            </div>

            <button type="submit" class="btn btn-stone w-full px-8 py-3">
              Send Message
            </button>
          </form>
        </div>

        <!-- Email direct contact -->
        <div class="text-center mb-20" style="color: var(--ink-faded); font-family: var(--font-body);">
          <p class="text-sm mb-1">Or email directly:</p>
          <a
            href="mailto:contact@nazaryah.com"
            class="hover:underline text-base"
            style="color: var(--bronze);"
          >
            contact@nazaryah.com
          </a>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-4 mb-12">
          <div class="flex-1 border-t border-[var(--sand-dark)]"></div>
          <span style="color: var(--bronze); font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 3px; text-transform: uppercase;">
            Voices Worth Hearing
          </span>
          <div class="flex-1 border-t border-[var(--sand-dark)]"></div>
        </div>

        <!-- Intro -->
        <p class="text-center mb-10" style="color: var(--ink-faded); font-family: var(--font-body); font-size: 1rem; line-height: 1.7;">
          These teachers and resources have shaped the scholarship behind this site. Not every view is shared — but every voice listed here takes the text seriously.
        </p>

        <!-- Connections Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {connections.map((connection) => (
            <div class="tile-card p-6 flex flex-col gap-3">
              <h3 class="text-lg font-semibold" style="font-family: var(--font-display); color: var(--deep-earth);">
                {connection.name}
              </h3>
              <p class="text-sm flex-1" style="color: var(--ink-faded); font-family: var(--font-body); line-height: 1.65;">
                {connection.description}
              </p>
              <a
                href={connection.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs font-semibold tracking-widest uppercase hover:underline mt-1"
                style="color: var(--bronze); font-family: var(--font-display);"
              >
                Visit &rarr;
              </a>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
