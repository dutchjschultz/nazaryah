---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Nazaryah - Get in Touch"
  description="Have questions about biblical studies? Want to suggest a topic? Get in touch with the Nazaryah team."
>
  <div class="py-16 md:py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-center mb-4" style="font-family: var(--font-display); color: var(--deep-earth);">
          Get in Touch
        </h1>
        <p class="text-center text-lg mb-12" style="color: var(--ink-faded);">
          We'd love to hear from you. Whether you have questions, feedback, or topic suggestions, don't hesitate to reach out.
        </p>

        <!-- Contact Form -->
        <div class="card p-8 mb-12">
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="input-field w-full"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="input-field w-full"
                placeholder="your.email@example.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Subject *
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="input-field w-full"
                placeholder="What's this about?"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium mb-2" style="color: var(--deep-earth); font-family: var(--font-display); letter-spacing: 1px;">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="input-field w-full"
                placeholder="Share your thoughts, questions, or suggestions..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn btn-stone w-full px-8 py-3"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Additional Contact Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="tile-card p-6">
            <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display); color: var(--bronze);">
              Email Us
            </h3>
            <p class="text-sm mb-4" style="color: var(--ink-faded);">
              For general inquiries, questions, or feedback:
            </p>
            <a
              href="mailto:contact@nazaryah.com"
              class="hover:underline"
              style="color: var(--copper-patina);"
            >
              contact@nazaryah.com
            </a>
          </div>

          <div class="tile-card p-6">
            <h3 class="text-xl font-semibold mb-3" style="font-family: var(--font-display); color: var(--bronze);">
              Topic Suggestions
            </h3>
            <p class="text-sm mb-4" style="color: var(--ink-faded);">
              Have a biblical topic you'd like us to explore? Let us know!
            </p>
            <a
              href="mailto:topics@nazaryah.com"
              class="hover:underline"
              style="color: var(--copper-patina);"
            >
              topics@nazaryah.com
            </a>
          </div>
        </div>

        <!-- FAQ Section -->
        <div class="mt-16">
          <h2 class="text-2xl font-bold mb-8 text-center" style="font-family: var(--font-display); color: var(--deep-earth);">
            Frequently Asked Questions
          </h2>
          <div class="space-y-6">
            <div class="card p-6">
              <h3 class="font-semibold mb-2" style="font-family: var(--font-display); color: var(--deep-earth);">
                Can I submit a guest article?
              </h3>
              <p class="text-sm" style="color: var(--ink-faded);">
                We're always interested in quality biblical scholarship. Email us your proposal, including your
                qualifications and a brief outline of your article.
              </p>
            </div>

            <div class="card p-6">
              <h3 class="font-semibold mb-2" style="font-family: var(--font-display); color: var(--deep-earth);">
                How often do you publish new content?
              </h3>
              <p class="text-sm" style="color: var(--ink-faded);">
                We aim to publish new studies weekly. Subscribe to our newsletter to receive notifications
                when new content is available.
              </p>
            </div>

            <div class="card p-6">
              <h3 class="font-semibold mb-2" style="font-family: var(--font-display); color: var(--deep-earth);">
                Do you offer teaching resources?
              </h3>
              <p class="text-sm" style="color: var(--ink-faded);">
                Currently, all our content is freely available for personal and educational use. We're exploring
                additional teaching resources and may offer them in the future.
              </p>
            </div>

            <div class="card p-6">
              <h3 class="font-semibold mb-2" style="font-family: var(--font-display); color: var(--deep-earth);">
                Can I cite your articles?
              </h3>
              <p class="text-sm" style="color: var(--ink-faded);">
                Yes! All our content is properly researched and can be cited. Each article includes publication
                date and author information. Please cite responsibly and check our most recent content for updates.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
