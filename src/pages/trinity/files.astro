---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const BOOK_ORDER: Record<string, number> = {
  'genesis': 1, 'exodus': 2, 'leviticus': 3, 'numbers': 4, 'deuteronomy': 5,
  'joshua': 6, 'judges': 7, 'ruth': 8, '1 samuel': 9, '2 samuel': 10,
  '1 kings': 11, '2 kings': 12, '1 chronicles': 13, '2 chronicles': 14,
  'ezra': 15, 'nehemiah': 16, 'esther': 17, 'job': 18,
  'psalm': 19, 'psalms': 19,
  'proverbs': 20, 'ecclesiastes': 21, 'song of solomon': 22, 'song of songs': 22,
  'isaiah': 23, 'jeremiah': 24, 'lamentations': 25, 'ezekiel': 26, 'daniel': 27,
  'hosea': 28, 'joel': 29, 'amos': 30, 'obadiah': 31, 'jonah': 32, 'micah': 33,
  'nahum': 34, 'habakkuk': 35, 'zephaniah': 36, 'haggai': 37, 'zechariah': 38, 'malachi': 39,
  'matthew': 40, 'mark': 41, 'luke': 42, 'john': 43, 'acts': 44,
  'romans': 45, '1 corinthians': 46, '2 corinthians': 47, 'galatians': 48,
  'ephesians': 49, 'philippians': 50, 'colossians': 51,
  '1 thessalonians': 52, '2 thessalonians': 53, '1 timothy': 54, '2 timothy': 55,
  'titus': 56, 'philemon': 57, 'hebrews': 58, 'james': 59,
  '1 peter': 60, '2 peter': 61, '1 john': 62, '2 john': 63, '3 john': 64,
  'jude': 65, 'revelation': 66,
};

function canonicalKey(verse: string | undefined): number {
  if (!verse) return 9_999_999_999;
  const m = verse.match(/^(.+?)\s+(\d+)(?::(\d+))?/);
  if (!m) return 9_999_999_999;
  const book = m[1].trim().toLowerCase();
  const chapter = parseInt(m[2], 10);
  const verseNum = m[3] ? parseInt(m[3], 10) : 0;
  const bookIdx = BOOK_ORDER[book] ?? 999;
  return bookIdx * 1_000_000 + chapter * 1_000 + verseNum;
}

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true && data.category === 'The Trinity Files';
});

const posts = allPosts.sort((a, b) => canonicalKey(a.data.verse) - canonicalKey(b.data.verse));
---

<BaseLayout
  title="Trinity Files — Nazaryah"
  description="Every verse trinitarians use to defend their doctrine — examined, dismantled, and returned to its original context. One verse at a time, one file at a time."
>
  <div class="tr-wrap">

    <!-- ── HERO ── -->
    <section class="tr-hero">
      <a href="/trinity" class="tr-back">&#8592; Back to Trinity</a>
      <p class="tr-label">&#8213; One Verse at a Time &#8213;</p>
      <h1 class="tr-title">Trinity Files</h1>
      <p class="tr-sub">
        Every verse trinitarians use to defend their doctrine — examined, dismantled, and returned to its original context. If the case is as strong as they claim, it should be able to survive scrutiny.
      </p>
    </section>

    <!-- ── INTRO ── -->
    <section class="tr-section">
      <div class="tr-prose">
        <p>
          Trinitarian theology rests on a small collection of proof texts — verses that, on the surface, appear to call Yahushua "God" or to demonstrate a plurality within the divine nature. These same verses are repeated across centuries of sermons, creeds, and apologetics. Almost none of them survive close examination.
        </p>
        <p>
          Each file here takes one of those verses and walks through it carefully: the original language, the manuscript evidence, the context the verse sits in, and what the text actually says once the doctrinal lens is removed. The rating at the top of each study reflects how strong the Trinitarian argument is on the surface — before the evidence is considered.
        </p>
      </div>
    </section>

    <!-- ── FOUNDATIONS DOORWAY ── -->
    <a class="fdoor" href="/foundations">
      <div class="fdoor-intro">
        <p class="fdoor-eyebrow">&#8213; The Foundations &#8213;</p>
        <p class="fdoor-desc">A handful of arguments turn up in study after study. Rather than re-explain them in every file, each is set down once here, in full — the deeper reading the verse studies point back to.</p>
      </div>
      <span class="fdoor-open">Open the Foundations&nbsp;<span class="arrow">&rarr;</span></span>
    </a>

    <!-- ── POST LIST ── -->
    <section class="tr-posts-section">
      <div class="tr-posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="tr-post-card">
            {post.data.verse && <span class="tr-post-verse">{post.data.verse}</span>}
            <h2 class="tr-post-title">{post.data.title}</h2>
            {post.data.subtitle && <p class="tr-post-subtitle">{post.data.subtitle}</p>}
            <span class="tr-post-read">Open File &nbsp;&#8594;</span>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="tr-empty">
          <p>Files are being prepared. Check back soon.</p>
        </div>
      )}
    </section>

    <!-- ── QUOTE ── -->
    <section class="tr-footer-quote">
      <p class="tr-quote-text">"Test everything; hold fast what is good."</p>
      <p class="tr-quote-ref">— 1 Thessalonians 5:21</p>
    </section>

  </div>
</BaseLayout>

<style>
  .tr-wrap {
    background: linear-gradient(180deg, #0e0904 0%, #1a1208 20%, #160f07 100%);
    color: #f0e0bf;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
  }

  .tr-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid #4a3218;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(150, 90, 40, 0.18), transparent 70%),
      linear-gradient(180deg, #0a0602 0%, #1a1208 100%);
    position: relative;
  }

  .tr-back {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: #8a6028;
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .tr-back:hover { color: #c4a46b; }

  .tr-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #8a6028;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .tr-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #f0e0bf;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .tr-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .tr-section {
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #2e1f0d;
  }

  /* ── Foundations doorway ── */
  .fdoor {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px 48px;
    align-items: center;
    max-width: 980px;
    margin: 10px auto 42px;
    padding: 26px 1.5rem;
    border-top: 1px solid #3a2510;
    border-bottom: 1px solid #3a2510;
    text-decoration: none;
    color: inherit;
  }

  .fdoor-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #8a6028;
    margin: 0 0 10px;
  }

  .fdoor-desc {
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    font-size: 1.1rem;
    font-style: italic;
    line-height: 1.55;
    color: #c4a46b;
    margin: 0;
    max-width: 52ch;
  }

  .fdoor-open {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #8a6028;
    white-space: nowrap;
    position: relative;
    padding-bottom: 6px;
    transition: color 0.3s ease;
  }
  .fdoor-open::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 100%;
    background: rgba(138, 96, 40, 0.45);
    transition: background 0.3s ease;
  }
  .fdoor-open .arrow {
    display: inline-block;
    transition: transform 0.35s ease;
  }
  .fdoor:hover .fdoor-open { color: #f0e0bf; }
  .fdoor:hover .fdoor-open::after { background: #8a6028; }
  .fdoor:hover .fdoor-open .arrow { transform: translateX(7px); }
  .fdoor:focus-visible { outline: 2px solid #8a6028; outline-offset: 4px; }

  @media (max-width: 680px) {
    .fdoor { grid-template-columns: 1fr; gap: 20px; padding: 24px 1.5rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fdoor-open, .fdoor-open::after, .fdoor-open .arrow { transition: none; }
  }

  .tr-prose {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
    color: #dcc99a;
  }
  .tr-prose p { margin-bottom: 1.2rem; }

  .tr-posts-section {
    padding: 3.5rem 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .tr-posts-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.1rem;
  }

  @media (max-width: 1320px) {
    .tr-posts-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 1080px) {
    .tr-posts-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 780px) {
    .tr-posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .tr-posts-grid { grid-template-columns: 1fr; }
  }

  .tr-post-card {
    display: flex;
    flex-direction: column;
    background: rgba(30, 18, 8, 0.7);
    border: 1px solid #3a2410;
    border-radius: 4px;
    padding: 1.15rem 1.1rem 1rem;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    text-align: center;
  }
  .tr-post-card:hover {
    border-color: #8a6028;
    background: rgba(50, 30, 10, 0.7);
  }

  .tr-post-verse {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2.5px;
    color: #c4a46b;
    text-transform: uppercase;
    margin: 0 0 0.7rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid #3a2510;
  }

  .tr-post-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(0.95rem, 1.4vw, 1.15rem);
    font-weight: 600;
    color: #f0e0bf;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .tr-post-subtitle {
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    font-style: italic;
    font-size: 0.92rem;
    color: #b09060;
    line-height: 1.45;
    margin: 0 0 0.9rem;
    flex-grow: 1;
  }

  .tr-post-read {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 2px;
    color: #8a6028;
    text-transform: uppercase;
    margin-top: auto;
  }

  .tr-empty {
    text-align: center;
    color: #7a5520;
    font-style: italic;
    padding: 3rem 0;
  }

  .tr-footer-quote {
    text-align: center;
    padding: 3rem 1.5rem;
    border-top: 1px solid #2e1f0d;
  }

  .tr-quote-text {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 600px;
    margin: 0 auto 0.5rem;
    line-height: 1.6;
  }

  .tr-quote-ref {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: #7a5520;
    text-transform: uppercase;
  }
</style>
