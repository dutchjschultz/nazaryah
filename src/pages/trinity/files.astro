---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true && data.category === 'The Trinity Files';
});

const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Trinity Files — Nazaryah"
  description="Every verse trinitarians use to defend their doctrine — examined, dismantled, and returned to its original context. One verse at a time, one file at a time."
>
  <div class="tr-wrap">

    <!-- ── HERO ── -->
    <section class="tr-hero">
      <a href="/trinity" class="tr-back">&#8592; Back to Trinity</a>
      <p class="tr-label">&#8213; One Verse at a Time &#8213;</p>
      <h1 class="tr-title">Trinity Files</h1>
      <p class="tr-sub">
        Every verse trinitarians use to defend their doctrine — examined, dismantled, and returned to its original context. If the case is as strong as they claim, it should be able to survive scrutiny.
      </p>
    </section>

    <!-- ── INTRO ── -->
    <section class="tr-section">
      <div class="tr-prose">
        <p>
          Trinitarian theology rests on a small collection of proof texts — verses that, on the surface, appear to call Yahushua "God" or to demonstrate a plurality within the divine nature. These same verses are repeated across centuries of sermons, creeds, and apologetics. Almost none of them survive close examination.
        </p>
        <p>
          Each file here takes one of those verses and walks through it carefully: the original language, the manuscript evidence, the context the verse sits in, and what the text actually says once the doctrinal lens is removed. The rating at the top of each study reflects how strong the Trinitarian argument is on the surface — before the evidence is considered.
        </p>
      </div>
    </section>

    <!-- ── POST LIST ── -->
    <section class="tr-posts-section">
      <div class="tr-posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="tr-post-card">
            <div class="tr-post-meta">
              <span class="tr-post-date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
            <h2 class="tr-post-title">{post.data.title}</h2>
            <p class="tr-post-desc">{post.data.description}</p>
            <span class="tr-post-read">Open File &nbsp;&#8594;</span>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="tr-empty">
          <p>Files are being prepared. Check back soon.</p>
        </div>
      )}
    </section>

    <!-- ── QUOTE ── -->
    <section class="tr-footer-quote">
      <p class="tr-quote-text">"Test everything; hold fast what is good."</p>
      <p class="tr-quote-ref">— 1 Thessalonians 5:21</p>
    </section>

  </div>
</BaseLayout>

<style>
  .tr-wrap {
    background: linear-gradient(180deg, #0e0904 0%, #1a1208 20%, #160f07 100%);
    color: #f0e0bf;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
  }

  .tr-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid #4a3218;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(150, 90, 40, 0.18), transparent 70%),
      linear-gradient(180deg, #0a0602 0%, #1a1208 100%);
    position: relative;
  }

  .tr-back {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: #8a6028;
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .tr-back:hover { color: #c4a46b; }

  .tr-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #8a6028;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .tr-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #f0e0bf;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .tr-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .tr-section {
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #2e1f0d;
  }

  .tr-prose {
    max-width: 720px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
    color: #dcc99a;
  }
  .tr-prose p { margin-bottom: 1.2rem; }

  .tr-posts-section {
    padding: 3.5rem 1.5rem;
    max-width: 860px;
    margin: 0 auto;
  }

  .tr-posts-grid {
    display: grid;
    gap: 1.5rem;
  }

  .tr-post-card {
    display: block;
    background: rgba(30, 18, 8, 0.7);
    border: 1px solid #3a2410;
    border-radius: 4px;
    padding: 1.8rem 2rem;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .tr-post-card:hover {
    border-color: #8a6028;
    background: rgba(50, 30, 10, 0.7);
  }

  .tr-post-meta {
    margin-bottom: 0.5rem;
  }

  .tr-post-date {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 2px;
    color: #7a5520;
    text-transform: uppercase;
  }

  .tr-post-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    color: #f0e0bf;
    margin: 0 0 0.6rem;
    line-height: 1.3;
  }

  .tr-post-desc {
    font-size: 1rem;
    color: #b09060;
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .tr-post-read {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: #8a6028;
    text-transform: uppercase;
  }

  .tr-empty {
    text-align: center;
    color: #7a5520;
    font-style: italic;
    padding: 3rem 0;
  }

  .tr-footer-quote {
    text-align: center;
    padding: 3rem 1.5rem;
    border-top: 1px solid #2e1f0d;
  }

  .tr-quote-text {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 600px;
    margin: 0 auto 0.5rem;
    line-height: 1.6;
  }

  .tr-quote-ref {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: #7a5520;
    text-transform: uppercase;
  }
</style>
