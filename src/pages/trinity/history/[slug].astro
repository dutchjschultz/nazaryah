---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { numberedEntries, getAdjacent, typeLabels } from '../../../data/trinity-timeline';

// Pre-render every article page at build time
export const prerender = true;

export function getStaticPaths() {
  return numberedEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { prev, next } = getAdjacent(entry.slug);
---

<BaseLayout
  title={`${entry.title} — Trinity History — Nazaryah`}
  description={entry.preview}
>
  <div class={`ta-wrap ${entry.type}`}>

    <!-- ── HEADER ── -->
    <section class="ta-header">
      <a href="/trinity/history" class="ta-back">&#8592; Back to the Timeline</a>

      <div class="ta-meta">
        <span class="ta-number">#{entry.number}</span>
        <span class="ta-divider"></span>
        <span class="ta-year">{entry.year}</span>
        <span class="ta-divider"></span>
        <span class="ta-type">{typeLabels[entry.type]}</span>
      </div>

      <h1 class="ta-title">{entry.title}</h1>
      <p class="ta-preview">{entry.preview}</p>
    </section>

    <!-- ── BODY ── -->
    <article class="ta-article">
      <div class="ta-body" set:html={entry.body} />
    </article>

    <!-- ── PREV / NEXT NAV ── -->
    <nav class="ta-nav">
      {prev ? (
        <a href={`/trinity/history/${prev.slug}`} class="ta-nav-link ta-prev">
          <span class="ta-nav-label">&#8592; Previous</span>
          <span class="ta-nav-title">#{prev.number} &middot; {prev.title}</span>
        </a>
      ) : <div></div>}

      {next ? (
        <a href={`/trinity/history/${next.slug}`} class="ta-nav-link ta-next">
          <span class="ta-nav-label">Next &#8594;</span>
          <span class="ta-nav-title">#{next.number} &middot; {next.title}</span>
        </a>
      ) : <div></div>}
    </nav>

    <!-- ── FOOTER QUOTE ── -->
    <div class="ta-footer">
      <p class="ta-footer-text">"My people are destroyed for lack of knowledge."</p>
      <span class="ta-footer-ref">— Hosea 4:6</span>
    </div>

  </div>
</BaseLayout>

<style>
  .ta-wrap {
    background: linear-gradient(180deg, #0e0904 0%, #1a1208 20%, #160f07 100%);
    color: #f0e0bf;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
    position: relative;
    z-index: 0;
  }

  /* ── HEADER ── */
  .ta-header {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    border-bottom: 1px solid #3a2510;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(150, 90, 40, 0.18), transparent 70%),
      linear-gradient(180deg, #0a0602 0%, #1a1208 100%);
    position: relative;
  }

  .ta-back {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #6a4820;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ta-back:hover { color: #c4a46b; }

  /* Meta row: #N · year · type */
  .ta-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.25rem;
    padding: 0.5rem 1.25rem;
    border: 1px solid #3a2510;
    border-radius: 999px;
    background: rgba(10,6,2,0.6);
  }

  .ta-number {
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #f0e0bf;
    letter-spacing: 1px;
  }

  .ta-year {
    font-family: 'Cinzel', serif;
    font-size: 0.82rem;
    letter-spacing: 1.5px;
    color: #c4a46b;
    text-transform: uppercase;
  }

  .ta-type {
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .ta-divider {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #5a3e1a;
  }

  /* Type accent on the meta pill */
  .pagan   .ta-number,
  .pagan   .ta-type   { color: #b85e45; }
  .greek   .ta-number,
  .greek   .ta-type   { color: #7e79c4; }
  .church  .ta-number,
  .church  .ta-type   { color: #5a99c8; }
  .council .ta-number,
  .council .ta-type   { color: #c45a5a; }

  .pagan   .ta-meta { border-color: #5a2510; }
  .greek   .ta-meta { border-color: #2d2860; }
  .church  .ta-meta { border-color: #18395a; }
  .council .ta-meta { border-color: #5a1818; }

  .ta-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    font-weight: 700;
    color: #f0e0bf;
    margin: 0 0 1.25rem;
    line-height: 1.2;
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
  }

  .ta-preview {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── ARTICLE BODY ── */
  .ta-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
  }

  .ta-body {
    font-size: 1.15rem;
    line-height: 1.9;
    color: #d9c9a8;
  }

  .ta-body p { margin-bottom: 1.5rem; }
  .ta-body p:last-child { margin-bottom: 0; }
  .ta-body em { color: #d4935a; font-style: italic; }
  .ta-body strong { color: #e8d5a8; font-weight: 600; }

  /* ── PREV / NEXT NAV ── */
  .ta-nav {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid #2e1f0d;
  }

  .ta-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(160deg, #1e1409 0%, #160f07 100%);
    border: 1px solid #3a2510;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.22s ease;
  }

  .ta-nav-link:hover {
    border-color: #6a4820;
    background: linear-gradient(160deg, #2a1d0c 0%, #1e1309 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }

  .ta-next { text-align: right; align-items: flex-end; }

  .ta-nav-label {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #8a6028;
  }

  .ta-nav-title {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: #f0e0bf;
    line-height: 1.3;
  }

  /* ── FOOTER ── */
  .ta-footer {
    text-align: center;
    padding: 2.5rem 1.5rem 3rem;
    border-top: 1px solid #2e1f0d;
    background: linear-gradient(180deg, #160f07 0%, #0e0904 100%);
  }

  .ta-footer-text {
    font-size: 1.05rem;
    font-style: italic;
    color: #c4a46b;
    margin-bottom: 0.3rem;
  }

  .ta-footer-ref {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: #4a3018;
    text-transform: uppercase;
    display: block;
  }

  @media (max-width: 560px) {
    .ta-back { position: static; display: block; margin-bottom: 1.5rem; text-align: left; }
    .ta-header { padding-top: 2rem; }
    .ta-meta { flex-wrap: wrap; justify-content: center; gap: 0.5rem 0.75rem; }
    .ta-nav { grid-template-columns: 1fr; }
    .ta-next { text-align: left; align-items: flex-start; }
  }
</style>
