---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { numberedEntries, typeLabels } from '../../../data/trinity-timeline';

interface Row {
  label: string;
  start: number;
  end: number;
  ticks: { label: string; year: number }[];
}

const rows: Row[] = [
  {
    label: 'Ancient World',
    start: -2500,
    end: 0,
    ticks: [
      { label: '2500 BC', year: -2500 },
      { label: '2000 BC', year: -2000 },
      { label: '1500 BC', year: -1500 },
      { label: '1000 BC', year: -1000 },
      { label: '500 BC',  year: -500  },
      { label: '0',       year: 0     },
    ],
  },
  {
    label: 'Early Church Era',
    start: 0,
    end: 600,
    ticks: [
      { label: '0',      year: 0   },
      { label: '100 AD', year: 100 },
      { label: '200 AD', year: 200 },
      { label: '300 AD', year: 300 },
      { label: '400 AD', year: 400 },
      { label: '500 AD', year: 500 },
      { label: '600 AD', year: 600 },
    ],
  },
  {
    label: 'From Rome to Present',
    start: 600,
    end: 2100,
    ticks: [
      { label: '600 AD',  year: 600  },
      { label: '900 AD',  year: 900  },
      { label: '1200 AD', year: 1200 },
      { label: '1500 AD', year: 1500 },
      { label: '1800 AD', year: 1800 },
      { label: '2100 AD', year: 2100 },
    ],
  },
];

const rowsWithEntries = rows.map((row) => ({
  ...row,
  entries: numberedEntries
    .filter((e) => e.yearSort >= row.start && e.yearSort <= row.end)
    .map((e) => ({
      ...e,
      pct: ((e.yearSort - row.start) / (row.end - row.start)) * 100,
    })),
}));
---

<BaseLayout
  title="Trinity History — Timeline — Nazaryah"
  description="The historical trail of the Trinity doctrine — from Babel's scattering to the Nicene Creed and beyond. A horizontal timeline of the core moments."
>
  <div class="th-wrap">

    <section class="th-header">
      <a href="/trinity" class="th-back">&#8592; Back to Trinity</a>
      <p class="th-label">&#8213; The Historical Trail &#8213;</p>
      <h1 class="th-title">Trinity History</h1>
      <p class="th-sub">
        A horizontal timeline of the moments that built the doctrine. Hover each number to read a preview — click to open the full article.
      </p>
    </section>

    <div class="th-legend">
      <span class="th-leg"><span class="th-dot pagan"></span>{typeLabels.pagan}</span>
      <span class="th-leg"><span class="th-dot greek"></span>{typeLabels.greek}</span>
      <span class="th-leg"><span class="th-dot church"></span>{typeLabels.church}</span>
      <span class="th-leg"><span class="th-dot council"></span>{typeLabels.council}</span>
    </div>

    <div class="th-rows">
      {rowsWithEntries.map((row) => (
        <div class="th-row">
          <div class="th-row-label">{row.label}</div>
          <div class="th-track">
            <div class="th-spine"></div>

            {row.ticks.map((t) => {
              const pct = ((t.year - row.start) / (row.end - row.start)) * 100;
              return (
                <div class="th-tick" style={`left:${pct}%;`}>
                  <div class="th-tick-mark"></div>
                  <div class="th-tick-label">{t.label}</div>
                </div>
              );
            })}

            {row.entries.map((e) => (
              <a
                href={`/trinity/history/${e.slug}`}
                class={`th-num ${e.type}`}
                style={`left:${e.pct}%;`}
                data-tooltip={`${e.title} — ${e.preview}`}
                aria-label={`Article ${e.number}: ${e.title}`}
              >
                <span class="th-num-text">{e.number}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="th-footer">
      <p class="th-footer-text">"My people are destroyed for lack of knowledge."</p>
      <span class="th-footer-ref">— Hosea 4:6</span>
    </div>

  </div>
</BaseLayout>

<style>
  .th-wrap {
    background: linear-gradient(180deg, #0e0904 0%, #1a1208 20%, #160f07 100%);
    color: #f0e0bf;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
    padding-bottom: 4rem;
  }

  .th-header {
    text-align: center;
    padding: 4rem 1.5rem 2.5rem;
    border-bottom: 1px solid #3a2510;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(150, 90, 40, 0.18), transparent 70%),
      linear-gradient(180deg, #0a0602 0%, #1a1208 100%);
    position: relative;
  }
  .th-back {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #6a4820;
    text-decoration: none;
  }
  .th-back:hover { color: #c4a46b; }
  .th-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #8a6028;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .th-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    color: #f0e0bf;
    margin: 0 0 0.75rem;
  }
  .th-sub {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .th-legend {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: 1.5rem 1rem;
  }
  .th-leg {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: #8a6028;
    text-transform: uppercase;
  }
  .th-dot {
    width: 10px; height: 10px; border-radius: 50%;
  }
  .th-dot.pagan   { background: #b85e45; }
  .th-dot.greek   { background: #7e79c4; }
  .th-dot.church  { background: #5a99c8; }
  .th-dot.council { background: #c45a5a; }

  .th-rows {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .th-row-label {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #c4a46b;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .th-track {
    position: relative;
    height: 100px;
    padding: 0 2rem;
  }

  .th-spine {
    position: absolute;
    left: 2rem;
    right: 2rem;
    top: 50%;
    height: 3px;
    background: linear-gradient(90deg, #3a2510, #6a4820 20%, #6a4820 80%, #3a2510);
    border-radius: 2px;
    transform: translateY(-50%);
  }

  .th-tick {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }
  .th-tick-mark {
    width: 2px;
    height: 14px;
    background: #8a6028;
  }
  .th-tick-label {
    position: absolute;
    top: 14px;
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: #6a4820;
    text-transform: uppercase;
    white-space: nowrap;
    margin-top: 4px;
  }

  .th-num {
    position: absolute;
    top: 50%;
    left: 0;
    margin-top: -18px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(160deg, #211608 0%, #1a1007 100%);
    border: 2px solid #8a5a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    z-index: 2;
    transition: all 0.22s ease;
    transform: translate(-50%, -50%);
  }
  .th-num-text {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 700;
    color: #f0e0bf;
  }
  .th-num:hover {
    box-shadow: 0 0 24px rgba(196, 164, 107, 0.4);
    z-index: 10;
    transform: translate(-50%, -50%) scale(1.15);
  }

  .th-num.pagan   { border-color: #b85e45; }
  .th-num.greek   { border-color: #7e79c4; }
  .th-num.church  { border-color: #5a99c8; }
  .th-num.council { border-color: #c45a5a; }

  .th-num[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: #0a0602;
    border: 1px solid #6a4820;
    color: #f0e0bf;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 13px;
    line-height: 1.5;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    width: max-content;
    max-width: 300px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 20;
    box-shadow: 0 10px 24px rgba(0,0,0,0.7);
    white-space: normal;
    text-align: left;
  }
  .th-num:hover::after {
    opacity: 1;
  }

  .th-footer {
    text-align: center;
    padding: 3rem 1.5rem 0;
    margin-top: 3rem;
    border-top: 1px solid #2e1f0d;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .th-footer-text {
    font-size: 1.05rem;
    font-style: italic;
    color: #c4a46b;
    margin-bottom: 0.3rem;
  }
  .th-footer-ref {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: #4a3018;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .th-rows { padding: 0 1rem; gap: 3.5rem; }
    .th-track { padding: 0 1rem; height: 90px; }
    .th-spine { left: 1rem; right: 1rem; }
    .th-num { width: 32px; height: 32px; }
    .th-num-text { font-size: 12px; }
    .th-tick-label { font-size: 8px; }
  }
  @media (max-width: 500px) {
    .th-back { position: static; display: block; margin-bottom: 1rem; text-align: left; }
  }
</style>
