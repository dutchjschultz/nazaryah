---
import HebrewLayout from '../../layouts/HebrewLayout.astro';

const CHAIN = [
  { letter: "𐤅", label: "Phoenician Waw", sound: "U", era: "~1100 BCE", correct: true },
  { letter: "Υ", label: "Greek Upsilon", sound: "U", era: "~800 BCE", correct: true },
  { letter: "V", label: "Latin V (=U shape)", sound: "U", era: "~100 BCE", correct: true },
  { letter: "U", label: "Medieval Split", sound: "U", era: "~200 CE", correct: true },
  { letter: "W", label: "Double U (UU→VV)", sound: "UU", era: "~700 CE", correct: false },
  { letter: "V", label: "Ashkenazi Shift", sound: "V", era: "~200 CE+", correct: false },
];

const EVIDENCE = [
  { n: 1, text: "Josephus (37 CE) — \"The sacred name consists of four vowels.\" V is a consonant. U is a vowel." },
  { n: 2, text: "Greek Septuagint (~250 BCE) — David transliterated as Δαυιδ with Upsilon (U), not Beta (V)." },
  { n: 3, text: "Dead Sea Scrolls (~200 BCE–70 CE) — Oldest manuscripts use Waw extensively as vowel letter for U/O sounds." },
  { n: 4, text: "Ugaritic (~1400 BCE) — Hebrew's closest ancient relative uses Waw as /w/. No V in any ancient Semitic language." },
  { n: 5, text: "Prof. Fassberg, Hebrew University — \"There is no doubt that the original sound was W and not V.\"" },
  { n: 6, text: "Prof. Moshavi, Hebrew University — Waw as mater lectionis for long U \"would be impossible to explain if it was pronounced V.\"" },
  { n: 7, text: "Yemenite Jews (unbroken tradition) — Never displaced to Europe. Still pronounce Waw as U/W." },
  { n: 8, text: "Samaritan Hebrews (unbroken tradition) — Still use Paleo-Hebrew script. Pronounce sixth letter as Waw." },
  { n: 9, text: "The Bet (ב) Argument — Only letter in biblical Hebrew that makes V sound. If Waw also made V, two letters same sound." },
  { n: 10, text: "Five Latin Descendants — F, U, V, W, Y ALL descend from Phoenician Waw. Every one traces to U/OO origin." },
];

const WORDS = [
  { hebrew: "רוּחַ", trans: "Ruach", meaning: "Spirit", note: "Everyone says 'Roo-akh.' Nobody says 'Rvach.' The ו is clearly U." },
  { hebrew: "רְאוּבֵן", trans: "Reuben", meaning: "Behold, a son", note: "Nobody says 'Revben.' The U is undisputed." },
  { hebrew: "יְהוּדָה", trans: "Yahudah", meaning: "Judah / Praise", note: "Same ו = same U. 'Yah-U-dah,' not 'Yah-V-dah.'" },
  { hebrew: "דָּוִד", trans: "Dawid", meaning: "David / Beloved", note: "Greek Septuagint: Δαυιδ with Upsilon (U), not Beta (V)." },
  { hebrew: "שָׁלוֹם", trans: "Shalom", meaning: "Peace", note: "The ו carries the long O vowel sound." },
  { hebrew: "תּוֹרָה", trans: "Torah", meaning: "Instruction / Law", note: "Dead Sea Scrolls spell it with a Waw vowel letter." },
  { hebrew: "אֱלוֹהִים", trans: "Elohim", meaning: "Mighty One(s)", note: "Dead Sea Scrolls write with a Waw. Masoretic text replaced it with a dot." },
  { hebrew: "יְשׁוּעָה", trans: "Yeshuah", meaning: "Salvation", note: "Root of Yahushua's name. ו = U, giving 'shu' not 'shv.'" },
];

const TIMELINE = [
  {
    id: "t1",
    era: "~3000–1500 BCE",
    title: "Proto-Sinaitic / Pictographic Origin",
    subtitle: "A Tent Peg — The Letter Was a Picture Before It Was a Sound",
    sound: "U / OO",
    correct: true,
    body: `Before the Hebrew alphabet existed as letters, it existed as pictures. The earliest form of what would become the sixth letter was a pictograph of a tent peg — a Y-shaped piece of hardwood driven into the ground to secure the ropes of a goat-hair tent. The ancient name was "Waw" meaning "peg" or "hook." Its pictographic meanings: to attach, to secure, to connect, to join, to add. This is why the letter ו is used as the Hebrew prefix for "and." The pictograph evolved through stages: Proto-Sinaitic (Y-shaped tent peg) → Early Semitic → Middle Semitic → Late Semitic/Paleo-Hebrew → Modern Aramaic-derived. At every stage, the SOUND remained U/OO.`,
    sources: [
      "\"The original pictograph is a tent peg. The ancient name was Waw. Sounds: w, ow, uw.\" — AHRC",
      "\"The Ancient Hebrew name for this letter is 'Wa', meaning 'peg' or 'hook.'\" — Paleo Hebrew Reference",
    ],
  },
  {
    id: "t2",
    era: "~1100 BCE",
    title: "Phoenician Waw (𐤅)",
    subtitle: "The Ancestor of Five Latin Letters — All From One U Sound",
    sound: "U / OO",
    correct: true,
    body: `The Phoenician alphabet descended from Proto-Sinaitic. Its sixth letter, Waw (𐤅), represented /w/ and vowel /u/. Waw was a "mater lectionis" — more often a vowel than consonant. FIVE letters of modern Latin descend from this single letter: F (via Greek Digamma), U (via Greek Upsilon), V (angular form of U), W ("double U"), Y (via Greek Upsilon). Every single one traces back to a U sound.`,
    sources: [
      "\"U is derived from the Semitic letter waw, along with F, V, W, and Y.\" — Letters Wiki",
      "\"Yod and Waw in particular are more often vowels than consonants.\" — Wikipedia: Mater Lectionis",
    ],
  },
  {
    id: "t3",
    era: "~800 BCE",
    title: "Greek Upsilon (Υ υ)",
    subtitle: "\"Simple U\" — The Greeks Named It What It Sounded Like",
    sound: "U / OO",
    correct: true,
    body: `Greeks split Waw into Digamma (Ϝ) for /w/ and Upsilon (Υ) for /u/. "Upsilon" literally means "simple U." In the Septuagint, David (דָּוִיד) was transliterated as Δαυιδ using Upsilon — the U vowel, not Beta which would indicate V.`,
    sources: [
      "\"Upsilon originated from Phoenician waw. In classical Greek, it had the value of [u].\" — Vaia Encyclopedia",
    ],
  },
  {
    id: "t4",
    era: "~1400–1200 BCE",
    title: "Ugaritic Confirmation",
    subtitle: "Hebrew's Closest Ancient Cousin Proves the U Sound",
    sound: "U / OO",
    correct: true,
    body: `Ugarit tablets show Waw as /w/ — consonantal form of U. No V exists. Every Semitic language descending from same family preserves U/W: Ugaritic, Arabic, Aramaic, Maltese, Ge'ez. Not one ancient Semitic language has V. The V is not Semitic — it is European.`,
    sources: [
      "\"Ugaritic and later Semitic languages like Arabic, Maltese, and Ge'ez, all use a double 'u.'\" — Yahweh's Restoration Ministry",
    ],
  },
  {
    id: "t5",
    era: "~200 BCE – 100 CE",
    title: "The Dead Sea Scrolls",
    subtitle: "Ancient Scribes Used the Waw as a Vowel Letter — Physical Proof",
    sound: "U / OO",
    correct: true,
    body: `The Dead Sea Scrolls use "plene" spelling extensively — inserting Waw as vowel indicator for U and O sounds. The word "lo" (no) is written לוא with Waw as vowel. Dr. Bill Barrick: "a Waw is sometimes given as a vowel letter for the qibbuts, which really represents a shureq — the sounds were very, very close."`,
    sources: [
      "\"The Dead Sea Scrolls used ו for the consonant 'w' but also the vowel sound 'o.'\" — Ancient Hebrew Torah Project",
    ],
  },
  {
    id: "t6",
    era: "37 CE",
    title: "Josephus — Eyewitness Testimony",
    subtitle: "\"The Sacred Name Consists of Four Vowels\"",
    sound: "U / OO",
    correct: true,
    body: `Josephus describes the high priest's golden crown: "the sacred name: it consists of four vowels." V is a consonant (requires teeth + lip). U is a vowel (open mouth). The name must be: Y (Yod) + H (He) + U (Waw) + H (He) = Yah-U-ah. Four open-mouth vowel sounds.`,
    sources: [
      "Josephus, War of the Jews, Book 5, Chapter 5",
    ],
  },
  {
    id: "t7",
    era: "~100 BCE – 1500 CE",
    title: "Latin V — The Roman Chisel Problem",
    subtitle: "Same Sound, Different Shape — Stone Changed the Letter, Not the Voice",
    sound: "U (carved as V)",
    correct: true,
    body: `Romans carved U as V shape because it was easier in stone. IVLIVS = "Yoo-lee-oos." AVGVSTVS = "Ow-goos-toos." The V/U distinction as separate letters didn't exist until the 16th century. The "vee" sound is MODERN.`,
    sources: [
      "\"Classical Latin used V for vowel /u/ and consonant /w/. The distinction didn't emerge until the 16th century.\"",
    ],
  },
  {
    id: "t8",
    era: "~700 CE",
    title: "The Invention of W — A \"Double U\"",
    subtitle: "Two U's Printed as Two V's — A Medieval European Accident",
    sound: "UU → W",
    correct: false,
    body: `Anglo-Saxon scribes wrote two U's (UU) for /w/ sound. Printing press used two V blocks (VV). Name "double-U" persisted. W is a medieval European invention — does not exist in Hebrew, Greek, or Latin.`,
    sources: [
      "\"The ancient Roman alphabet did not have 'w.' The sound was represented by 'uu.'\" — Oxford English Dictionary",
    ],
  },
  {
    id: "t9",
    era: "~70–200 CE onward",
    title: "The Ashkenazi V Corruption",
    subtitle: "Germanic Languages Overwrote the Ancient Sound",
    sound: "V (Germanic corruption)",
    correct: false,
    body: `Prof. Fassberg: "There is no doubt that the original sound was W and not V." The shift occurred during Mishnaic Period. Yemenite Jews (never in Europe) still say U/W. Samaritans (use Paleo-Hebrew) still say Waw. The only V in biblical Hebrew comes from Bet (ב). Evidence is unanimous: Ugaritic, Aramaic, Arabic, Ge'ez, Yemenite, Samaritan — all say U/W.`,
    sources: [
      "\"Prof. Fassberg: 'There is no doubt the original sound was w and not v.'\"",
      "\"The Yemenite Jews who retain an ancient, pure pronunciation still pronounce the waw as 'w.'\" — Horowitz",
    ],
  },
  {
    id: "t10",
    era: "~600–1000 CE",
    title: "The Masoretic Vowel System",
    subtitle: "When Dots Replaced Letters — And the Evidence Was Obscured",
    sound: "U (systematically removed from text)",
    correct: true,
    body: `Masoretes replaced physical Waw vowel letters with dot system. This obscured the evidence. Dead Sea Scrolls show what pre-Masoretic text looked like — Waw was everywhere as vowel. Masoretes worked 600–1000 CE, a 2000-year gap from biblical Hebrew.`,
    sources: [
      "\"Around 700 CE the Masorites added dots and dashes.\" — AHRC FAQ",
    ],
  },
];

const TABS = [
  { id: "thesis",   label: "Thesis" },
  { id: "journey",  label: "Journey" },
  { id: "evidence", label: "Evidence" },
  { id: "words",    label: "Word Proof" },
  { id: "timeline", label: "Timeline" },
  { id: "verdict",  label: "Verdict" },
];
---

<HebrewLayout
  title="The Case for U — Waw — Hebrew — Nazaryah"
  description="Why the Hebrew letter Waw (ו) always carried a U sound — never a V, never a W. Evidence from Josephus, the Septuagint, the Dead Sea Scrolls, and Hebrew University."
>
  <!-- HERO -->
  <section class="hl-hero">
    <a href="/hebrew" class="hl-back">&#8592; Back to Hebrew</a>
    <p class="hl-label">&#8213; The Sixth Letter &#8213;</p>
    <div class="waw-hero-letter">ו</div>
    <h1 class="hl-title">The Case for U</h1>
    <p class="hl-sub">Why the Hebrew ו was always a U — never a V, never a W</p>
  </section>

  <!-- TABS NAV -->
  <nav class="waw-tab-nav" aria-label="Study sections">
    {TABS.map((t, i) => (
      <button
        type="button"
        class={`waw-tab${i === 0 ? " active" : ""}`}
        data-tab={t.id}
        aria-selected={i === 0 ? "true" : "false"}
      >
        {t.label}
      </button>
    ))}
  </nav>

  <!-- ══ SECTION: THESIS ══ -->
  <section class="waw-panel active" data-panel="thesis">
    <div class="waw-inner">
      <p class="waw-eyebrow">The Argument in Brief</p>
      <h2 class="waw-panel-title">The Thesis</h2>
      <div class="waw-thesis-body">
        <div class="waw-thesis-letter">ו</div>
        <div class="waw-thesis-text">
          <p>
            The sixth letter of the Hebrew alphabet — ו — is called "Vav" in modern Hebrew and transliterated as "W" in academic circles. Both are wrong.
          </p>
          <p>
            The evidence overwhelmingly proves this letter always carried a <strong>U (oo)</strong> sound.
          </p>
          <p>
            This matters: The Father's name is <strong>Yah-U-ah</strong> (יהוה). The Son's name is <strong>Yah-U-shua</strong> (יהושע).
          </p>
        </div>
      </div>
      <div class="waw-thesis-names">
        <div class="waw-name-card waw-name-gold">
          <div class="waw-name-heb">יהוה</div>
          <div class="waw-name-trans">Yah · U · ah</div>
          <div class="waw-name-label">The Father's Name</div>
        </div>
        <div class="waw-thesis-arrow">→</div>
        <div class="waw-name-card waw-name-gold">
          <div class="waw-name-heb">יהושע</div>
          <div class="waw-name-trans">Yah · U · shua</div>
          <div class="waw-name-label">The Son's Name</div>
        </div>
      </div>
      <p class="waw-thesis-cta">Use the tabs above to walk through every layer of evidence.</p>
    </div>
  </section>

  <!-- ══ SECTION: JOURNEY ══ -->
  <section class="waw-panel" data-panel="journey">
    <div class="waw-inner">
      <p class="waw-eyebrow">How the Letter Traveled</p>
      <h2 class="waw-panel-title">The Letter's Journey</h2>
      <p class="waw-panel-sub">One letter. Three thousand years. The sound never changed — only the shape, and eventually the pronunciation under European influence.</p>

      <!-- Chain -->
      <div class="waw-chain-wrap">
        <div class="waw-chain">
          {CHAIN.map((node, i) => (
            <>
              <div class={`waw-node${node.correct ? " waw-node-gold" : " waw-node-red"}`}>
                <div class="waw-node-letter">{node.letter}</div>
                <div class="waw-node-label">{node.label}</div>
                <div class="waw-node-sound">{node.sound}</div>
                <div class="waw-node-era">{node.era}</div>
                {!node.correct && <div class="waw-node-corrupt">corruption</div>}
              </div>
              {i < CHAIN.length - 1 && (
                <div class={`waw-chain-arrow${CHAIN[i + 1].correct ? "" : " waw-chain-arrow-red"}`}>→</div>
              )}
            </>
          ))}
        </div>
      </div>

      <!-- Legend -->
      <div class="waw-legend">
        <span class="waw-legend-dot waw-legend-gold"></span><span class="waw-legend-text">Correct U sound — original, unbroken</span>
        <span class="waw-legend-dot waw-legend-red"></span><span class="waw-legend-text">Corruption — European alteration</span>
      </div>

      <div class="waw-journey-prose">
        <p>
          The Phoenician Waw (𐤅) carried the U/OO sound. When the Greeks adopted the alphabet around 800 BCE, they preserved both its forms: Digamma (Ϝ) for the consonant /w/, and <strong>Upsilon (Υ)</strong> — literally "simple U" — for the vowel. The Romans inherited Upsilon as the letter V, but carved it angular in stone because chisels preferred straight lines. The sound remained U.
        </p>
        <p>
          Two corruptions entered later. First: Anglo-Saxon scribes in ~700 CE needed to write the /w/ sound and doubled two U's (UU → VV in type), giving us the letter W — named "double-U" because that is exactly what it was. Second: As Ashkenazi Jewish communities settled in Germanic Europe, their pronunciation of Waw shifted to V under the influence of surrounding Germanic languages.
        </p>
        <p>
          Neither corruption has ancient roots. The original sound — confirmed by Josephus, the Septuagint, the Dead Sea Scrolls, Ugaritic tablets, Yemenite tradition, and Hebrew University professors — was always <strong>U</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ SECTION: EVIDENCE ══ -->
  <section class="waw-panel" data-panel="evidence">
    <div class="waw-inner">
      <p class="waw-eyebrow">The Scholarly Record</p>
      <h2 class="waw-panel-title">Ten Pillars of Evidence</h2>
      <p class="waw-panel-sub">Ten independent witnesses across 3,000 years of history — all pointing to the same conclusion.</p>

      <div class="waw-pillars">
        {EVIDENCE.map((e) => (
          <div class="waw-pillar">
            <div class="waw-pillar-num">{e.n}</div>
            <div class="waw-pillar-text">{e.text}</div>
          </div>
        ))}
      </div>

      <div class="waw-evidence-note">
        <p>These are not fringe sources. They are: a first-century Jewish historian writing under Roman authority, the oldest Greek translation of Scripture, the oldest physical Hebrew manuscripts ever found, ancient clay tablets predating Moses, and sitting professors at the Hebrew University of Jerusalem.</p>
      </div>
    </div>
  </section>

  <!-- ══ SECTION: WORDS ══ -->
  <section class="waw-panel" data-panel="words">
    <div class="waw-inner">
      <p class="waw-eyebrow">The Evidence in Plain Sight</p>
      <h2 class="waw-panel-title">The Proof in Every Word</h2>
      <p class="waw-panel-sub">The same letter ו appears in words everyone already pronounces correctly. If it sounds like U in one word, it sounds like U in all words — including the sacred names.</p>

      <div class="waw-words-grid">
        {WORDS.map((w) => (
          <div class="waw-word-card">
            <div class="waw-word-heb">{w.hebrew}</div>
            <div class="waw-word-trans">{w.trans}</div>
            <div class="waw-word-meaning">{w.meaning}</div>
            <div class="waw-word-note">{w.note}</div>
          </div>
        ))}
      </div>

      <div class="waw-words-conclusion">
        <p>
          The same ו that gives "Roo-akh" its U sound is the same ו in יהוה and יהושע. There is no rule that makes ו into U in Ruach but V in the sacred names. Consistency demands Yah-<strong>U</strong>-ah and Yah-<strong>U</strong>-shua.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ SECTION: TIMELINE ══ -->
  <section class="waw-panel" data-panel="timeline">
    <div class="waw-inner">
      <p class="waw-eyebrow">3,000 Years of Documentation</p>
      <h2 class="waw-panel-title">The Full Historical Record</h2>
      <p class="waw-panel-sub">Click any entry to expand the full account. The evidence is layered, consistent, and from independent sources across millennia.</p>

      <div class="waw-timeline">
        {TIMELINE.map((entry) => (
          <div class={`waw-tl-item${entry.correct ? "" : " waw-tl-corrupt"}`} data-tl={entry.id}>
            <button type="button" class="waw-tl-trigger" aria-expanded="false">
              <div class="waw-tl-left">
                <div class="waw-tl-dot"></div>
                <div class="waw-tl-line-seg"></div>
              </div>
              <div class="waw-tl-header">
                <span class="waw-tl-era">{entry.era}</span>
                <span class={`waw-tl-sound-badge${entry.correct ? " waw-badge-gold" : " waw-badge-red"}`}>{entry.sound}</span>
                <h3 class="waw-tl-title">{entry.title}</h3>
                <p class="waw-tl-subtitle">{entry.subtitle}</p>
              </div>
              <div class="waw-tl-chevron" aria-hidden="true">&#8964;</div>
            </button>
            <div class="waw-tl-body" hidden>
              <p class="waw-tl-content">{entry.body}</p>
              {entry.sources.length > 0 && (
                <div class="waw-tl-sources">
                  <span class="waw-tl-sources-label">Sources</span>
                  {entry.sources.map((s) => (
                    <p class="waw-tl-source">{s}</p>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ SECTION: VERDICT ══ -->
  <section class="waw-panel" data-panel="verdict">
    <div class="waw-inner waw-inner-verdict">
      <p class="waw-eyebrow">The Conclusion</p>
      <h2 class="waw-panel-title">The Verdict</h2>

      <div class="waw-verdict-body">
        <p>The Hebrew letter ו has always carried a <strong>U / OO</strong> sound.</p>
        <p>The <strong>V</strong> pronunciation is a Germanic corruption from Ashkenazi influence. The only V in biblical Hebrew comes from Bet (ב).</p>
        <p>The <strong>W</strong> pronunciation is a medieval English invention — two U's doubled together.</p>
      </div>

      <div class="waw-verdict-chain">
        <span class="waw-vc-node">Phoenician Waw</span>
        <span class="waw-vc-arrow">→</span>
        <span class="waw-vc-node">Greek Upsilon ("simple U")</span>
        <span class="waw-vc-arrow">→</span>
        <span class="waw-vc-node">Latin V (= U in stone)</span>
        <span class="waw-vc-arrow">→</span>
        <span class="waw-vc-always">always a U</span>
      </div>

      <div class="waw-verdict-witnesses">
        <p class="waw-verdict-wit-label">Confirmed by</p>
        <div class="waw-witnesses">
          <span class="waw-witness">Josephus</span>
          <span class="waw-witness">Septuagint</span>
          <span class="waw-witness">Dead Sea Scrolls</span>
          <span class="waw-witness">Ugaritic Tablets</span>
          <span class="waw-witness">Yemenite Tradition</span>
          <span class="waw-witness">Samaritan Tradition</span>
          <span class="waw-witness">Hebrew University</span>
        </div>
      </div>

      <div class="waw-verdict-final">
        <p class="waw-verdict-names">Yah · U · ah &nbsp;&nbsp;·&nbsp;&nbsp; Yah · U · shua</p>
        <p class="waw-verdict-heb">יהוה &nbsp;&nbsp;·&nbsp;&nbsp; יהושע</p>
        <p class="waw-verdict-caption">Therefore</p>
      </div>
    </div>
  </section>
</HebrewLayout>

<script>
  // ── Tab switching ──────────────────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.waw-tab');
  const panels = document.querySelectorAll<HTMLElement>('.waw-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        t.classList.toggle('active', t.dataset.tab === target);
        t.setAttribute('aria-selected', t.dataset.tab === target ? 'true' : 'false');
      });
      panels.forEach((p) => {
        p.classList.toggle('active', p.dataset.panel === target);
      });
    });
  });

  // ── Timeline accordion (one open at a time) ────────────────────────
  const tlItems = document.querySelectorAll<HTMLElement>('.waw-tl-item');

  tlItems.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.waw-tl-trigger');
    const body = item.querySelector<HTMLElement>('.waw-tl-body');
    const chevron = item.querySelector<HTMLElement>('.waw-tl-chevron');
    if (!trigger || !body) return;

    trigger.addEventListener('click', () => {
      const isOpen = !body.hidden;

      // Close all
      tlItems.forEach((other) => {
        const otherBody = other.querySelector<HTMLElement>('.waw-tl-body');
        const otherTrigger = other.querySelector<HTMLButtonElement>('.waw-tl-trigger');
        const otherChevron = other.querySelector<HTMLElement>('.waw-tl-chevron');
        if (otherBody) otherBody.hidden = true;
        if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        if (otherChevron) otherChevron.style.transform = '';
        other.classList.remove('waw-tl-open');
      });

      // Open clicked if it was closed
      if (!isOpen) {
        body.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        item.classList.add('waw-tl-open');
      }
    });
  });
</script>

<style>
  /* ── Hero letter ── */
  .waw-hero-letter {
    font-size: 5rem;
    color: #c9a84c;
    line-height: 1;
    margin-bottom: 0.5rem;
    text-shadow: 0 0 40px rgba(201, 168, 76, 0.45);
  }

  /* ── Tab nav ── */
  .waw-tab-nav {
    display: flex;
