---
import HebrewLayout from '../../layouts/HebrewLayout.astro';
import { wordPictures } from '../../data/hebrew-alphabet';
---

<HebrewLayout
  title="Word Pictures — Hebrew — Nazaryah"
  description="Hebrew words are not collections of sounds. They are collections of stories. Each word broken down letter by letter."
>
  <section class="hl-hero">
    <a href="/hebrew" class="hl-back">&#8592; Back to Hebrew</a>
    <p class="hl-label">&#8213; Section Two &#8213;</p>
    <h1 class="hl-title">Word Pictures</h1>
    <p class="hl-sub">
      Hebrew words are not collections of sounds. They are collections of stories — each letter contributing its ancient image to a compound meaning no translation can fully capture.
    </p>
  </section>

  <section class="hl-section">
    <div class="wp-grid">
      {wordPictures.map((w) => (
        <div class="wp-card">
          <div class="wp-scripts">
            <span class="wp-paleo">{w.paleo}</span>
            <span class="wp-modern">{w.modern}</span>
          </div>
          <div class="wp-roman">{w.roman} &middot; {w.gloss}</div>
          <div class="wp-break" set:html={w.breakdown} />
          <p class="wp-meaning" set:html={w.meaning} />
        </div>
      ))}
    </div>
  </section>

  <section class="hl-section hl-center">
    <p style="color:#8a6028;font-style:italic;font-size:0.95rem;max-width:560px;margin:0 auto;">
      More word pictures will be added over time. Each one opens a door into how Hebrew thinks — in images, not abstractions.
    </p>
  </section>
</HebrewLayout>

<style>
  .wp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  .wp-card {
    background: linear-gradient(160deg, #1e1409 0%, #160f07 100%);
    border: 2px solid #8a5a2a;
    border-radius: 8px;
    padding: 1.75rem 1.5rem;
    transition: all 0.25s ease;
  }
  .wp-card:hover {
    border-color: #c4a46b;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    transform: translateY(-2px);
  }
  .wp-scripts {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    direction: rtl;
    margin-bottom: 0.35rem;
  }
  .wp-paleo {
    font-size: 2.2rem;
    color: #b88540;
    line-height: 1.1;
  }
  .wp-modern {
    font-size: 2.75rem;
    color: #e8c97a;
    line-height: 1.1;
    text-shadow: 0 0 16px rgba(232, 201, 122, 0.25);
  }
  .wp-roman {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    color: #c4a46b;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
  }
  .wp-break {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: #6a4820;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2e1f0d;
  }
  .wp-break :global(.ha-cl) { color: #c4a46b; font-size: 1rem; }
  .wp-meaning {
    font-size: 1rem;
    color: #c4ad84;
    line-height: 1.75;
    margin: 0;
  }
  .wp-meaning :global(strong) { color: #e8d5a8; }
</style>
