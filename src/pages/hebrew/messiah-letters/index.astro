---
import HebrewLayout from '../../../layouts/HebrewLayout.astro';
import { messiahLetters } from '../../../data/messiah-letters';
---

<HebrewLayout
  title="Yahushua in Every Letter — Hebrew — Nazaryah"
  description="How Yahushua the Messiah embodies and fulfills every one of the 22 Hebrew letters — from Aleph to Tav."
>
  <section class="hl-hero">
    <a href="/hebrew" class="hl-back">&#8592; Back to Hebrew</a>
    <p class="hl-label">&#8213; A Scripture Study &#8213;</p>
    <h1 class="hl-title">Yahushua in Every Letter</h1>
    <span class="heb-display">א ב ג ד ה ו ז ח ט י כ ל מ נ ס ע פ צ ק ר ש ת</span>
    <p class="hl-sub">
      The Hebrew aleph-bet is not merely an alphabet. Each letter carries a concept rooted in its ancient form. When those concepts are held against the life and mission of Yahushua the Messiah — and tested against Scripture that is specifically about the Son — the letters become a testimony written before He arrived.
    </p>
  </section>

  <section class="hl-section">
    <h2 class="hl-section-title hl-center">The Twenty-Two Letters</h2>
    <p class="hl-section-sub hl-center">Select any letter to open its full study.</p>

    <div class="letter-grid">
      {messiahLetters.map((l) => (
        <a href={`/hebrew/messiah-letters/${l.slug}`} class="letter-tile">
          <span class="tile-char">{l.char}</span>
          <span class="tile-name">{l.name}</span>
          <span class="tile-num">{l.num} of 22</span>
          <span class="tile-concept">{l.concept}</span>
        </a>
      ))}
    </div>
  </section>
</HebrewLayout>

<style>
  .heb-display {
    display: block;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: #C9A84C;
    direction: rtl;
    line-height: 1.6;
    margin: 1rem auto 1.5rem;
    opacity: 0.75;
    letter-spacing: 0.15em;
  }

  .letter-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.65rem;
  }

  .letter-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.1rem 0.5rem 0.9rem;
    border-radius: 4px;
    border: 1px solid rgba(201,168,76,0.18);
    background: rgba(201,168,76,0.04);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    cursor: pointer;
  }

  .letter-tile:hover {
    background: rgba(201,168,76,0.1);
    border-color: rgba(201,168,76,0.45);
    transform: translateY(-2px);
  }

  .tile-char {
    font-size: 2.2rem;
    color: #e8c97a;
    line-height: 1;
    direction: rtl;
  }

  .tile-name {
    font-family: 'Cinzel', serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: #c4ad84;
    text-transform: uppercase;
  }

  .tile-num {
    font-family: 'Cinzel', serif;
    font-size: 0.55rem;
    color: #5a3e1a;
    letter-spacing: 0.05em;
  }

  .tile-concept {
    font-size: 0.65rem;
    color: #8B6914;
    font-style: italic;
    text-align: center;
    line-height: 1.3;
    margin-top: 0.1rem;
    padding: 0 0.25rem;
  }

  @media (max-width: 700px) {
    .letter-grid { grid-template-columns: repeat(4, 1fr); }
    .tile-concept { display: none; }
  }

  @media (max-width: 440px) {
    .letter-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
