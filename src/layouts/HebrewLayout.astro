---
import BaseLayout from './BaseLayout.astro';
interface Props { title: string; description?: string; }
const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="hl-wrap">
    <slot />
  </div>
</BaseLayout>

<style is:global>
  /* ── Shared dark-clay theme for every Hebrew sub-page ── */
  .hl-wrap {
    background: linear-gradient(180deg, #0e0904 0%, #1a1208 20%, #160f07 100%);
    color: #f0e0bf;
    font-family: 'Crimson Pro', 'Crimson Text', Georgia, serif;
    min-height: 80vh;
    position: relative;
    z-index: 0;
  }

  /* Hero block */
  .hl-hero {
    text-align: center;
    padding: 5rem 1.5rem 3.5rem;
    border-bottom: 1px solid #4a3218;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(150, 90, 40, 0.18), transparent 70%),
      linear-gradient(180deg, #0a0602 0%, #1a1208 100%);
    position: relative;
  }
  .hl-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 4px;
    color: #8a6028;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hl-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #f0e0bf;
    margin: 0 0 1rem;
    line-height: 1.15;
  }
  .hl-sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #c4a46b;
    font-style: italic;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Back link */
  .hl-back {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #6a4820;
    text-decoration: none;
    transition: color 0.2s;
  }
  .hl-back:hover { color: #c4a46b; }

  /* Section wrapper */
  .hl-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    border-bottom: 1px solid #2e1f0d;
  }
  .hl-section:last-child { border-bottom: none; }
  .hl-center { text-align: center; }
  .hl-section-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    color: #f0e0bf;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #3a2510;
  }
  .hl-section-sub {
    font-size: 1.05rem;
    color: #c4ad84;
    font-style: italic;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }
  @media (max-width: 560px) {
    .hl-back { position: static; display: block; margin-bottom: 1rem; text-align: left; }
  }
</style>
