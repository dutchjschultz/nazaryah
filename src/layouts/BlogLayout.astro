---
import BaseLayout from './BaseLayout.astro';
import References from '../components/References.astro';
import AssociatedStudies from '../components/AssociatedStudies.astro';
import StudyRail from '../components/StudyRail.astro';
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, deck, date, category, tags, author, references } = post.data;

// Categories that are books on the shelf — these posts are chapters, so their
// header links back to the book rather than carrying the Trinity tag.
const bookCategories: Record<string, string> = {
  'The Bearer': '/books/the-bearer',
  'Five Titles, One Christ': '/books/five-titles',
  'What the Pulpit Buried': '/books/pulpit-buried',
};
const bookHref = bookCategories[category];

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Calculate reading time (rough estimate: 200 words per minute)
const { Content } = await post.render();
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);

// Companion study (if any) — rendered here as chrome so the shared post body
// stays portable. In the blog context the link points at the /blog/ sibling.
const companionSlug = post.data.companion;
const companion = companionSlug ? await getEntry('posts', companionSlug) : null;
---

<BaseLayout title={`${title} - Nazaryah`} description={description} article={true}>
  <article class="py-16 md:py-20" data-pagefind-body>
    <div class="container mx-auto px-6">
      <!-- Breadcrumb -->
      <nav class="max-w-4xl mx-auto mb-8 text-sm" style="font-family: var(--font-body);" data-pagefind-ignore>
        <ol class="flex items-center space-x-2" style="color: var(--ink-faded);">
          <li><a href="/" class="hover:text-[var(--bronze)]">Home</a></li>
          <li>/</li>
          <li><a href="/blog" class="hover:text-[var(--bronze)]">Blog</a></li>
          <li>/</li>
          <li class="font-medium" style="color: var(--ink);">{title}</li>
        </ol>
      </nav>

      <!-- Article Header -->
      <header class="max-w-4xl mx-auto mb-12 text-center" data-pagefind-ignore>
        {bookHref ? (
          <div class="mb-3">
            <a href={bookHref} class="bookshelf-home-tag">
              &#9672; From the Bookshelf
            </a>
          </div>
        ) : ['Trinity Studies', 'The Sender and The Sent', 'The Trinity Files'].includes(category) ? (
          <div class="mb-3">
            <a href="/trinity" class="trinity-home-tag">
              &#8592; Trinity
            </a>
          </div>
        ) : null}
        <div class="tag mb-4" style="color: var(--bronze);">
          {category}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6" style="font-family: var(--font-display); color: var(--deep-earth);">
          {title}
        </h1>
        {deck && (
          <p class="post-deck">{deck}</p>
        )}
        <div class="flex items-center justify-center gap-6 text-sm" style="color: var(--ink-faded); font-family: var(--font-body);">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>{author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{readingTime} min read</span>
          </div>
        </div>

        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center mt-6">
            {tags.map((tag) => (
              <span class="tag" style="color: var(--ink-faded);">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Association rail (cluster names + jump to panel) -->
      <div class="max-w-3xl mx-auto" data-pagefind-ignore>
        <StudyRail current={post} />
      </div>

      <!-- Article Content -->
      <div class="max-w-3xl mx-auto prose">
        <Content />
      </div>

      <!-- Companion study (wrapper-rendered; points at the /blog/ sibling) -->
      {companion && (
        <div class="max-w-3xl mx-auto companion-note" data-pagefind-ignore>
          <p class="companion-label">Read Next</p>
          <a href={`/blog/${companion.slug}`} class="companion-link">
            {companion.data.title} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      )}

      <!-- References Section -->
      {references && references.length > 0 && (
        <div class="max-w-3xl mx-auto" data-pagefind-ignore>
          <References references={references} />
        </div>
      )}

      <!-- Associated Studies (cross-reference clusters) -->
      <div class="max-w-3xl mx-auto" data-pagefind-ignore>
        <AssociatedStudies current={post} />
      </div>

      <!-- Article Footer -->
      <footer class="max-w-3xl mx-auto mt-16 pt-8 border-t border-[var(--sand-dark)]" data-pagefind-ignore>
        <div class="flex items-center justify-between">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 hover:underline"
            style="color: var(--bronze); font-family: var(--font-display); font-size: 0.9rem; letter-spacing: 1px;"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>

          <div class="flex gap-4">
            <button
              class="p-2 rounded border border-[var(--sand-dark)] hover:bg-[var(--stone)] hover:text-[var(--linen)] hover:border-[var(--stone)] transition-all"
              title="Share on Twitter"
              onclick={`window.open('https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}','_blank','width=550,height=420')`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </button>
          </div>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .trinity-home-tag {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8a6028;
    border: 1px solid #8a6028;
    border-radius: 2px;
    padding: 3px 10px;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .trinity-home-tag:hover {
    color: #c4a46b;
    border-color: #c4a46b;
    background: rgba(138, 96, 40, 0.08);
  }
  .bookshelf-home-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #8a6028;
    border: 1px solid #b89150;
    border-radius: 2px;
    padding: 3px 12px;
    text-decoration: none;
    background: linear-gradient(180deg, rgba(201,169,97,0.12), rgba(201,169,97,0.04));
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .bookshelf-home-tag:hover {
    color: #4a2808;
    border-color: #c4a46b;
    background: rgba(201, 169, 97, 0.18);
  }
  /* Deck: one-line orientation rendered from frontmatter, under the title */
  .post-deck {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--ink-faded);
    max-width: 46ch;
    margin: -0.5rem auto 1.75rem;
  }
  :global(.dark) .post-deck { color: var(--color-dark-secondary-text); }

  /* Companion study card (rendered by the wrapper, not the body) */
  .companion-note {
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--sand-dark);
    border-left: 3px solid var(--gold);
    border-radius: 3px;
    background: rgba(138, 101, 32, 0.04);
  }
  :global(.dark) .companion-note { border-color: rgba(196,173,132,0.28); border-left-color: var(--gold-light); }
  .companion-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.35rem;
  }
  :global(.dark) .companion-label { color: var(--gold-light); }
  .companion-link {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--deep-earth);
    text-decoration: none;
  }
  :global(.dark) .companion-link { color: var(--color-dark-text); }
  .companion-link:hover { color: var(--bronze); }
</style>

<style is:global>
  /* Enhance prose styles for biblical content */
  .prose {
    color: var(--ink);
  }

  .dark .prose {
    color: var(--color-dark-text);
  }

  .prose strong {
    font-weight: 600;
    color: var(--deep-earth);
  }

  .dark .prose strong {
    color: var(--color-dark-text);
  }

  .prose em {
    font-style: italic;
  }

  .prose ol,
  .prose ul {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .prose li {
    margin: 0.5rem 0;
  }

  .prose hr {
    border: 0;
    border-top: 1px solid var(--sand-dark);
    margin: 2rem 0;
  }

  .dark .prose hr {
    border-color: rgba(139,125,107,0.25);
  }
</style>
