---
import BaseLayout from './BaseLayout.astro';
import References from '../components/References.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, date, category, tags, author, references } = post.data;

// Format date
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Calculate reading time (rough estimate: 200 words per minute)
const { Content } = await post.render();
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---

<BaseLayout title={`${title} - Nazaryah`} description={description} article={true}>
  <article class="py-16 md:py-20">
    <div class="container mx-auto px-6">
      <!-- Breadcrumb -->
      <nav class="max-w-4xl mx-auto mb-8 font-sans text-sm">
        <ol class="flex items-center space-x-2 text-[var(--color-secondary-text)] dark:text-[var(--color-dark-text)]">
          <li><a href="/" class="hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)]">Home</a></li>
          <li>/</li>
          <li><a href="/blog" class="hover:text-[var(--color-accent)] dark:hover:text-[var(--color-dark-accent)]">Blog</a></li>
          <li>/</li>
          <li class="text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)] font-medium">{title}</li>
        </ol>
      </nav>

      <!-- Article Header -->
      <header class="max-w-4xl mx-auto mb-12 text-center">
        <div class="text-sm font-sans text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] mb-4 uppercase tracking-wide">
          {category}
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-[var(--color-primary-text)] dark:text-[var(--color-dark-text)] mb-6">
          {title}
        </h1>
        <div class="flex items-center justify-center gap-6 text-sm font-sans text-[var(--color-secondary-text)] dark:text-[var(--color-dark-text)]">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span>{author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{readingTime} min read</span>
          </div>
        </div>

        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center mt-6">
            {tags.map((tag) => (
              <span class="text-xs font-sans px-3 py-1 bg-[#f5f5f5] dark:bg-[#2a2a2a] text-[var(--color-secondary-text)] dark:text-[var(--color-dark-text)] rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Article Content -->
      <div class="max-w-3xl mx-auto prose">
        <Content />
      </div>

      <!-- References Section -->
      {references && references.length > 0 && (
        <div class="max-w-3xl mx-auto">
          <References references={references} />
        </div>
      )}

      <!-- Article Footer -->
      <footer class="max-w-3xl mx-auto mt-16 pt-8 border-t border-[var(--color-border)] dark:border-[var(--color-dark-accent)]">
        <div class="flex items-center justify-between">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 font-sans text-[var(--color-accent)] dark:text-[var(--color-dark-accent)] hover:underline"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>

          <div class="flex gap-4">
            <button
              class="p-2 rounded-lg border border-[var(--color-border)] dark:border-[var(--color-dark-accent)] hover:bg-[var(--color-accent)] hover:text-white hover:border-[var(--color-accent)] dark:hover:bg-[var(--color-dark-accent)] transition-all"
              title="Share on Twitter"
              onclick={`window.open('https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}','_blank','width=550,height=420')`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </button>
          </div>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Enhance prose styles for biblical content */
  .prose {
    color: var(--color-primary-text);
  }

  .dark .prose {
    color: var(--color-dark-text);
  }

  .prose strong {
    font-weight: 600;
    color: var(--color-primary-text);
  }

  .dark .prose strong {
    color: var(--color-dark-text);
  }

  .prose em {
    font-style: italic;
  }

  .prose ol,
  .prose ul {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .prose li {
    margin: 0.5rem 0;
  }

  .prose hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .dark .prose hr {
    border-color: var(--color-dark-accent);
  }
</style>
